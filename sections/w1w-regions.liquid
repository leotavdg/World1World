<section class="w1w-regions">
  <div class="w1w-regions__header">
    <h2 class="w1w-regions__heading">{{ section.settings.heading }}</h2>
  </div>
  <div class="w1w-regions__scroll-wrap">
    {%- for block in section.blocks -%}
      {%- assign card_tag = 'div' -%}
      {%- assign card_href = '' -%}
      {%- if block.settings.collection != blank -%}
        {%- assign card_tag = 'a' -%}
        {%- assign card_href = block.settings.collection.url -%}
      {%- elsif block.settings.url != blank -%}
        {%- assign card_tag = 'a' -%}
        {%- assign card_href = block.settings.url -%}
      {%- endif -%}
      <{{ card_tag }}
        class="w1w-region-card"
        {{ block.shopify_attributes }}
        {%- if card_href != '' -%} href="{{ card_href }}"{%- endif -%}
      >
        <div class="w1w-region-card__media">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'w1w-region-card__img', alt: block.settings.image.alt | escape }}
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'w1w-region-card__img w1w-region-card__img--placeholder' }}
          {%- endif -%}
          <div class="w1w-region-card__content">
            <h3 class="w1w-region-card__title">{{ block.settings.title }}</h3>
            <p class="w1w-region-card__subtitle">{{ block.settings.subtitle }}</p>
          </div>
        </div>
      </{{ card_tag }}>
    {%- else -%}
      {%- assign placeholder_regions = 'Europe,South America,Africa,Asia' | split: ',' -%}
      {%- for region in placeholder_regions -%}
        <div class="w1w-region-card">
          <div class="w1w-region-card__media">
            {{ 'collection-1' | placeholder_svg_tag: 'w1w-region-card__img w1w-region-card__img--placeholder' }}
            <div class="w1w-region-card__content">
              <h3 class="w1w-region-card__title">{{ region }}</h3>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
  .w1w-regions {
    padding: 96px 0 0;
    background: #131313;
    overflow: hidden;
  }
  .w1w-regions__header {
    max-width: 1536px;
    margin: 0 auto;
    padding: 0 32px;
    margin-bottom: 48px;
  }
  .w1w-regions__heading {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    margin: 0;
  }
  .w1w-regions__scroll-wrap {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    padding: 0 32px 32px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .w1w-regions__scroll-wrap::-webkit-scrollbar {
    display: none;
  }
  .w1w-region-card {
    flex: none;
    width: 400px;
    aspect-ratio: 16 / 9;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    display: block;
  }
  .w1w-region-card__media {
    width: 100%;
    height: 100%;
    position: relative;
  }
  .w1w-region-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1);
    transition: filter 0.7s;
    display: block;
  }
  .w1w-region-card__img--placeholder {
    background: #262626;
    filter: grayscale(1);
  }
  .w1w-region-card:hover .w1w-region-card__img {
    filter: grayscale(0);
  }
  .w1w-region-card__content {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 32px;
  }
  .w1w-region-card__title {
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.875rem;
    font-weight: 900;
    color: #fff;
    text-transform: uppercase;
    font-style: italic;
    letter-spacing: -0.03em;
    margin: 0 0 4px;
  }
  .w1w-region-card__subtitle {
    color: #f3ffca;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 0;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .w1w-region-card:hover .w1w-region-card__subtitle {
    opacity: 1;
  }
  @media (max-width: 768px) {
    .w1w-region-card {
      width: 280px;
    }
    .w1w-regions__scroll-wrap {
      padding: 0 16px 32px;
    }
    .w1w-regions__header {
      padding: 0 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "W1W Regions",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Regions"
    }
  ],
  "blocks": [
    {
      "type": "region",
      "name": "Region",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Europe"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Hover subtitle",
          "default": "Explore 24 Nations"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Link to collection"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Custom link (used if no collection selected)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "W1W Regions",
      "blocks": [
        {
          "type": "region",
          "settings": {
            "title": "Europe",
            "subtitle": "Explore 24 Nations"
          }
        },
        {
          "type": "region",
          "settings": {
            "title": "South America",
            "subtitle": "The Core of Passion"
          }
        },
        {
          "type": "region",
          "settings": {
            "title": "Africa",
            "subtitle": "Untamed Energy"
          }
        },
        {
          "type": "region",
          "settings": {
            "title": "Asia",
            "subtitle": "The Rising Stars"
          }
        }
      ]
    }
  ]
}
{% endschema %}
