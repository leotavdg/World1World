{%- assign threshold_cents = section.settings.free_ship_threshold | times: 100 -%}

<div class="w1w-cart-section">
  <div class="wrap">

    {%- if cart.item_count == 0 -%}

      <div class="w1w-cart-empty">
        <h2 class="w1w-cart-empty-h">{{ section.settings.empty_heading }}</h2>
        <p class="w1w-cart-empty-p">{{ section.settings.empty_subtext }}</p>
        <a href="{{ section.settings.empty_cta_url }}" class="btn btn-primary btn-lg">{{ section.settings.empty_cta_label }}</a>
      </div>

    {%- else -%}

      <div class="w1w-cart-grid">

        <!-- ── Left: Line items ── -->
        <div class="w1w-cart-lines" id="w1wCartLines">
          {%- for item in cart.items -%}
            {%- assign is_donation = false -%}
            {%- if item.properties.Donation == 'true' -%}
              {%- assign is_donation = true -%}
            {%- endif -%}

            {%- if is_donation -%}
              <div class="w1w-cart-item w1w-cart-item--donation" data-key="{{ item.key }}" data-qty="{{ item.quantity }}">
                <div class="w1w-cart-item-img w1w-cart-donation-icon">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--lime)" stroke-width="1.6"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </div>
                <div class="w1w-cart-item-body">
                  <h3 class="w1w-cart-item-name">DONATION</h3>
                  <p class="w1w-cart-item-meta">Support soccer athletes</p>
                  <button class="w1w-cart-remove" data-key="{{ item.key }}">{{ section.settings.remove_label }}</button>
                </div>
                <div class="w1w-cart-item-price">{{ item.line_price | money }}</div>
              </div>
            {%- else -%}
              <div class="w1w-cart-item" data-key="{{ item.key }}" data-qty="{{ item.quantity }}">
                <div class="w1w-cart-item-img">
                  {%- if item.image -%}
                    {{ item.image | image_url: width: 300 | image_tag: loading: 'lazy', alt: item.title, class: 'w1w-cart-item-photo' }}
                  {%- else -%}
                    <div class="bracelet-scene" style="aspect-ratio:1;height:100%">
                      <div class="floor"></div>
                      <div class="bracelet-ph" style="width:88%"></div>
                    </div>
                  {%- endif -%}
                </div>
                <div class="w1w-cart-item-body">
                  <h3 class="w1w-cart-item-name">{{ item.product.title | upcase }}</h3>
                  <p class="w1w-cart-item-meta">
                    {%- if item.variant_title and item.variant_title != 'Default Title' -%}
                      {{ item.variant_title }}
                    {%- endif -%}
                  </p>
                  <div class="w1w-cart-item-controls">
                    <div class="w1w-cart-qty">
                      <button class="w1w-cart-qty-btn" data-key="{{ item.key }}" data-delta="-1" aria-label="Decrease quantity">−</button>
                      <span class="w1w-cart-qty-num">{{ item.quantity }}</span>
                      <button class="w1w-cart-qty-btn" data-key="{{ item.key }}" data-delta="1" aria-label="Increase quantity">+</button>
                    </div>
                    <button class="w1w-cart-remove" data-key="{{ item.key }}">{{ section.settings.remove_label }}</button>
                  </div>
                </div>
                <div class="w1w-cart-item-price">{{ item.line_price | money }}</div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <!-- ── Right: Order summary ── -->
        <aside class="w1w-cart-summary" id="w1wCartSummary">
          <h2 class="w1w-cart-summary-h">{{ section.settings.summary_heading }}</h2>

          <div class="w1w-cart-sum-rows">
            <div class="w1w-sum-row">
              <span class="w1w-sum-label">{{ section.settings.subtotal_label }}</span>
              <span class="w1w-sum-val">{{ cart.original_total_price | money }}</span>
            </div>

            {%- if cart.total_discount > 0 -%}
              <div class="w1w-sum-row w1w-sum-row--disc">
                <span class="w1w-sum-label">{{ section.settings.discount_label }}</span>
                <span class="w1w-sum-val">− {{ cart.total_discount | money }}</span>
              </div>
            {%- endif -%}

            <div class="w1w-sum-row">
              <span class="w1w-sum-label">{{ section.settings.shipping_label }}</span>
              <span class="w1w-sum-val">
                {%- if cart.total_price >= threshold_cents -%}
                  {{ section.settings.free_shipping_text }}
                {%- else -%}
                  {{ section.settings.shipping_cost_text }}
                {%- endif -%}
              </span>
            </div>

            <div class="w1w-sum-row">
              <span class="w1w-sum-label">{{ section.settings.tax_label }}</span>
              <span class="w1w-sum-val">{{ section.settings.tax_text }}</span>
            </div>

            <div class="w1w-sum-row w1w-sum-row--total">
              <span class="w1w-sum-label w1w-sum-label--total">{{ section.settings.total_label }}</span>
              <span class="w1w-sum-val w1w-sum-val--total">{{ cart.total_price | money }}</span>
            </div>
          </div>

          {%- if section.settings.show_donation -%}
            <div class="w1w-donation" id="w1wDonation">
              <div class="w1w-donation__stripe"></div>
              <div class="w1w-donation__body">
                <div class="w1w-donation__top">
                  <div class="w1w-donation__icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                  </div>
                  <div>
                    <span class="w1w-donation__eyebrow">{{ section.settings.donation_heading }}</span>
                    <p class="w1w-donation__desc">{{ section.settings.donation_description }}</p>
                  </div>
                </div>
                <div class="w1w-donation__picks">
                  <button type="button" class="w1w-donation__pick" data-amount="1">
                    <span class="w1w-donation__pick-amt">$1</span>
                  </button>
                  <button type="button" class="w1w-donation__pick" data-amount="3">
                    <span class="w1w-donation__pick-amt">$3</span>
                  </button>
                  <button type="button" class="w1w-donation__pick" data-amount="5">
                    <span class="w1w-donation__pick-amt">$5</span>
                  </button>
                  <button type="button" class="w1w-donation__pick w1w-donation__pick--other" data-amount="custom">
                    <span class="w1w-donation__pick-amt">···</span>
                  </button>
                </div>
                <div class="w1w-donation__custom" id="w1wDonationCustom" style="display:none;">
                  <span class="w1w-donation__dollar">$</span>
                  <input type="number" class="w1w-donation__input" id="w1wDonationInput" min="1" max="500" placeholder="0" step="1">
                </div>
                <div class="w1w-donation__action">
                  <span class="w1w-donation__price" id="w1wDonationPrice"></span>
                  <button type="button" class="w1w-donation__submit" id="w1wDonationAdd" disabled>DONATE</button>
                </div>
                {%- if section.settings.donation_link_url != blank -%}
                  <a href="{{ section.settings.donation_link_url }}" class="w1w-donation__learn" target="_blank" rel="noopener">{{ section.settings.donation_link_label }} →</a>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          <a href="/checkout" class="btn btn-primary btn-lg w1w-sum-cta">{{ section.settings.checkout_label }}</a>
          <a href="{{ section.settings.keep_shopping_url }}" class="btn btn-ghost w1w-sum-cta w1w-sum-cta--ghost">{{ section.settings.keep_shopping_label }}</a>

          {%- if section.blocks.size > 0 -%}
            <div class="w1w-cart-trust">
              {%- for block in section.blocks -%}
                {%- if block.type == 'trust_badge' and block.settings.text != blank -%}
                  <span {{ block.shopify_attributes }}>★ {{ block.settings.text }}</span>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </aside>

      </div>

    {%- endif -%}

  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  function updateItem(key, qty, triggerEl) {
    if (triggerEl) triggerEl.disabled = true;
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty })
    })
    .then(function (r) { return r.json(); })
    .then(function () { location.reload(); })
    .catch(function () { if (triggerEl) triggerEl.disabled = false; });
  }

  document.querySelectorAll('.w1w-cart-qty-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item = btn.closest('.w1w-cart-item');
      var currentQty = parseInt(item.dataset.qty);
      var delta = parseInt(btn.dataset.delta);
      updateItem(btn.dataset.key, Math.max(0, currentQty + delta), btn);
    });
  });

  document.querySelectorAll('.w1w-cart-remove').forEach(function (btn) {
    btn.addEventListener('click', function () {
      updateItem(btn.dataset.key, 0, btn);
    });
  });

});
</script>

<script>
/* ── Donation — standalone script ── */
(function () {
  var w1wDonationAmount = 0;

  document.addEventListener('click', function (e) {
    /* Amount pick buttons */
    var pick = e.target.closest('.w1w-donation__pick');
    if (pick) {
      document.querySelectorAll('.w1w-donation__pick').forEach(function (b) { b.classList.remove('active'); });
      pick.classList.add('active');

      var customRow = document.getElementById('w1wDonationCustom');
      var customInput = document.getElementById('w1wDonationInput');

      if (pick.dataset.amount === 'custom') {
        if (customRow) customRow.style.display = 'flex';
        if (customInput) customInput.focus();
        w1wDonationAmount = parseInt(customInput ? customInput.value : 0) || 0;
      } else {
        if (customRow) customRow.style.display = 'none';
        w1wDonationAmount = parseInt(pick.dataset.amount);
      }

      var priceEl = document.getElementById('w1wDonationPrice');
      if (priceEl) priceEl.textContent = w1wDonationAmount > 0 ? '$' + w1wDonationAmount + '.00' : '';

      var addBtn = document.getElementById('w1wDonationAdd');
      if (addBtn) addBtn.disabled = w1wDonationAmount < 1;
      return;
    }

    /* Donate submit button */
    var submitBtn = e.target.closest('#w1wDonationAdd');
    if (!submitBtn || submitBtn.disabled) return;
    if (w1wDonationAmount < 1) return;

    var amt = w1wDonationAmount;
    submitBtn.disabled = true;
    submitBtn.textContent = 'ADDING…';

    /* Step 1: get donation product variant ID */
    fetch('/products/donation.js')
    .then(function (resp) {
      if (!resp.ok) throw new Error('Donation product not found — is it published?');
      return resp.json();
    })
    .then(function (prod) {
      var vid = prod.variants[0].id;

      /* Step 2: get current cart to find & remove any existing donation */
      return fetch('/cart.js').then(function (r) { return r.json(); })
      .then(function (cart) {
        var removes = [];
        for (var i = 0; i < cart.items.length; i++) {
          if (cart.items[i].product_id === prod.id || (cart.items[i].properties && cart.items[i].properties.Donation === 'true')) {
            removes.push(fetch('/cart/change.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: cart.items[i].key, quantity: 0 })
            }));
          }
        }
        if (removes.length > 0) {
          return removes.reduce(function (chain, p) { return chain.then(function () { return p; }); }, Promise.resolve());
        }
      })
      .then(function () {
        /* Step 3: add fresh donation */
        return fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            items: [{ id: vid, quantity: amt, properties: { 'Donation': 'true' } }]
          })
        });
      });
    })
    .then(function (resp) {
      if (!resp.ok) throw new Error('Cart add failed');
      return resp.json();
    })
    .then(function () {
      window.location.reload();
    })
    .catch(function (err) {
      window.alert('Donation error: ' + err.message);
      submitBtn.disabled = false;
      submitBtn.textContent = 'DONATE';
    });
  });

  /* Custom input listener */
  document.addEventListener('input', function (e) {
    if (e.target.id === 'w1wDonationInput') {
      w1wDonationAmount = parseInt(e.target.value) || 0;
      var priceEl = document.getElementById('w1wDonationPrice');
      if (priceEl) priceEl.textContent = w1wDonationAmount > 0 ? '$' + w1wDonationAmount + '.00' : '';
      var addBtn = document.getElementById('w1wDonationAdd');
      if (addBtn) addBtn.disabled = w1wDonationAmount < 1;
    }
  });
})();
</script>

{% stylesheet %}

.w1w-cart-section {
  padding: 48px 0 120px;
}

/* ── Empty state ── */
.w1w-cart-empty {
  text-align: center;
  padding: 80px 0;
}
.w1w-cart-empty-h {
  font-size: clamp(32px, 5vw, 48px);
  margin-bottom: 16px;
  letter-spacing: -0.02em;
  line-height: 1;
}
.w1w-cart-empty-p {
  color: var(--ink-2);
  margin-bottom: 32px;
  font-size: 15px;
  font-family: var(--font-body);
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
}

/* ── Two-column grid: items | summary ── */
.w1w-cart-grid {
  display: grid;
  grid-template-columns: 1fr 360px;
  grid-template-areas: "lines summary";
  gap: 48px;
  align-items: start;
}
.w1w-cart-lines  { grid-area: lines; }
.w1w-cart-summary { grid-area: summary; }

/* ── Line items ── */
.w1w-cart-lines {
  border-top: 1px solid var(--line);
}
.w1w-cart-item {
  display: grid;
  grid-template-columns: 120px 1fr auto;
  gap: 24px;
  padding: 24px 0;
  border-bottom: 1px solid var(--line);
  align-items: center;
}
.w1w-cart-item-img {
  width: 120px;
  aspect-ratio: 1;
  background: var(--bg-1);
  overflow: hidden;
  flex-shrink: 0;
}
.w1w-cart-item-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.w1w-cart-item-name {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 20px;
  letter-spacing: -0.01em;
  line-height: 1.1;
  margin: 0 0 4px;
}
.w1w-cart-item-meta {
  font-size: 12px;
  color: var(--ink-2);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin: 0 0 12px;
  font-family: var(--font-display);
  font-weight: 700;
}
.w1w-cart-item-controls {
  display: flex;
  gap: 16px;
  align-items: center;
}
.w1w-cart-item-price {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 24px;
  color: var(--lime);
  align-self: flex-start;
  text-align: right;
  white-space: nowrap;
}

/* Qty stepper */
.w1w-cart-qty {
  display: inline-flex;
  border: 1px solid var(--line);
  align-items: center;
}
.w1w-cart-qty-btn {
  width: 36px;
  height: 36px;
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 500;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ink-0);
  transition: background .12s;
  line-height: 1;
}
.w1w-cart-qty-btn:hover { background: var(--bg-2); }
.w1w-cart-qty-btn:disabled { opacity: 0.35; cursor: not-allowed; }
.w1w-cart-qty-num {
  width: 40px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 15px;
  border-left: 1px solid var(--line);
  border-right: 1px solid var(--line);
  height: 36px;
}
.w1w-cart-remove {
  color: var(--ink-3);
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-weight: 700;
  font-family: var(--font-display);
  background: none;
  border: none;
  cursor: pointer;
  transition: color .12s;
  padding: 0;
}
.w1w-cart-remove:hover { color: #ef4444; }

.w1w-cart-item--donation { border-bottom-style: dashed; }
.w1w-cart-donation-icon {
  background: rgba(243,255,202,0.06) !important;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ── Summary sidebar ── */
.w1w-cart-summary {
  background: var(--bg-1);
  border: 1px solid var(--line);
  padding: 32px;
  position: sticky;
  top: calc(var(--header-height, 112px) + 24px);
}
.w1w-cart-summary-h {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 700;
  margin: 0 0 20px;
  letter-spacing: -0.01em;
  color: var(--ink-0);
}

/* Price rows */
.w1w-cart-sum-rows {
  display: flex;
  flex-direction: column;
  margin-bottom: 20px;
}
.w1w-sum-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid var(--line);
}
.w1w-sum-row:last-child { border-bottom: none; }
.w1w-sum-row--disc .w1w-sum-label,
.w1w-sum-row--disc .w1w-sum-val { color: var(--lime); }
.w1w-sum-row--donation .w1w-sum-label,
.w1w-sum-row--donation .w1w-sum-val { color: var(--lime); }
.w1w-sum-label {
  font-size: 12px;
  color: var(--ink-2);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-family: var(--font-display);
  font-weight: 700;
}
.w1w-sum-val {
  font-size: 14px;
  color: var(--ink-0);
  font-family: var(--font-display);
  font-weight: 500;
}
.w1w-sum-row--total {
  border-top: 1px solid var(--line);
  border-bottom: none;
  padding-top: 16px;
  margin-top: 4px;
}
.w1w-sum-label--total {
  font-size: 14px;
  color: var(--ink-0);
  letter-spacing: 0.1em;
}
.w1w-sum-val--total {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 28px;
  color: var(--lime);
}

/* CTAs */
.w1w-sum-cta {
  display: block;
  width: 100%;
  text-align: center;
  margin-top: 12px;
}
.w1w-sum-cta--ghost {
  margin-top: 8px;
}

/* Trust badges */
.w1w-cart-trust {
  display: flex;
  gap: 6px;
  margin-top: 16px;
  flex-wrap: wrap;
  font-size: 10px;
  color: var(--ink-3);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-family: var(--font-display);
  font-weight: 700;
}

/* ── Donation ── */
.w1w-donation {
  margin-top: 20px;
  background: var(--bg-0);
  border: 1px solid var(--line);
  overflow: hidden;
}
.w1w-donation__stripe {
  height: 3px;
  background: linear-gradient(90deg, var(--lime-hot, #CAFD00), var(--lime, #F3FFCA));
}
.w1w-donation__body {
  padding: 20px;
}
.w1w-donation__top {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  margin-bottom: 16px;
}
.w1w-donation__icon {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(243,255,202,0.08);
  color: var(--lime);
  flex-shrink: 0;
}
.w1w-donation__eyebrow {
  display: block;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ink-0);
  margin-bottom: 4px;
}
.w1w-donation__desc {
  font-size: 11px;
  color: var(--ink-3);
  line-height: 1.5;
  margin: 0;
  font-family: var(--font-body);
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
}
.w1w-donation__picks {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 4px;
  margin-bottom: 12px;
}
.w1w-donation__pick {
  padding: 14px 0;
  border: 1px solid var(--line);
  background: transparent;
  cursor: pointer;
  transition: all .15s;
  text-align: center;
  position: relative;
}
.w1w-donation__pick:hover {
  border-color: rgba(243,255,202,0.25);
  background: rgba(243,255,202,0.04);
}
.w1w-donation__pick.active {
  border-color: var(--lime);
  background: rgba(243,255,202,0.06);
}
.w1w-donation__pick.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--lime);
}
.w1w-donation__pick-amt {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 16px;
  color: var(--ink-1);
  letter-spacing: -0.01em;
}
.w1w-donation__pick.active .w1w-donation__pick-amt {
  color: var(--lime);
}
.w1w-donation__pick--other .w1w-donation__pick-amt {
  font-size: 18px;
  letter-spacing: 0.15em;
}
.w1w-donation__custom {
  display: flex;
  align-items: center;
  border: 1px solid var(--line);
  margin-bottom: 12px;
  background: #1A1A1A !important;
}
.w1w-donation__dollar {
  padding: 0 10px;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 18px;
  color: var(--lime);
}
.w1w-donation__input {
  flex: 1;
  background: #1A1A1A !important;
  background-color: #1A1A1A !important;
  border: none;
  color: var(--ink-0);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 18px;
  padding: 12px 12px 12px 0;
  outline: none;
  -moz-appearance: textfield;
}
.w1w-donation__input::-webkit-outer-spin-button,
.w1w-donation__input::-webkit-inner-spin-button { -webkit-appearance: none; }
.w1w-donation__action {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.w1w-donation__price {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 22px;
  color: var(--lime);
  letter-spacing: -0.02em;
  text-align: center;
}
.w1w-donation__submit {
  width: 100%;
  padding: 12px;
  background: linear-gradient(180deg, rgba(243,255,202,0.12) 0%, rgba(243,255,202,0.04) 100%);
  border: 1px solid rgba(243,255,202,0.2);
  color: var(--lime);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all .18s;
}
.w1w-donation__submit:hover:not(:disabled) {
  background: var(--lime);
  color: var(--lime-dark);
  border-color: var(--lime);
}
.w1w-donation__submit:disabled {
  opacity: 0.25;
  cursor: not-allowed;
}
.w1w-donation__success {
  padding: 12px;
  text-align: center;
  color: var(--lime);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}
.w1w-donation__learn {
  display: block;
  margin-top: 12px;
  font-size: 10px;
  color: var(--ink-3);
  text-decoration: none;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-family: var(--font-display);
  font-weight: 700;
  text-align: center;
  transition: color .15s;
}
.w1w-donation__learn:hover { color: var(--lime); }

/* ── Responsive ── */
@media (max-width: 1000px) {
  .w1w-cart-grid { grid-template-columns: 1fr 300px; gap: 32px; }
}
@media (max-width: 800px) {
  .w1w-cart-grid {
    grid-template-columns: 1fr;
    grid-template-areas: "lines" "summary";
  }
  .w1w-cart-summary { position: static; }
}
@media (max-width: 600px) {
  .w1w-cart-item { grid-template-columns: 80px 1fr; gap: 16px; }
  .w1w-cart-item-img { width: 80px; }
  .w1w-cart-item-price { grid-column: 2; grid-row: 1; align-self: start; font-size: 18px; }
  .w1w-cart-item-body { grid-column: 2; }
}

{% endstylesheet %}

