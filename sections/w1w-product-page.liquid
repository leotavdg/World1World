{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_slug = product.handle
-%}

<div class="w1w-pdp-wrap">
  <div class="wrap">

    <!-- Breadcrumbs -->
    <nav class="w1w-crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/collections/all">Shop</a>
      <span>/</span>
      <span>{{ product.title }}</span>
    </nav>

    <!-- Country flag stripe (colors injected by JS) -->
    <div class="w1w-flag-stripe" id="w1wFlagStripe" aria-hidden="true">
      <div class="w1w-flag-stripe__seg" id="w1wFlagC1"></div>
      <div class="w1w-flag-stripe__seg" id="w1wFlagC2"></div>
      <div class="w1w-flag-stripe__seg" id="w1wFlagC3"></div>
    </div>

    <div class="w1w-pdp">

      <!-- ── Gallery ── -->
      <div class="w1w-pdp-gallery" id="w1wGallery">
        <div class="w1w-pdp-main-wrap">
          <div class="w1w-pdp-glow" id="w1wGlowEl"></div>
          <div class="w1w-pdp-main" id="w1wMainScene">
            <!-- Bracelet rendered by JS using country colors, or fallback to product image -->
            {%- if product.featured_image != blank -%}
              <img
                id="w1wFallbackImg"
                src="{{ product.featured_image | image_url: width: 1000 }}"
                alt="{{ product.featured_image.alt | default: product.title | escape }}"
                loading="eager"
                style="width:100%;height:100%;object-fit:cover;display:block"
              >
            {%- else -%}
              <div id="w1wBraceletMain" class="bracelet-scene" style="height:100%;aspect-ratio:1">
                <div class="floor"></div>
                <div class="bracelet-ph" id="w1wMainPh"></div>
              </div>
            {%- endif -%}
            <span class="w1w-pdp-tag" id="w1wMainTag">DROP 03</span>
          </div>
          <!-- Corner labels -->
          <span class="w1w-pdp-corner w1w-pdp-corner--tl">N° 2026</span>
          <span class="w1w-pdp-corner w1w-pdp-corner--br" id="w1wCornerBr">{{ product.title | upcase }}</span>
        </div>

        <div class="w1w-pdp-thumbs" id="w1wThumbs"></div>

        <!-- Edition info strip below thumbs -->
        <div class="w1w-pdp-edition-strip">
          <div class="w1w-pdp-edition-item">
            <span class="w1w-pdp-edition-label">Material</span>
            <span class="w1w-pdp-edition-val">Paracord 550</span>
          </div>
          <div class="w1w-pdp-edition-item">
            <span class="w1w-pdp-edition-label">Release</span>
            <span class="w1w-pdp-edition-val">Drop 03</span>
          </div>
          <div class="w1w-pdp-edition-item">
            <span class="w1w-pdp-edition-label">Year</span>
            <span class="w1w-pdp-edition-val">2026</span>
          </div>
        </div>
      </div>

      <!-- ── Info panel ── -->
      <div class="w1w-pdp-info">

        <span class="w1w-pdp-sub" id="w1wSub">
          {%- if product.metafields.custom.sub != blank -%}
            {{ product.metafields.custom.sub }}
          {%- else -%}
            WORLD 1 WORLD EDITION
          {%- endif -%}
        </span>

        <h1 class="w1w-pdp-title">{{ product.title | upcase }}</h1>

        <!-- Confederation / edition metadata -->
        <div class="w1w-pdp-meta">
          <div class="w1w-pdp-meta-item">
            <span class="w1w-pdp-meta-k">Confederation</span>
            <strong class="w1w-pdp-meta-v" id="w1wConfed">{{ product.vendor | default: 'W1W' }}</strong>
          </div>
          <div class="w1w-pdp-meta-item">
            <span class="w1w-pdp-meta-k">Edition</span>
            <strong class="w1w-pdp-meta-v">N°/2026</strong>
          </div>
          <div class="w1w-pdp-meta-item">
            <span class="w1w-pdp-meta-k">Status</span>
            <strong class="w1w-pdp-meta-v w1w-pdp-status {% unless current_variant.available %}w1w-pdp-status--out{% endunless %}">
              {{ current_variant.available | ternary: 'In Stock', 'Sold Out' }}
            </strong>
          </div>
        </div>

        <!-- Price -->
        <div class="w1w-pdp-price-row">
          <div class="w1w-pdp-price">{{ current_variant.price | money }}</div>
          <div class="w1w-pdp-price-note">Free shipping on 3+</div>
        </div>

        {%- form 'product', product, id: 'w1w-product-form', novalidate: 'novalidate' -%}
          <input type="hidden" name="id" id="w1wVariantId" value="{{ current_variant.id }}">

          {%- unless product.has_only_default_variant -%}
            <!-- Size -->
            <div class="w1w-field">
              <div class="w1w-field-label">
                <span>Size</span>
                <a href="#" onclick="alert('S: 6-7\" · M: 7-8\" · L: 8-9\"');return false" class="w1w-field-guide">Size guide →</a>
              </div>
              <div class="w1w-size-row" id="w1wSizeRow">
                {%- for variant in product.variants -%}
                  <button
                    type="button"
                    class="w1w-size-btn{% if variant == current_variant %} active{% endif %}{% unless variant.available %} w1w-size-btn--na{% endunless %}"
                    data-variant-id="{{ variant.id }}"
                    data-variant-price="{{ variant.price }}"
                    data-variant-available="{{ variant.available }}"
                    {% unless variant.available %}aria-disabled="true"{% endunless %}
                  >
                    {{ variant.title }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endunless -%}

          <!-- Bundle tier -->
          <div class="w1w-field">
            <div class="w1w-field-label">
              <span>Stack &amp; Save</span>
              <span class="w1w-field-lime">More = Less</span>
            </div>
            <div class="w1w-tier-row" id="w1wTierRow">
              <button type="button" class="w1w-tier active" data-t="0" data-qty="1" data-pct="0">
                <div class="w1w-tier-qty">1×</div>
                <div class="w1w-tier-lb">SINGLE</div>
                <div class="w1w-tier-off" style="opacity:0">—</div>
              </button>
              <button type="button" class="w1w-tier" data-t="1" data-qty="3" data-pct="10">
                <div class="w1w-tier-qty">3×</div>
                <div class="w1w-tier-lb">TRIO</div>
                <div class="w1w-tier-off">Save 10%</div>
              </button>
              <button type="button" class="w1w-tier" data-t="2" data-qty="5" data-pct="15">
                <div class="w1w-tier-qty">5×</div>
                <div class="w1w-tier-lb">FIVE-A-SIDE</div>
                <div class="w1w-tier-off">Save 15%</div>
              </button>
              <button type="button" class="w1w-tier" data-t="3" data-qty="8" data-pct="20">
                <div class="w1w-tier-qty">8×</div>
                <div class="w1w-tier-lb">STARTING XI</div>
                <div class="w1w-tier-off">Save 20%</div>
              </button>
            </div>
          </div>

          <!-- Qty -->
          <div class="w1w-field">
            <div class="w1w-field-label"><span>Quantity</span></div>
            <div class="w1w-qty-row">
              <div class="w1w-qty-ctrl">
                <button type="button" id="w1wQtyMinus">−</button>
                <input type="number" name="quantity" id="w1wQtyInput" value="1" min="1" readonly>
                <button type="button" id="w1wQtyPlus">+</button>
              </div>
              <span class="w1w-ships-note">Ships in 24h · Worldwide</span>
            </div>
          </div>

          <!-- Total -->
          <div class="w1w-pdp-total">
            <div>
              <div class="w1w-pdp-total-k">Total</div>
              <div class="w1w-pdp-total-hint" id="w1wTotalHint">1 band · no discount</div>
            </div>
            <div class="w1w-pdp-total-right">
              <span class="w1w-pdp-total-v" id="w1wTotalAmt">{{ current_variant.price | money }}</span>
              <span class="w1w-pdp-total-saved" id="w1wTotalSaved"></span>
            </div>
          </div>

          <!-- Actions -->
          <div class="w1w-pdp-actions">
            <button
              type="submit"
              class="btn btn-primary btn-lg btn-block"
              id="w1wAddBtn"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {%- if current_variant.available -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                ADD TO BAG
              {%- else -%}
                SOLD OUT
              {%- endif -%}
            </button>
            <a href="/collections/all" class="btn btn-ghost btn-block">STACK MORE NATIONS</a>
          </div>

        {%- endform -%}

        <!-- Trust / features grid -->
        <div class="w1w-pdp-feats">
          <div class="w1w-pdp-feat">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--lime)" stroke-width="1.6"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            <div>
              <div class="w1w-feat-title">Paracord 550</div>
              <div class="w1w-feat-desc">7-strand military-grade</div>
            </div>
          </div>
          <div class="w1w-pdp-feat">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--lime)" stroke-width="1.6"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <div>
              <div class="w1w-feat-title">Water &amp; Sweat Proof</div>
              <div class="w1w-feat-desc">Stadium to street</div>
            </div>
          </div>
          <div class="w1w-pdp-feat">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--lime)" stroke-width="1.6"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <div>
              <div class="w1w-feat-title">Ships in 24h</div>
              <div class="w1w-feat-desc">73 countries</div>
            </div>
          </div>
          <div class="w1w-pdp-feat">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--lime)" stroke-width="1.6"><polyline points="20 6 9 17 4 12"/></svg>
            <div>
              <div class="w1w-feat-title">30-Day Returns</div>
              <div class="w1w-feat-desc">No questions asked</div>
            </div>
          </div>
        </div>

      </div><!-- /.w1w-pdp-info -->
    </div><!-- /.w1w-pdp -->

  </div><!-- /.wrap -->
</div><!-- /.w1w-pdp-wrap -->

<!-- ── Marquee strip ── -->
<div class="w1w-strip w1w-strip--pdp">
  <div class="w1w-strip-track" aria-hidden="true">
    <span>WEAR YOUR NATION</span>
    <span>DROP 03</span>
    <span>2026 WORLD EDITION</span>
    <span>50+ NATIONS</span>
    <span>PARACORD 550</span>
    <span>SHIPS WORLDWIDE</span>
    <span>WEAR YOUR NATION</span>
    <span>DROP 03</span>
    <span>2026 WORLD EDITION</span>
    <span>50+ NATIONS</span>
    <span>PARACORD 550</span>
    <span>SHIPS WORLDWIDE</span>
  </div>
</div>

<!-- ── Feature deep-dive (from schema) ── -->
<div class="w1w-pdp-features-full">
  <div class="wrap">
    <div class="w1w-pdp-features-grid">
      <div class="w1w-pdp-feature-card reveal">
        <div class="w1w-pdp-feature-num">01</div>
        <h3 class="w1w-pdp-feature-title">{{ section.settings.feature_1_title }}</h3>
        <p class="w1w-pdp-feature-desc">{{ section.settings.feature_1_desc }}</p>
        <div class="w1w-pdp-feature-line"></div>
      </div>
      <div class="w1w-pdp-feature-card reveal">
        <div class="w1w-pdp-feature-num">02</div>
        <h3 class="w1w-pdp-feature-title">{{ section.settings.feature_2_title }}</h3>
        <p class="w1w-pdp-feature-desc">{{ section.settings.feature_2_desc }}</p>
        <div class="w1w-pdp-feature-line"></div>
      </div>
      <div class="w1w-pdp-feature-card reveal">
        <div class="w1w-pdp-feature-num">03</div>
        <h3 class="w1w-pdp-feature-title">WORLDWIDE DELIVERY</h3>
        <p class="w1w-pdp-feature-desc">Every order ships within 24 hours. 73 countries. Track from pitch to doorstep.</p>
        <div class="w1w-pdp-feature-line"></div>
      </div>
    </div>
  </div>
</div>

<!-- ── Bundle Builder ── -->
<section class="w1w-bundle" id="w1wBundle">
  <div class="wrap">
    <div class="w1w-bundle-head">
      <div>
        <span class="eyebrow">Build Your Squad</span>
        <h3 style="margin-top:8px">STACK THE NATIONS.</h3>
      </div>
      <div class="w1w-bundle-discount-note">3 = 10% off · 5 = 15% · 8 = 20%</div>
    </div>
    <p class="w1w-bundle-hint">Pick up to 11. Build the starting XI, gift the supporters, dress the group chat. Discounts apply automatically.</p>
    <div class="w1w-bundle-picker">
      <div class="w1w-bundle-grid" id="w1wBundleGrid"></div>
      <div class="w1w-bundle-summary">
        <h4>Your Squad</h4>
        <div class="w1w-bundle-picked" id="w1wBundlePicked">
          <div class="w1w-bundle-empty">Pick your first nation →</div>
        </div>
        <div class="w1w-bundle-math" id="w1wBundleMath"></div>
        <button class="btn btn-primary btn-block" id="w1wAddBundle">ADD SQUAD TO BAG →</button>
        <button class="w1w-bundle-clear" id="w1wClearBundle">Clear selection</button>
      </div>
    </div>
  </div>
</section>

<!-- ── Related Nations ── -->
<section class="w1w-related">
  <div class="wrap">
    <div class="sec-head">
      <div>
        <span class="eyebrow">More From This Region</span>
        <h2 style="margin-top:12px;font-size:clamp(28px,4vw,48px)">RELATED NATIONS</h2>
      </div>
      <a href="/collections/all" class="btn btn-outline">VIEW ALL →</a>
    </div>
    <div class="w1w-related-grid" id="w1wRelatedGrid"></div>
  </div>
</section>


<script>
(function(){
  var COUNTRIES = window.W1W_COUNTRIES || [];
  var TIERS = window.W1W_BUNDLE_TIERS || [
    {qty:1,label:'SINGLE',pct:0},{qty:3,label:'TRIO',pct:10},
    {qty:5,label:'FIVE-A-SIDE',pct:15},{qty:8,label:'STARTING XI',pct:20}
  ];
  var BASE_PRICE = window.W1W_PRICE || {{ current_variant.price | divided_by: 100.0 }};
  var slug = {{ product.handle | json }};
  var country = COUNTRIES.find(function(c){ return c.slug === slug; });

  // ── Apply country colors to flag stripe ──
  var colors = country ? country.colors : ['#F3FFCA','#131313','#F3FFCA'];
  var c1El = document.getElementById('w1wFlagC1');
  var c2El = document.getElementById('w1wFlagC2');
  var c3El = document.getElementById('w1wFlagC3');
  if (c1El) c1El.style.background = colors[0];
  if (c2El) c2El.style.background = colors[1];
  if (c3El) c3El.style.background = colors[2];

  // Apply glow color from primary country color
  var glowEl = document.getElementById('w1wGlowEl');
  if (glowEl) {
    glowEl.style.background = colors[0];
  }

  // ── Set sub / confed from data if found ──
  if (country){
    var subEl = document.getElementById('w1wSub');
    if (subEl) subEl.textContent = country.sub;
    var confedEl = document.getElementById('w1wConfed');
    if (confedEl) confedEl.textContent = country.confed;
  }

  // ── Gallery with color variants ──
  var variants = [
    colors,
    [colors[1], colors[2], colors[0]],
    [colors[2], colors[0], colors[1]],
    ['#0E0E0E', colors[0], colors[1]],
  ];
  var tags = ['DROP 03','AWAY','REVERSE','BLACKOUT'];

  function braceletScene(c, pct){
    pct = pct || '85%';
    return '<div class="bracelet-scene" style="height:100%;aspect-ratio:1"><div class="floor"></div><div class="bracelet-ph" style="--c1:'+c[0]+';--c2:'+c[1]+';--c3:'+c[2]+';width:'+pct+'"></div></div>';
  }

  // Replace main with bracelet if no product image
  var fallbackImg = document.getElementById('w1wFallbackImg');
  var mainScene = document.getElementById('w1wMainScene');
  if (!fallbackImg && mainScene){
    mainScene.innerHTML = braceletScene(variants[0], '80%') + '<span class="w1w-pdp-tag">' + tags[0] + '</span>';
  }
  var mainTag = document.getElementById('w1wMainTag');

  // Thumbs
  var thumbsEl = document.getElementById('w1wThumbs');
  if (thumbsEl){
    thumbsEl.innerHTML = variants.map(function(v,i){
      return '<div class="w1w-pdp-thumb'+(i===0?' active':'')+'" data-i="'+i+'">' + braceletScene(v,'90%') + '<span class="w1w-pdp-thumb-tag">'+tags[i]+'</span></div>';
    }).join('');
    thumbsEl.querySelectorAll('.w1w-pdp-thumb').forEach(function(el){
      el.addEventListener('click', function(){
        var i = parseInt(el.dataset.i);
        thumbsEl.querySelectorAll('.w1w-pdp-thumb').forEach(function(t){ t.classList.remove('active'); });
        el.classList.add('active');
        if (fallbackImg) {
          if (i === 0) { fallbackImg.style.display = 'block'; }
          else { fallbackImg.style.display = 'none'; }
        }
        if (mainScene) {
          var existing = mainScene.querySelector('.bracelet-scene');
          if (existing) existing.remove();
          if (!fallbackImg || i > 0) {
            var frag = document.createRange().createContextualFragment(braceletScene(variants[i],'80%'));
            mainScene.insertBefore(frag, mainScene.firstChild);
          }
        }
        if (mainTag) mainTag.textContent = tags[i];
        // Pulse glow on switch
        if (glowEl) { glowEl.style.opacity = '0.6'; setTimeout(function(){ glowEl.style.opacity = '0.35'; }, 400); }
      });
    });
  }

  // ── Size selection ──
  var selectedVariantId = {{ current_variant.id }};
  var selectedPrice = {{ current_variant.price }};
  document.querySelectorAll('.w1w-size-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      document.querySelectorAll('.w1w-size-btn').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      selectedVariantId = parseInt(btn.dataset.variantId);
      selectedPrice = parseInt(btn.dataset.variantPrice);
      var varInput = document.getElementById('w1wVariantId');
      if (varInput) varInput.value = selectedVariantId;
      recalc();
    });
  });

  // ── Tier + Qty ──
  var tierIdx = 0;
  var qty = 1;

  document.querySelectorAll('.w1w-tier').forEach(function(btn){
    btn.addEventListener('click', function(){
      document.querySelectorAll('.w1w-tier').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      tierIdx = parseInt(btn.dataset.t);
      qty = TIERS[tierIdx].qty;
      recalc();
    });
  });

  var minusBtn = document.getElementById('w1wQtyMinus');
  var plusBtn  = document.getElementById('w1wQtyPlus');
  if (minusBtn) minusBtn.addEventListener('click', function(){ qty = Math.max(1, qty - 1); recalc(); });
  if (plusBtn)  plusBtn.addEventListener('click',  function(){ qty = qty + 1; recalc(); });

  function recalc(){
    var tier = TIERS[tierIdx];
    var effQty = Math.max(qty, tier ? tier.qty : 1);
    var unitPrice = selectedPrice / 100;
    var gross = unitPrice * effQty;
    var pct = tier ? tier.pct : 0;
    var disc = gross * pct / 100;
    var total = gross - disc;

    var qtyInput = document.getElementById('w1wQtyInput');
    if (qtyInput) qtyInput.value = effQty;
    qty = effQty;

    var totalAmt = document.getElementById('w1wTotalAmt');
    if (totalAmt) totalAmt.textContent = '$' + total.toFixed(2);

    var totalHint = document.getElementById('w1wTotalHint');
    if (totalHint) totalHint.textContent = effQty + ' band' + (effQty > 1 ? 's' : '') + ' · ' + (pct ? pct + '% off' : 'no discount');

    var totalSaved = document.getElementById('w1wTotalSaved');
    if (totalSaved) totalSaved.textContent = disc > 0 ? 'Saved $' + disc.toFixed(2) : '';
  }
  recalc();

  // ── Bundle Builder ──
  var bundleGrid = document.getElementById('w1wBundleGrid');
  if (bundleGrid && COUNTRIES.length){
    bundleGrid.innerHTML = COUNTRIES.map(function(c){
      return '<div class="w1w-bundle-card" data-s="'+c.slug+'">' +
        '<div class="w1w-bundle-check">✓</div>' +
        '<div class="w1w-bundle-swatch" style="background:linear-gradient(90deg,'+c.colors[0]+' 33%,'+c.colors[1]+' 33% 66%,'+c.colors[2]+' 66%)"></div>' +
        '<div class="w1w-bundle-nm">'+c.name+'</div>' +
      '</div>';
    }).join('');

    var picked = new Set(country ? [country.slug] : []);
    if (country) {
      var startCard = bundleGrid.querySelector('[data-s="'+country.slug+'"]');
      if (startCard) startCard.classList.add('picked');
    }

    function renderBundle(){
      var list = COUNTRIES.filter(function(c){ return picked.has(c.slug); });
      var pickedEl = document.getElementById('w1wBundlePicked');
      if (!list.length){
        if (pickedEl) pickedEl.innerHTML = '<div class="w1w-bundle-empty">Pick your first nation →</div>';
      } else {
        if (pickedEl){
          pickedEl.innerHTML = list.map(function(c){
            return '<span class="w1w-bundle-pill" data-s="'+c.slug+'">'+c.name+' ×</span>';
          }).join('');
          pickedEl.querySelectorAll('.w1w-bundle-pill').forEach(function(el){
            el.addEventListener('click', function(){
              picked.delete(el.dataset.s);
              var card = bundleGrid.querySelector('[data-s="'+el.dataset.s+'"]');
              if (card) card.classList.remove('picked');
              renderBundle();
            });
          });
        }
      }
      var n = list.length;
      var unit = BASE_PRICE;
      var gross = n * unit;
      var discPct = n >= 8 ? 20 : n >= 5 ? 15 : n >= 3 ? 10 : 0;
      var disc = gross * discPct / 100;
      var total = gross - disc;
      var mathEl = document.getElementById('w1wBundleMath');
      var nextTier = TIERS.find(function(t){ return t.qty > n; });
      if (mathEl){
        mathEl.innerHTML =
          '<div class="w1w-bm-row"><span>'+n+' bands × $'+unit.toFixed(2)+'</span><span>$'+gross.toFixed(2)+'</span></div>' +
          (discPct ? '<div class="w1w-bm-row w1w-bm-disc"><span>Stack discount ('+discPct+'%)</span><span>− $'+disc.toFixed(2)+'</span></div>' : '') +
          (nextTier ? '<div class="w1w-bm-row" style="color:var(--ink-3);font-size:11px;letter-spacing:0.1em;text-transform:uppercase">+' + (nextTier.qty - n) + ' more for ' + nextTier.pct + '% off</div>' : '') +
          '<div class="w1w-bm-row w1w-bm-tot"><span>Total</span><span>$'+total.toFixed(2)+'</span></div>';
      }
      var addBundle = document.getElementById('w1wAddBundle');
      if (addBundle) addBundle.textContent = n ? 'ADD '+n+' TO BAG →' : 'PICK NATIONS →';
    }

    bundleGrid.querySelectorAll('.w1w-bundle-card').forEach(function(el){
      el.addEventListener('click', function(){
        var s = el.dataset.s;
        if (picked.has(s)){ picked.delete(s); el.classList.remove('picked'); }
        else { picked.add(s); el.classList.add('picked'); }
        renderBundle();
      });
    });

    var clearBtn = document.getElementById('w1wClearBundle');
    if (clearBtn) clearBtn.addEventListener('click', function(){
      picked.clear();
      bundleGrid.querySelectorAll('.w1w-bundle-card').forEach(function(el){ el.classList.remove('picked'); });
      renderBundle();
    });

    var addBundleBtn = document.getElementById('w1wAddBundle');
    if (addBundleBtn) addBundleBtn.addEventListener('click', function(){
      if (!picked.size) return;
      var n = picked.size;
      var discPct = n >= 8 ? 20 : n >= 5 ? 15 : n >= 3 ? 10 : 0;
      var effPrice = BASE_PRICE * (1 - discPct / 100);
      picked.forEach(function(s){
        var c = COUNTRIES.find(function(x){ return x.slug === s; });
        if (c && window.W1W) W1W.addToCart({ slug: s, name: c.name, size: 'M', qty: 1, price: effPrice });
      });
    });

    renderBundle();
  }

  // ── Related nations ──
  var relatedGrid = document.getElementById('w1wRelatedGrid');
  if (relatedGrid && country){
    var related = COUNTRIES.filter(function(c){ return c.region === country.region && c.slug !== country.slug; }).slice(0, 4);
    if (!related.length) related = COUNTRIES.filter(function(c){ return c.slug !== country.slug; }).slice(0, 4);
    relatedGrid.innerHTML = related.map(function(c){
      return '<a class="product-card reveal" href="/products/'+c.slug+'">' +
        '<div class="product-card-media">' +
          (c.host ? '<span class="product-card-tag" style="background:var(--lime-hot)">2026 HOST</span>' : (c.featured ? '<span class="product-card-tag">FEATURED</span>' : '')) +
          '<div class="bracelet-scene"><div class="floor"></div><div class="bracelet-ph" style="--c1:'+c.colors[0]+';--c2:'+c.colors[1]+';--c3:'+c.colors[2]+'"></div></div>' +
        '</div>' +
        '<div class="product-card-body">' +
          '<div><div class="product-card-country">'+c.name.toUpperCase()+'</div><div class="product-card-sub">'+c.sub+'</div></div>' +
          '<div class="product-card-price">$'+(window.W1W_PRICE || 5)+'</div>' +
        '</div>' +
      '</a>';
    }).join('');
  }

  // ── Scroll reveal ──
  var revealEls = document.querySelectorAll('.reveal');
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.1 });
    revealEls.forEach(function(el){ obs.observe(el); });
  } else {
    revealEls.forEach(function(el){ el.classList.add('in'); });
  }
})();
</script>


{% stylesheet %}

/* ── PDP wrapper ── */
.w1w-pdp-wrap {
  background: var(--bg-0);
  color: var(--ink-0);
  padding-bottom: 0;
}

/* ── Breadcrumbs ── */
.w1w-crumbs {
  padding: 24px 0 16px;
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--ink-3);
  display: flex;
  gap: 8px;
  align-items: center;
}
.w1w-crumbs a { color: var(--ink-3); transition: color .12s; }
.w1w-crumbs a:hover { color: var(--lime); }

/* ── Flag stripe ── */
.w1w-flag-stripe {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  height: 4px;
  margin-bottom: 40px;
  overflow: hidden;
}
.w1w-flag-stripe__seg {
  transition: background .4s ease;
}

/* ── Two-column layout ── */
.w1w-pdp {
  display: grid;
  grid-template-columns: 1.15fr 1fr;
  gap: 72px;
  padding: 0 0 120px;
  align-items: start;
}

/* ── Gallery ── */
.w1w-pdp-gallery {
  position: sticky;
  top: calc(var(--nav-h, 72px) + 24px);
}
.w1w-pdp-main-wrap {
  position: relative;
}
/* Ambient glow behind image */
.w1w-pdp-glow {
  position: absolute;
  inset: -40px;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.35;
  pointer-events: none;
  z-index: 0;
  transition: opacity .4s ease, background .4s ease;
}
.w1w-pdp-main {
  position: relative;
  aspect-ratio: 1 / 1;
  background:
    radial-gradient(ellipse 70% 50% at 50% 30%, rgba(243,255,202,0.07), transparent 60%),
    radial-gradient(ellipse at 50% 100%, rgba(0,0,0,0.5), transparent 60%),
    var(--bg-1);
  overflow: hidden;
  z-index: 1;
  box-shadow: 0 40px 80px -20px rgba(0,0,0,0.7);
}
.w1w-pdp-main .bracelet-scene { height: 100%; aspect-ratio: 1; }
.w1w-pdp-main .bracelet-ph { width: 80%; }

/* Corner accent labels */
.w1w-pdp-corner {
  position: absolute;
  padding: 6px 10px;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  z-index: 2;
}
.w1w-pdp-corner--tl {
  top: -10px;
  left: -10px;
  background: var(--bg-3);
  color: var(--lime);
  border: 1px solid rgba(243,255,202,0.2);
}
.w1w-pdp-corner--br {
  bottom: -10px;
  right: -10px;
  background: var(--lime);
  color: var(--lime-dark) !important;
  max-width: 160px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Tag overlay */
.w1w-pdp-tag {
  position: absolute;
  top: 20px; left: 20px;
  padding: 6px 10px;
  background: var(--lime);
  color: var(--lime-dark) !important;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  z-index: 2;
}

/* Thumbs */
.w1w-pdp-thumbs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 4px;
  margin-top: 16px;
}
.w1w-pdp-thumb {
  aspect-ratio: 1 / 1;
  background: var(--bg-2);
  cursor: pointer;
  overflow: hidden;
  border: 1px solid transparent;
  transition: border-color .15s;
  position: relative;
}
.w1w-pdp-thumb .bracelet-scene { height: 100%; aspect-ratio: 1; }
.w1w-pdp-thumb .bracelet-ph { width: 90%; }
.w1w-pdp-thumb:hover,
.w1w-pdp-thumb.active { border-color: var(--lime); }
.w1w-pdp-thumb-tag {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 8px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--ink-3);
  padding: 4px 6px;
  background: linear-gradient(0deg, rgba(0,0,0,0.7), transparent);
  text-align: center;
}
.w1w-pdp-thumb.active .w1w-pdp-thumb-tag { color: var(--lime); }

/* Edition strip */
.w1w-pdp-edition-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  margin-top: 4px;
  background: var(--line);
}
.w1w-pdp-edition-item {
  background: var(--bg-1);
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.w1w-pdp-edition-label {
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ink-3);
  font-family: var(--font-display);
}
.w1w-pdp-edition-val {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 13px;
  color: var(--lime);
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

/* ── Info panel ── */
.w1w-pdp-sub {
  font-family: var(--font-display);
  font-size: 11px;
  letter-spacing: 0.4em;
  color: var(--lime);
  text-transform: uppercase;
  margin-bottom: 16px;
  display: block;
}
.w1w-pdp-title {
  font-size: clamp(48px, 6vw, 80px);
  line-height: 0.88;
  margin-bottom: 24px;
  color: var(--ink-0);
  letter-spacing: -0.04em;
}

/* Metadata grid */
.w1w-pdp-meta {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--line);
  margin-bottom: 32px;
  border-top: 1px solid var(--line);
}
.w1w-pdp-meta-item {
  background: var(--bg-0);
  padding: 14px 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.w1w-pdp-meta-k {
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ink-3);
  font-family: var(--font-display);
}
.w1w-pdp-meta-v {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 13px;
  color: var(--lime);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.w1w-pdp-status { color: var(--lime); }
.w1w-pdp-status--out { color: var(--red) !important; }

/* Price */
.w1w-pdp-price-row {
  display: flex;
  align-items: baseline;
  gap: 16px;
  margin-bottom: 28px;
}
.w1w-pdp-price {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 56px;
  color: var(--lime);
  letter-spacing: -0.03em;
  line-height: 1;
}
.w1w-pdp-price-note {
  font-size: 12px;
  color: var(--ink-3);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-family: var(--font-display);
}

/* Fields */
.w1w-field { margin-bottom: 24px; }
.w1w-field-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: var(--font-display);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ink-2);
  margin-bottom: 10px;
}
.w1w-field-guide { color: var(--lime); text-decoration: none; }
.w1w-field-guide:hover { text-decoration: underline; }
.w1w-field-lime { color: var(--lime); }

/* Size buttons */
.w1w-size-row { display: flex; gap: 4px; }
.w1w-size-btn {
  flex: 1;
  padding: 14px 0;
  border: 1px solid var(--line);
  color: var(--ink-1);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.1em;
  cursor: pointer;
  background: var(--bg-1);
  text-transform: uppercase;
  transition: all .15s;
}
.w1w-size-btn:hover { border-color: var(--line-strong); background: var(--bg-2); }
.w1w-size-btn.active { background: var(--lime); color: var(--lime-dark) !important; border-color: var(--lime); }
.w1w-size-btn--na { opacity: 0.35; text-decoration: line-through; cursor: not-allowed; }

/* Tier row */
.w1w-tier-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px; }
.w1w-tier {
  padding: 16px 8px;
  border: 1px solid var(--line);
  background: var(--bg-1);
  cursor: pointer;
  text-align: left;
  transition: all .15s;
}
.w1w-tier:hover { border-color: var(--line-strong); background: var(--bg-2); }
.w1w-tier.active { background: var(--lime-softer); border-color: var(--lime); }
.w1w-tier-qty {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 22px;
  color: var(--ink-0);
}
.w1w-tier.active .w1w-tier-qty { color: var(--lime); }
.w1w-tier-lb {
  font-size: 9px;
  letter-spacing: 0.12em;
  color: var(--ink-2);
  text-transform: uppercase;
  margin-top: 4px;
}
.w1w-tier-off { font-size: 9px; color: var(--lime); margin-top: 4px; font-weight: 700; }

/* Qty */
.w1w-qty-row { display: flex; align-items: center; gap: 16px; }
.w1w-qty-ctrl { display: inline-flex; border: 1px solid var(--line); }
.w1w-qty-ctrl button {
  width: 44px; height: 44px;
  font-family: var(--font-display);
  font-size: 18px;
  color: var(--ink-0);
  background: transparent;
  border: none;
}
.w1w-qty-ctrl button:hover { color: var(--lime); }
.w1w-qty-ctrl input {
  width: 60px; text-align: center;
  background: transparent; color: var(--ink-0);
  border: 0; outline: none;
  font-family: var(--font-display); font-weight: 700; font-size: 18px;
  -moz-appearance: textfield;
}
.w1w-qty-ctrl input::-webkit-outer-spin-button,
.w1w-qty-ctrl input::-webkit-inner-spin-button { -webkit-appearance: none; }
.w1w-ships-note {
  font-size: 11px;
  color: var(--ink-3);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-family: var(--font-display);
}

/* Total */
.w1w-pdp-total {
  padding: 20px;
  background: var(--bg-1);
  border: 1px solid var(--line);
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}
.w1w-pdp-total-k {
  font-family: var(--font-display);
  font-size: 11px;
  letter-spacing: 0.2em;
  color: var(--ink-2);
  text-transform: uppercase;
}
.w1w-pdp-total-hint {
  font-size: 11px;
  color: var(--ink-3);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-top: 4px;
}
.w1w-pdp-total-right { display: flex; align-items: baseline; gap: 10px; }
.w1w-pdp-total-v {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 32px;
  color: var(--lime);
}
.w1w-pdp-total-saved {
  font-size: 11px;
  color: var(--lime);
  font-weight: 700;
  letter-spacing: 0.1em;
}

/* Actions */
.w1w-pdp-actions { display: grid; gap: 8px; margin: 20px 0 28px; }
.w1w-pdp-actions .btn-primary {
  position: relative;
  overflow: hidden;
}
.w1w-pdp-actions .btn-primary::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.15) 50%, transparent 100%);
  transform: translateX(-100%);
  transition: transform 0.6s ease;
}
.w1w-pdp-actions .btn-primary:hover::after { transform: translateX(100%); }

/* Features grid */
.w1w-pdp-feats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4px;
}
.w1w-pdp-feat {
  padding: 16px;
  background: var(--bg-1);
  border: 1px solid var(--line);
  font-size: 12px;
  color: var(--ink-1);
  display: flex;
  gap: 12px;
  align-items: flex-start;
  transition: border-color .15s;
}
.w1w-pdp-feat:hover { border-color: var(--line-strong); }
.w1w-feat-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 12px;
  color: var(--ink-0);
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
.w1w-feat-desc {
  font-size: 11px;
  color: var(--ink-3);
  letter-spacing: 0.05em;
  margin-top: 2px;
  text-transform: uppercase;
}

/* ── Marquee strip ── */
.w1w-strip--pdp {
  margin-top: 0;
  background: var(--bg-1);
}

/* ── Feature deep-dive ── */
.w1w-pdp-features-full {
  background: var(--bg-0);
  padding: 80px 0;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}
.w1w-pdp-features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--line);
}
.w1w-pdp-feature-card {
  background: var(--bg-0);
  padding: 48px 40px;
  position: relative;
  overflow: hidden;
}
.w1w-pdp-feature-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--lime), transparent);
  opacity: 0;
  transition: opacity .3s;
}
.w1w-pdp-feature-card:hover::before { opacity: 1; }
.w1w-pdp-feature-num {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.3em;
  color: var(--lime);
  text-transform: uppercase;
  margin-bottom: 24px;
}
.w1w-pdp-feature-title {
  font-size: clamp(18px, 2vw, 24px);
  color: var(--ink-0);
  margin-bottom: 16px;
  line-height: 1;
  letter-spacing: -0.02em;
}
.w1w-pdp-feature-desc {
  font-size: 14px;
  color: var(--ink-2);
  line-height: 1.7;
  font-family: var(--font-body);
  font-weight: 400;
  letter-spacing: 0;
  text-transform: none;
}
.w1w-pdp-feature-line {
  height: 1px;
  background: var(--line);
  margin-top: 32px;
  position: relative;
  overflow: hidden;
}
.w1w-pdp-feature-line::after {
  content: '';
  position: absolute;
  left: 0; top: 0;
  height: 100%;
  width: 60px;
  background: var(--lime);
}

/* ── Bundle section ── */
.w1w-bundle {
  padding: 80px 0;
  background:
    radial-gradient(ellipse at 80% 0%, rgba(243,255,202,0.05), transparent 50%),
    var(--bg-1);
  border-top: 1px solid var(--line);
}
.w1w-bundle-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 24px;
  margin-bottom: 8px;
  flex-wrap: wrap;
}
.w1w-bundle-head h3 { font-size: clamp(24px, 3vw, 40px); color: var(--ink-0); }
.w1w-bundle-discount-note {
  font-family: var(--font-display);
  font-size: 11px;
  letter-spacing: 0.2em;
  color: var(--lime);
  text-transform: uppercase;
}
.w1w-bundle-hint { color: var(--ink-2); margin-bottom: 40px; font-size: 14px; max-width: 520px; line-height: 1.7; }
.w1w-bundle-picker {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 32px;
  align-items: start;
}
.w1w-bundle-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(88px, 1fr));
  gap: 6px;
  max-height: 420px;
  overflow-y: auto;
  padding-right: 8px;
}
.w1w-bundle-grid::-webkit-scrollbar { width: 4px; }
.w1w-bundle-grid::-webkit-scrollbar-thumb { background: var(--line-strong); }
.w1w-bundle-card {
  aspect-ratio: 3/4;
  background: var(--bg-2);
  padding: 10px;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  border: 1px solid transparent;
  transition: all .15s;
  position: relative;
}
.w1w-bundle-card:hover { border-color: var(--line-strong); transform: translateY(-2px); }
.w1w-bundle-card.picked { border-color: var(--lime); background: var(--lime-softer); }
.w1w-bundle-swatch { aspect-ratio: 3/2; border-radius: 2px; }
.w1w-bundle-nm {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 9px;
  letter-spacing: 0.05em;
  color: var(--ink-0);
  text-transform: uppercase;
  line-height: 1.2;
}
.w1w-bundle-check {
  position: absolute;
  top: 6px; right: 6px;
  width: 18px; height: 18px;
  background: var(--lime);
  color: var(--lime-dark) !important;
  border-radius: 50%;
  display: none;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 700;
}
.w1w-bundle-card.picked .w1w-bundle-check { display: inline-flex; }
.w1w-bundle-summary {
  background: var(--bg-2);
  border: 1px solid var(--line);
  padding: 24px;
  position: sticky;
  top: calc(var(--nav-h, 72px) + 24px);
}
.w1w-bundle-summary h4 {
  font-family: var(--font-display);
  font-size: 11px;
  letter-spacing: 0.2em;
  color: var(--lime);
  margin-bottom: 16px;
  text-transform: uppercase;
}
.w1w-bundle-picked {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  min-height: 40px;
  margin-bottom: 16px;
  padding: 8px;
  border: 1px dashed var(--line);
}
.w1w-bundle-pill {
  padding: 4px 8px;
  background: var(--bg-3);
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  font-family: var(--font-display);
  font-weight: 700;
  color: var(--ink-0);
}
.w1w-bundle-pill:hover { background: var(--red); color: white; }
.w1w-bundle-empty {
  color: var(--ink-3);
  font-size: 12px;
  padding: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-family: var(--font-display);
}
.w1w-bundle-math {
  display: grid;
  gap: 8px;
  font-size: 13px;
  margin-bottom: 16px;
  padding: 16px 0;
  border-top: 1px solid var(--line);
}
.w1w-bm-row { display: flex; justify-content: space-between; color: var(--ink-1); }
.w1w-bm-disc { color: var(--lime); font-weight: 700; }
.w1w-bm-tot {
  border-top: 1px solid var(--line);
  padding-top: 12px;
  color: var(--ink-0);
  font-size: 15px;
  font-weight: 700;
}
.w1w-bm-tot span:last-child { color: var(--lime); font-family: var(--font-display); font-size: 22px; }
.w1w-bundle-clear {
  margin-top: 12px;
  width: 100%;
  color: var(--ink-3);
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  background: transparent;
  border: none;
  cursor: pointer;
  font-family: var(--font-display);
  transition: color .12s;
}
.w1w-bundle-clear:hover { color: var(--ink-1); }

/* ── Related nations ── */
.w1w-related {
  padding: 80px 0 120px;
  background: var(--bg-0);
  border-top: 1px solid var(--line);
}
.w1w-related-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}

/* ── Responsive ── */
@media (max-width: 960px) {
  .w1w-pdp { grid-template-columns: 1fr; gap: 40px; }
  .w1w-pdp-gallery { position: static; }
  .w1w-pdp-features-grid { grid-template-columns: 1fr; }
  .w1w-bundle-picker { grid-template-columns: 1fr; }
  .w1w-bundle-summary { position: static; }
  .w1w-bundle { padding: 48px 0; }
  .w1w-related-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .w1w-pdp-meta { grid-template-columns: repeat(3, 1fr); }
  .w1w-pdp-feats { grid-template-columns: 1fr; }
  .w1w-related-grid { grid-template-columns: repeat(2, 1fr); }
  .w1w-pdp-price { font-size: 44px; }
  .w1w-pdp-corner { display: none; }
}

{% endstylesheet %}

{% schema %}
{
  "name": "W1W Product Page",
  "settings": [
    {
      "type": "header",
      "content": "Feature Callouts"
    },
    {
      "type": "text",
      "id": "feature_1_title",
      "label": "Feature 1 title",
      "default": "COMFORT-FIT TECH"
    },
    {
      "type": "textarea",
      "id": "feature_1_desc",
      "label": "Feature 1 description",
      "default": "Dual-weave nylon designed for moisture-wicking under peak performance conditions."
    },
    {
      "type": "text",
      "id": "feature_2_title",
      "label": "Feature 2 title",
      "default": "RIO ENERGY SOUL"
    },
    {
      "type": "textarea",
      "id": "feature_2_desc",
      "label": "Feature 2 description",
      "default": "Signature 5-star embroidery celebrating the legacy of world football icons."
    }
  ],
  "presets": [
    {
      "name": "W1W Product Page"
    }
  ]
}
{% endschema %}
