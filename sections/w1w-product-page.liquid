{%- liquid
  assign current_variant = product.selected_or_first_available_variant
-%}

<div class="w1w-pdp-wrap">
  <div class="wrap">

    <nav class="w1w-crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span>
      <a href="/collections/all">Shop</a><span>/</span>
      <span>{{ product.title }}</span>
    </nav>

    <!-- Country flag stripe — JS fills in colors -->
    <div class="w1w-flag-stripe" id="w1wFlagStripe" aria-hidden="true">
      <div class="w1w-flag-stripe__seg" id="w1wFlagC1"></div>
      <div class="w1w-flag-stripe__seg" id="w1wFlagC2"></div>
      <div class="w1w-flag-stripe__seg" id="w1wFlagC3"></div>
    </div>

    <div class="w1w-pdp">

      <!-- ── Gallery ── -->
      <div class="w1w-pdp-gallery" id="w1wGallery">
        <div class="w1w-pdp-main-wrap">
          <div class="w1w-pdp-glow" id="w1wGlowEl"></div>
          <div class="w1w-pdp-main" id="w1wMainScene">
            {%- if product.featured_image != blank -%}
              <img
                id="w1wFallbackImg"
                src="{{ product.featured_image | image_url: width: 1000 }}"
                alt="{{ product.featured_image.alt | default: product.title | escape }}"
                loading="eager"
                style="width:100%;height:100%;object-fit:cover;display:block"
              >
            {%- else -%}
              <div class="bracelet-scene" style="height:100%;aspect-ratio:1">
                <div class="floor"></div>
                <div class="bracelet-ph" id="w1wMainPh"></div>
              </div>
            {%- endif -%}
            <span class="w1w-pdp-tag" id="w1wMainTag">DROP 03</span>
          </div>
          <span class="w1w-pdp-corner w1w-pdp-corner--tl">N° 2026</span>
          <span class="w1w-pdp-corner w1w-pdp-corner--br">{{ product.title | upcase }}</span>
        </div>

        <!-- Color-variant thumbnails (JS-populated) -->
        <div class="w1w-pdp-thumbs" id="w1wThumbs"></div>

        <div class="w1w-pdp-edition-strip">
          <div class="w1w-pdp-edition-item">
            <span class="w1w-pdp-edition-label">Material</span>
            <span class="w1w-pdp-edition-val">Paracord 550</span>
          </div>
          <div class="w1w-pdp-edition-item">
            <span class="w1w-pdp-edition-label">Release</span>
            <span class="w1w-pdp-edition-val">Drop 03</span>
          </div>
          <div class="w1w-pdp-edition-item">
            <span class="w1w-pdp-edition-label">Year</span>
            <span class="w1w-pdp-edition-val">2026</span>
          </div>
        </div>
      </div>

      <!-- ── Info panel ── -->
      <div class="w1w-pdp-info">

        <span class="w1w-pdp-sub" id="w1wSub">
          {%- if product.metafields.custom.sub != blank -%}
            {{ product.metafields.custom.sub }}
          {%- else -%}WORLD 1 WORLD EDITION{%- endif -%}
        </span>

        <h1 class="w1w-pdp-title">{{ product.title | upcase }}</h1>

        <div class="w1w-pdp-meta">
          <div class="w1w-pdp-meta-item">
            <span class="w1w-pdp-meta-k">Confederation</span>
            <strong class="w1w-pdp-meta-v" id="w1wConfed">{{ product.vendor | default: 'W1W' }}</strong>
          </div>
          <div class="w1w-pdp-meta-item">
            <span class="w1w-pdp-meta-k">Edition</span>
            <strong class="w1w-pdp-meta-v">N°/2026</strong>
          </div>
          <div class="w1w-pdp-meta-item">
            <span class="w1w-pdp-meta-k">Status</span>
            <strong class="w1w-pdp-meta-v{% unless current_variant.available %} w1w-pdp-status--out{% endunless %}">
              {{ current_variant.available | ternary: 'In Stock', 'Sold Out' }}
            </strong>
          </div>
        </div>

        <div class="w1w-pdp-price-row">
          <div class="w1w-pdp-price">{{ current_variant.price | money }}</div>
          <div class="w1w-pdp-price-note">Free shipping on 3+</div>
        </div>

        {%- form 'product', product, id: 'w1w-product-form', novalidate: 'novalidate' -%}
          <input type="hidden" name="id" id="w1wVariantId" value="{{ current_variant.id }}">

          {%- unless product.has_only_default_variant -%}
            <div class="w1w-field">
              <div class="w1w-field-label">
                <span>Size</span>
                <a href="#" onclick="alert('S: 6-7\" · M: 7-8\" · L: 8-9\"');return false" class="w1w-field-guide">Size guide →</a>
              </div>
              <div class="w1w-size-row">
                {%- for variant in product.variants -%}
                  <button
                    type="button"
                    class="w1w-size-btn{% if variant == current_variant %} active{% endif %}{% unless variant.available %} w1w-size-btn--na{% endunless %}"
                    data-variant-id="{{ variant.id }}"
                    data-variant-price="{{ variant.price }}"
                    {% unless variant.available %}aria-disabled="true"{% endunless %}
                  >{{ variant.title }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endunless -%}

          <!-- Stack & Save tier -->
          <div class="w1w-field">
            <div class="w1w-field-label">
              <span>Stack &amp; Save</span>
              <span class="w1w-field-lime">More = Less</span>
            </div>
            <div class="w1w-tier-row">
              <button type="button" class="w1w-tier active" data-t="0" data-qty="1" data-pct="0">
                <div class="w1w-tier-qty">1×</div>
                <div class="w1w-tier-lb">SINGLE</div>
                <div class="w1w-tier-off" style="opacity:0">—</div>
              </button>
              <button type="button" class="w1w-tier" data-t="1" data-qty="3" data-pct="10">
                <div class="w1w-tier-qty">3×</div>
                <div class="w1w-tier-lb">TRIO</div>
                <div class="w1w-tier-off">Save 10%</div>
              </button>
              <button type="button" class="w1w-tier" data-t="2" data-qty="5" data-pct="15">
                <div class="w1w-tier-qty">5×</div>
                <div class="w1w-tier-lb">FIVE-A-SIDE</div>
                <div class="w1w-tier-off">Save 15%</div>
              </button>
              <button type="button" class="w1w-tier" data-t="3" data-qty="8" data-pct="20">
                <div class="w1w-tier-qty">8×</div>
                <div class="w1w-tier-lb">STARTING XI</div>
                <div class="w1w-tier-off">Save 20%</div>
              </button>
            </div>
          </div>

          <div class="w1w-field">
            <div class="w1w-field-label"><span>Quantity</span></div>
            <div class="w1w-qty-row">
              <div class="w1w-qty-ctrl">
                <button type="button" id="w1wQtyMinus">−</button>
                <input type="number" name="quantity" id="w1wQtyInput" value="1" min="1" readonly>
                <button type="button" id="w1wQtyPlus">+</button>
              </div>
              <span class="w1w-ships-note">Ships in 24h · Worldwide</span>
            </div>
          </div>

          <div class="w1w-pdp-total">
            <div>
              <div class="w1w-pdp-total-k">Total</div>
              <div class="w1w-pdp-total-hint" id="w1wTotalHint">1 band · no discount</div>
            </div>
            <div class="w1w-pdp-total-right">
              <span class="w1w-pdp-total-v" id="w1wTotalAmt">{{ current_variant.price | money }}</span>
              <span class="w1w-pdp-total-saved" id="w1wTotalSaved"></span>
            </div>
          </div>

          <div class="w1w-pdp-actions">
            <button type="submit" class="btn btn-primary btn-lg btn-block w1w-atb" id="w1wAddBtn" {% unless current_variant.available %}disabled{% endunless %}>
              {%- if current_variant.available -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                ADD TO BAG
              {%- else -%}SOLD OUT{%- endif -%}
            </button>
            <a href="/collections/all" class="btn btn-ghost btn-block">STACK MORE NATIONS</a>
          </div>
        {%- endform -%}

        {%- if product.description != blank -%}
          <div class="w1w-pdp-desc rte">{{ product.description }}</div>
        {%- endif -%}

        <div class="w1w-pdp-feats">
          <div class="w1w-pdp-feat">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--lime)" stroke-width="1.6"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            <div><div class="w1w-feat-title">Paracord 550</div><div class="w1w-feat-desc">7-strand military-grade</div></div>
          </div>
          <div class="w1w-pdp-feat">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--lime)" stroke-width="1.6"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <div><div class="w1w-feat-title">Water &amp; Sweat Proof</div><div class="w1w-feat-desc">Stadium to street</div></div>
          </div>
          <div class="w1w-pdp-feat">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--lime)" stroke-width="1.6"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <div><div class="w1w-feat-title">Ships in 24h</div><div class="w1w-feat-desc">73 countries</div></div>
          </div>
          <div class="w1w-pdp-feat">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--lime)" stroke-width="1.6"><polyline points="20 6 9 17 4 12"/></svg>
            <div><div class="w1w-feat-title">30-Day Returns</div><div class="w1w-feat-desc">No questions asked</div></div>
          </div>
        </div>

      </div><!-- /.w1w-pdp-info -->
    </div><!-- /.w1w-pdp -->
  </div><!-- /.wrap -->
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var COUNTRIES = window.W1W_COUNTRIES || [];
  var TIERS = window.W1W_BUNDLE_TIERS || [
    {qty:1,pct:0},{qty:3,pct:10},{qty:5,pct:15},{qty:8,pct:20}
  ];
  var slug = {{ product.handle | json }};
  var country = COUNTRIES.find(function (c) { return c.slug === slug; });
  var colors = country ? country.colors : ['#F3FFCA','#131313','#F3FFCA'];

  // Flag stripe
  var fc = ['w1wFlagC1','w1wFlagC2','w1wFlagC3'];
  fc.forEach(function (id, i) {
    var el = document.getElementById(id);
    if (el) el.style.background = colors[i];
  });

  // Glow
  var glowEl = document.getElementById('w1wGlowEl');
  if (glowEl) glowEl.style.background = colors[0];

  // Sub / confed text
  if (country) {
    var subEl = document.getElementById('w1wSub');
    if (subEl) subEl.textContent = country.sub;
    var confedEl = document.getElementById('w1wConfed');
    if (confedEl) confedEl.textContent = country.confed;
  }

  // Gallery variants
  var variants = [
    colors,
    [colors[1], colors[2], colors[0]],
    [colors[2], colors[0], colors[1]],
    ['#0E0E0E', colors[0], colors[1]]
  ];
  var tags = ['DROP 03','AWAY','REVERSE','BLACKOUT'];

  function braceletScene(c, pct) {
    return '<div class="bracelet-scene" style="height:100%;aspect-ratio:1"><div class="floor"></div>' +
      '<div class="bracelet-ph" style="--c1:' + c[0] + ';--c2:' + c[1] + ';--c3:' + c[2] + ';width:' + (pct||'85%') + '"></div></div>';
  }

  var fallbackImg = document.getElementById('w1wFallbackImg');
  var mainScene   = document.getElementById('w1wMainScene');
  var mainTag     = document.getElementById('w1wMainTag');
  if (!fallbackImg && mainScene) {
    mainScene.innerHTML = braceletScene(variants[0],'80%') + '<span class="w1w-pdp-tag">DROP 03</span>';
  }

  var thumbsEl = document.getElementById('w1wThumbs');
  if (thumbsEl) {
    thumbsEl.innerHTML = variants.map(function (v, i) {
      return '<div class="w1w-pdp-thumb' + (i===0?' active':'') + '" data-i="' + i + '">' +
        braceletScene(v,'90%') +
        '<span class="w1w-pdp-thumb-tag">' + tags[i] + '</span>' +
        '</div>';
    }).join('');
    thumbsEl.querySelectorAll('.w1w-pdp-thumb').forEach(function (el) {
      el.addEventListener('click', function () {
        var i = parseInt(el.dataset.i);
        thumbsEl.querySelectorAll('.w1w-pdp-thumb').forEach(function (t) { t.classList.remove('active'); });
        el.classList.add('active');
        if (fallbackImg) fallbackImg.style.display = i===0 ? 'block' : 'none';
        if (mainScene) {
          var ex = mainScene.querySelector('.bracelet-scene');
          if (ex) ex.remove();
          if (!fallbackImg || i > 0) {
            mainScene.insertBefore(
              document.createRange().createContextualFragment(braceletScene(variants[i],'80%')),
              mainScene.firstChild
            );
          }
        }
        if (mainTag) mainTag.textContent = tags[i];
        if (glowEl) { glowEl.style.opacity='0.6'; setTimeout(function(){glowEl.style.opacity='0.35';},400); }
      });
    });
  }

  // Size buttons
  var selectedVariantId = {{ current_variant.id }};
  var selectedPrice = {{ current_variant.price }};
  document.querySelectorAll('.w1w-size-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.w1w-size-btn').forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      selectedVariantId = parseInt(btn.dataset.variantId);
      selectedPrice = parseInt(btn.dataset.variantPrice);
      var vi = document.getElementById('w1wVariantId');
      if (vi) vi.value = selectedVariantId;
      recalc();
    });
  });

  // Tier + qty
  var tierIdx = 0, qty = 1;
  document.querySelectorAll('.w1w-tier').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.w1w-tier').forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      tierIdx = parseInt(btn.dataset.t);
      qty = TIERS[tierIdx].qty;
      recalc();
    });
  });
  var minus = document.getElementById('w1wQtyMinus');
  var plus  = document.getElementById('w1wQtyPlus');
  if (minus) minus.addEventListener('click', function(){ qty=Math.max(1,qty-1); recalc(); });
  if (plus)  plus.addEventListener('click',  function(){ qty=qty+1; recalc(); });

  function recalc() {
    var tier = TIERS[tierIdx];
    var effQty = Math.max(qty, tier?tier.qty:1);
    var unit = selectedPrice/100;
    var gross = unit*effQty;
    var pct = tier?tier.pct:0;
    var disc = gross*pct/100;
    qty = effQty;
    var qi = document.getElementById('w1wQtyInput'); if(qi) qi.value=effQty;
    var ta = document.getElementById('w1wTotalAmt'); if(ta) ta.textContent='$'+(gross-disc).toFixed(2);
    var th = document.getElementById('w1wTotalHint'); if(th) th.textContent=effQty+' band'+(effQty>1?'s':'')+' · '+(pct?pct+'% off':'no discount');
    var ts = document.getElementById('w1wTotalSaved'); if(ts) ts.textContent=disc>0?'Saved $'+disc.toFixed(2):'';
  }
  recalc();
});
</script>

{% stylesheet %}

.w1w-pdp-wrap { background: var(--bg-0); color: var(--ink-0); }

.w1w-crumbs {
  padding: 24px 0 16px;
  font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--ink-3); display: flex; gap: 8px; align-items: center;
}
.w1w-crumbs a { color: var(--ink-3); transition: color .12s; }
.w1w-crumbs a:hover { color: var(--lime); }

.w1w-flag-stripe { display: grid; grid-template-columns: repeat(3,1fr); height: 4px; margin-bottom: 40px; }
.w1w-flag-stripe__seg { transition: background .5s; }

.w1w-pdp {
  display: grid; grid-template-columns: 1.15fr 1fr;
  gap: 72px; padding-bottom: 100px; align-items: start;
}

/* Gallery */
.w1w-pdp-gallery { position: sticky; top: calc(var(--nav-h,72px) + 24px); }
.w1w-pdp-main-wrap { position: relative; }
.w1w-pdp-glow {
  position: absolute; inset: -50px; border-radius: 50%;
  filter: blur(90px); opacity: 0.35; pointer-events: none; z-index: 0;
  transition: opacity .4s, background .5s;
}
.w1w-pdp-main {
  position: relative; aspect-ratio: 1;
  background:
    radial-gradient(ellipse 70% 50% at 50% 30%, rgba(243,255,202,0.07), transparent 60%),
    var(--bg-1);
  overflow: hidden; z-index: 1;
  box-shadow: 0 40px 80px -20px rgba(0,0,0,0.8);
}
.w1w-pdp-main .bracelet-scene { height: 100%; aspect-ratio: 1; }
.w1w-pdp-main .bracelet-ph { width: 80%; }
.w1w-pdp-corner {
  position: absolute; padding: 6px 10px; font-family: var(--font-display);
  font-weight: 700; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; z-index: 2;
}
.w1w-pdp-corner--tl { top: -10px; left: -10px; background: var(--bg-3); color: var(--lime); border: 1px solid rgba(243,255,202,0.2); }
.w1w-pdp-corner--br { bottom: -10px; right: -10px; background: var(--lime); color: var(--lime-dark) !important; max-width: 160px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.w1w-pdp-tag { position: absolute; top: 20px; left: 20px; padding: 6px 10px; background: var(--lime); color: var(--lime-dark) !important; font-family: var(--font-display); font-weight: 700; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; z-index: 2; }
.w1w-pdp-thumbs { display: grid; grid-template-columns: repeat(4,1fr); gap: 4px; margin-top: 16px; }
.w1w-pdp-thumb { aspect-ratio: 1; background: var(--bg-2); cursor: pointer; overflow: hidden; border: 1px solid transparent; transition: border-color .15s; position: relative; }
.w1w-pdp-thumb .bracelet-scene { height: 100%; }
.w1w-pdp-thumb .bracelet-ph { width: 90%; }
.w1w-pdp-thumb:hover, .w1w-pdp-thumb.active { border-color: var(--lime); }
.w1w-pdp-thumb-tag { position: absolute; bottom: 0; left: 0; right: 0; font-family: var(--font-display); font-weight: 700; font-size: 8px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3); padding: 4px 6px; background: linear-gradient(0deg,rgba(0,0,0,0.7),transparent); text-align: center; }
.w1w-pdp-thumb.active .w1w-pdp-thumb-tag { color: var(--lime); }
.w1w-pdp-edition-strip { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; margin-top: 4px; background: var(--line); }
.w1w-pdp-edition-item { background: var(--bg-1); padding: 12px; display: flex; flex-direction: column; gap: 4px; }
.w1w-pdp-edition-label { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-3); font-family: var(--font-display); }
.w1w-pdp-edition-val { font-family: var(--font-display); font-weight: 700; font-size: 13px; color: var(--lime); text-transform: uppercase; }

/* Info */
.w1w-pdp-sub { font-family: var(--font-display); font-size: 11px; letter-spacing: 0.4em; color: var(--lime); text-transform: uppercase; margin-bottom: 16px; display: block; }
.w1w-pdp-title { font-size: clamp(44px,5.5vw,76px); line-height: 0.88; margin-bottom: 24px; color: var(--ink-0); letter-spacing: -0.04em; }
.w1w-pdp-meta { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: var(--line); margin-bottom: 28px; border-top: 1px solid var(--line); }
.w1w-pdp-meta-item { background: var(--bg-0); padding: 14px 0; display: flex; flex-direction: column; gap: 6px; }
.w1w-pdp-meta-k { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-3); font-family: var(--font-display); }
.w1w-pdp-meta-v { font-family: var(--font-display); font-weight: 700; font-size: 13px; color: var(--lime); text-transform: uppercase; }
.w1w-pdp-status--out { color: var(--red) !important; }
.w1w-pdp-price-row { display: flex; align-items: baseline; gap: 16px; margin-bottom: 28px; }
.w1w-pdp-price { font-family: var(--font-display); font-weight: 700; font-size: 52px; color: var(--lime); letter-spacing: -0.03em; line-height: 1; }
.w1w-pdp-price-note { font-size: 11px; color: var(--ink-3); letter-spacing: 0.1em; text-transform: uppercase; font-family: var(--font-display); }
.w1w-field { margin-bottom: 24px; }
.w1w-field-label { display: flex; justify-content: space-between; align-items: center; font-family: var(--font-display); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-2); margin-bottom: 10px; }
.w1w-field-guide { color: var(--lime); text-decoration: none; }
.w1w-field-guide:hover { text-decoration: underline; }
.w1w-field-lime { color: var(--lime); }
.w1w-size-row { display: flex; gap: 4px; }
.w1w-size-btn { flex: 1; padding: 14px 0; border: 1px solid var(--line); color: var(--ink-1); font-family: var(--font-display); font-weight: 700; font-size: 13px; letter-spacing: 0.1em; cursor: pointer; background: var(--bg-1); text-transform: uppercase; transition: all .15s; }
.w1w-size-btn:hover { border-color: var(--line-strong); background: var(--bg-2); }
.w1w-size-btn.active { background: var(--lime); color: var(--lime-dark) !important; border-color: var(--lime); }
.w1w-size-btn--na { opacity: 0.35; text-decoration: line-through; cursor: not-allowed; }
.w1w-tier-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 4px; }
.w1w-tier { padding: 16px 8px; border: 1px solid var(--line); background: var(--bg-1); cursor: pointer; text-align: left; transition: all .15s; }
.w1w-tier:hover { border-color: var(--line-strong); background: var(--bg-2); }
.w1w-tier.active { background: var(--lime-softer); border-color: var(--lime); }
.w1w-tier-qty { font-family: var(--font-display); font-weight: 700; font-size: 22px; color: var(--ink-0); }
.w1w-tier.active .w1w-tier-qty { color: var(--lime); }
.w1w-tier-lb { font-size: 9px; letter-spacing: 0.12em; color: var(--ink-2); text-transform: uppercase; margin-top: 4px; }
.w1w-tier-off { font-size: 9px; color: var(--lime); margin-top: 4px; font-weight: 700; }
.w1w-qty-row { display: flex; align-items: center; gap: 16px; }
.w1w-qty-ctrl { display: inline-flex; border: 1px solid var(--line); }
.w1w-qty-ctrl button { width: 44px; height: 44px; font-family: var(--font-display); font-size: 18px; color: var(--ink-0); background: transparent; border: none; }
.w1w-qty-ctrl button:hover { color: var(--lime); }
.w1w-qty-ctrl input { width: 60px; text-align: center; background: transparent; color: var(--ink-0); border: 0; outline: none; font-family: var(--font-display); font-weight: 700; font-size: 18px; -moz-appearance: textfield; }
.w1w-qty-ctrl input::-webkit-outer-spin-button,
.w1w-qty-ctrl input::-webkit-inner-spin-button { -webkit-appearance: none; }
.w1w-ships-note { font-size: 11px; color: var(--ink-3); letter-spacing: 0.1em; text-transform: uppercase; font-family: var(--font-display); }
.w1w-pdp-total { padding: 20px; background: var(--bg-1); border: 1px solid var(--line); display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
.w1w-pdp-total-k { font-family: var(--font-display); font-size: 11px; letter-spacing: 0.2em; color: var(--ink-2); text-transform: uppercase; }
.w1w-pdp-total-hint { font-size: 11px; color: var(--ink-3); letter-spacing: 0.1em; text-transform: uppercase; margin-top: 4px; }
.w1w-pdp-total-right { display: flex; align-items: baseline; gap: 10px; }
.w1w-pdp-total-v { font-family: var(--font-display); font-weight: 700; font-size: 32px; color: var(--lime); }
.w1w-pdp-total-saved { font-size: 11px; color: var(--lime); font-weight: 700; letter-spacing: 0.1em; }
.w1w-pdp-actions { display: grid; gap: 8px; margin: 20px 0 24px; }
.w1w-atb { position: relative; overflow: hidden; }
.w1w-atb::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg,transparent 0%,rgba(255,255,255,0.15) 50%,transparent 100%); transform: translateX(-100%); transition: transform .6s; }
.w1w-atb:hover::after { transform: translateX(100%); }
.w1w-pdp-desc { font-size: 14px; color: var(--ink-2); line-height: 1.75; padding: 20px 0; border-top: 1px solid var(--line); margin-bottom: 24px; font-family: var(--font-body); font-weight: 400; text-transform: none; letter-spacing: 0; }
.w1w-pdp-desc p { margin-bottom: 12px; }
.w1w-pdp-desc p:last-child { margin-bottom: 0; }
.w1w-pdp-feats { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; }
.w1w-pdp-feat { padding: 16px; background: var(--bg-1); border: 1px solid var(--line); display: flex; gap: 12px; align-items: flex-start; transition: border-color .15s; }
.w1w-pdp-feat:hover { border-color: var(--line-strong); }
.w1w-feat-title { font-family: var(--font-display); font-weight: 700; font-size: 12px; color: var(--ink-0); letter-spacing: 0.05em; text-transform: uppercase; }
.w1w-feat-desc { font-size: 11px; color: var(--ink-3); letter-spacing: 0.05em; margin-top: 2px; text-transform: uppercase; }

@media (max-width: 900px) {
  .w1w-pdp { grid-template-columns: 1fr; gap: 40px; }
  .w1w-pdp-gallery { position: static; }
}
@media (max-width: 600px) {
  .w1w-pdp-price { font-size: 44px; }
  .w1w-pdp-feats { grid-template-columns: 1fr; }
  .w1w-pdp-corner { display: none; }
}

{% endstylesheet %}

{% schema %}
{
  "name": "W1W Product Page",
  "settings": [],
  "presets": [{ "name": "W1W Product Page" }]
}
{% endschema %}
