<!-- ── Upsell: Build Your Squad ── -->
<section class="w1w-upsell-section">
  <div class="wrap">

    <!-- Discount banner -->
    {%- if section.settings.show_banner -%}
    <div class="w1w-upsell-banner">
      <div class="w1w-upsell-banner__icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--lime-dark)" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
      </div>
      <div class="w1w-upsell-banner__body">
        <strong>{{ section.settings.banner_heading }}</strong>
        {{ section.settings.banner_body }}
      </div>
      <div class="w1w-upsell-banner__tiers">
        {%- if section.settings.tier_1_qty != blank -%}
          <span>{{ section.settings.tier_1_qty }}× = <strong>{{ section.settings.tier_1_pct }}% off</strong></span>
        {%- endif -%}
        {%- if section.settings.tier_2_qty != blank -%}
          <span>{{ section.settings.tier_2_qty }}× = <strong>{{ section.settings.tier_2_pct }}% off</strong></span>
        {%- endif -%}
        {%- if section.settings.tier_3_qty != blank -%}
          <span>{{ section.settings.tier_3_qty }}× = <strong>{{ section.settings.tier_3_pct }}% off</strong></span>
        {%- endif -%}
      </div>
    </div>
    {%- endif -%}

    <!-- Section header -->
    <div class="w1w-upsell-head">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="w1w-upsell-title">{{ section.settings.title }}</h2>
        {%- if section.settings.hint != blank -%}
          <p class="w1w-upsell-hint">{{ section.settings.hint }}</p>
        {%- endif -%}
      </div>
    </div>

    <div class="w1w-upsell-picker">

      <!-- Left: country grid with region filter -->
      <div class="w1w-upsell-grid-wrap">
        <div class="w1w-region-tabs" id="w1wRegionTabs">
          <button class="w1w-region-tab active" data-region="">All</button>
          <button class="w1w-region-tab" data-region="concacaf">CONCACAF</button>
          <button class="w1w-region-tab" data-region="southamerica">CONMEBOL</button>
          <button class="w1w-region-tab" data-region="europe">UEFA</button>
          <button class="w1w-region-tab" data-region="africa">CAF</button>
          <button class="w1w-region-tab" data-region="asia">AFC</button>
        </div>
        <div class="w1w-upsell-grid" id="w1wBundleGrid"></div>
      </div>

      <!-- Right: squad summary -->
      <div class="w1w-upsell-summary">
        <h4 class="w1w-upsell-summary-title">
          Your Squad
          <span class="w1w-squad-count" id="w1wSquadCount"></span>
        </h4>
        <div class="w1w-upsell-picked" id="w1wBundlePicked">
          <div class="w1w-upsell-empty">Pick your first nation →</div>
        </div>
        <div class="w1w-upsell-math" id="w1wBundleMath"></div>
        <button class="btn btn-primary btn-block" id="w1wAddBundle">PICK NATIONS →</button>
        <button class="w1w-upsell-clear" id="w1wClearBundle">Clear selection</button>
      </div>

    </div>
  </div>
</section>

<!-- ── Related Nations ── -->
<section class="w1w-related">
  <div class="wrap">
    <div class="sec-head">
      <div>
        {%- if section.settings.related_eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.related_eyebrow }}</span>
        {%- endif -%}
        <h2 style="margin-top:12px;font-size:clamp(28px,4vw,48px)">{{ section.settings.related_title }}</h2>
      </div>
      {%- if section.settings.related_cta_label != blank -%}
        <a href="{{ section.settings.related_cta_url }}" class="btn btn-outline">{{ section.settings.related_cta_label }}</a>
      {%- endif -%}
    </div>
    <div class="w1w-related-grid" id="w1wRelatedGrid"></div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var COUNTRIES = window.W1W_COUNTRIES || [];
  var TIERS = window.W1W_BUNDLE_TIERS || [
    {qty:1,pct:0},{qty:3,pct:10},{qty:5,pct:15},{qty:8,pct:20}
  ];
  var BASE_PRICE = window.W1W_PRICE || 5;

  // Detect current product slug from URL
  var pathParts = window.location.pathname.split('/');
  var slug = pathParts[pathParts.indexOf('products') + 1] || '';
  var country = COUNTRIES.find(function (c) { return c.slug === slug; });

  function braceletHTML(c) {
    return '<div class="bracelet-scene"><div class="floor"></div>' +
      '<div class="bracelet-ph" style="--c1:' + c.colors[0] + ';--c2:' + c.colors[1] + ';--c3:' + c.colors[2] + '"></div></div>';
  }

  // ── Bundle Builder ──
  var bundleGrid = document.getElementById('w1wBundleGrid');
  if (bundleGrid && COUNTRIES.length) {
    var activeRegion = '';
    var picked = new Set(country ? [country.slug] : []);

    function renderGrid() {
      var list = activeRegion
        ? COUNTRIES.filter(function (c) { return c.region === activeRegion; })
        : COUNTRIES;

      bundleGrid.innerHTML = list.map(function (c) {
        return '<div class="w1w-upsell-card' + (picked.has(c.slug) ? ' picked' : '') + '" data-s="' + c.slug + '">' +
          '<div class="w1w-upsell-check">✓</div>' +
          '<div class="w1w-upsell-swatch" style="background:linear-gradient(90deg,' + c.colors[0] + ' 33%,' + c.colors[1] + ' 33% 66%,' + c.colors[2] + ' 66%)"></div>' +
          '<div class="w1w-upsell-nm">' + c.name + '</div>' +
          '</div>';
      }).join('');

      bundleGrid.querySelectorAll('.w1w-upsell-card').forEach(function (el) {
        el.addEventListener('click', function () {
          var s = el.dataset.s;
          if (picked.has(s)) { picked.delete(s); el.classList.remove('picked'); }
          else { picked.add(s); el.classList.add('picked'); }
          renderSummary();
        });
      });
    }

    // Region tabs
    document.querySelectorAll('.w1w-region-tab').forEach(function (tab) {
      tab.addEventListener('click', function () {
        document.querySelectorAll('.w1w-region-tab').forEach(function (t) { t.classList.remove('active'); });
        tab.classList.add('active');
        activeRegion = tab.dataset.region;
        renderGrid();
      });
    });

    function renderSummary() {
      var list = COUNTRIES.filter(function (c) { return picked.has(c.slug); });
      var n = list.length;
      var countEl = document.getElementById('w1wSquadCount');
      if (countEl) countEl.textContent = n ? '(' + n + ')' : '';

      var pickedEl = document.getElementById('w1wBundlePicked');
      if (pickedEl) {
        if (!list.length) {
          pickedEl.innerHTML = '<div class="w1w-upsell-empty">Pick your first nation →</div>';
        } else {
          pickedEl.innerHTML = list.map(function (c) {
            return '<span class="w1w-upsell-pill" data-s="' + c.slug + '">' +
              '<span class="w1w-pill-swatch" style="background:linear-gradient(90deg,' + c.colors[0] + ' 33%,' + c.colors[1] + ' 33% 66%,' + c.colors[2] + ' 66%)"></span>' +
              c.name + ' ×</span>';
          }).join('');
          pickedEl.querySelectorAll('.w1w-upsell-pill').forEach(function (el) {
            el.addEventListener('click', function () {
              picked.delete(el.dataset.s);
              var card = bundleGrid.querySelector('[data-s="' + el.dataset.s + '"]');
              if (card) card.classList.remove('picked');
              renderSummary();
            });
          });
        }
      }

      var unit = BASE_PRICE;
      var gross = n * unit;
      var discPct = n >= 8 ? 20 : n >= 5 ? 15 : n >= 3 ? 10 : 0;
      var disc = gross * discPct / 100;
      var total = gross - disc;
      var nextTier = TIERS.find(function (t) { return t.qty > n; });
      var mathEl = document.getElementById('w1wBundleMath');
      if (mathEl) {
        mathEl.innerHTML = n > 0 ? (
          '<div class="w1w-math-row"><span>' + n + ' band' + (n>1?'s':'') + ' × $' + unit.toFixed(2) + '</span><span>$' + gross.toFixed(2) + '</span></div>' +
          (discPct ? '<div class="w1w-math-row w1w-math-disc"><span>Stack discount (' + discPct + '%)</span><span>−$' + disc.toFixed(2) + '</span></div>' : '') +
          (nextTier ? '<div class="w1w-math-hint">+' + (nextTier.qty-n) + ' more for ' + nextTier.pct + '% off</div>' : '') +
          '<div class="w1w-math-row w1w-math-tot"><span>Total</span><span>$' + total.toFixed(2) + '</span></div>'
        ) : '';
      }

      var addBtn = document.getElementById('w1wAddBundle');
      if (addBtn) addBtn.textContent = n ? 'ADD ' + n + ' TO BAG →' : 'PICK NATIONS →';
    }

    var clearBtn = document.getElementById('w1wClearBundle');
    if (clearBtn) clearBtn.addEventListener('click', function () {
      picked.clear(); renderGrid(); renderSummary();
    });

    var addBtn = document.getElementById('w1wAddBundle');
    if (addBtn) addBtn.addEventListener('click', function () {
      if (!picked.size) return;
      var n = picked.size;
      var discPct = n>=8?20:n>=5?15:n>=3?10:0;
      var effPrice = BASE_PRICE * (1 - discPct/100);
      picked.forEach(function (s) {
        var c = COUNTRIES.find(function (x) { return x.slug === s; });
        if (c && window.W1W) window.W1W.addToCart({ slug:s, name:c.name, size:'M', qty:1, price:effPrice });
      });
    });

    renderGrid();
    renderSummary();
  }

  // ── Related Nations ──
  var relatedGrid = document.getElementById('w1wRelatedGrid');
  if (relatedGrid) {
    var related = country
      ? COUNTRIES.filter(function (c) { return c.region === country.region && c.slug !== country.slug; }).slice(0,4)
      : COUNTRIES.filter(function (c) { return c.slug !== slug; }).slice(0,4);
    relatedGrid.innerHTML = related.map(function (c) {
      return '<a class="product-card reveal" href="/products/' + c.slug + '">' +
        '<div class="product-card-media">' +
          (c.host ? '<span class="product-card-tag" style="background:var(--lime-hot)">2026 HOST</span>' :
           c.featured ? '<span class="product-card-tag">FEATURED</span>' : '') +
          braceletHTML(c) +
        '</div>' +
        '<div class="product-card-body">' +
          '<div><div class="product-card-country">' + c.name.toUpperCase() + '</div>' +
          '<div class="product-card-sub">' + c.sub + '</div></div>' +
          '<div class="product-card-price">$' + (window.W1W_PRICE||5) + '</div>' +
        '</div>' +
        '</a>';
    }).join('');

    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); } });
      }, { threshold: 0.1 });
      relatedGrid.querySelectorAll('.reveal').forEach(function (el) { obs.observe(el); });
    } else {
      relatedGrid.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('in'); });
    }
  }
});
</script>

{% stylesheet %}

/* ── Upsell section ── */
.w1w-upsell-section {
  padding: 80px 0;
  background: radial-gradient(ellipse at 80% 0%, rgba(243,255,202,0.05), transparent 50%), var(--bg-1);
  border-top: 1px solid var(--line);
}

/* Discount banner */
.w1w-upsell-banner {
  display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
  background: linear-gradient(135deg, var(--lime) 0%, var(--lime-hot) 100%);
  color: var(--lime-dark) !important;
  padding: 20px 24px; margin-bottom: 56px;
}
.w1w-upsell-banner__icon { flex-shrink: 0; display: flex; }
.w1w-upsell-banner__body { flex: 1; font-size: 14px; color: var(--lime-dark) !important; line-height: 1.5; }
.w1w-upsell-banner__body strong { font-family: var(--font-display); font-weight: 700; display: block; font-size: 15px; margin-bottom: 4px; }
.w1w-upsell-banner__tiers { display: flex; gap: 16px; font-family: var(--font-display); font-size: 12px; color: rgba(81,103,0,0.8) !important; flex-wrap: wrap; }
.w1w-upsell-banner__tiers strong { color: var(--lime-dark) !important; font-weight: 700; }

/* Section head */
.w1w-upsell-head { margin-bottom: 32px; }
.w1w-upsell-title { font-size: clamp(28px, 3.5vw, 48px); color: var(--ink-0); margin-top: 8px; }
.w1w-upsell-hint { color: var(--ink-2); font-size: 14px; line-height: 1.7; max-width: 560px; margin-top: 12px; font-family: var(--font-body); font-weight: 400; text-transform: none; letter-spacing: 0; }

/* Picker layout */
.w1w-upsell-picker { display: grid; grid-template-columns: 1fr 320px; gap: 32px; align-items: start; }
.w1w-upsell-grid-wrap {}

/* Region tabs */
.w1w-region-tabs { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 12px; }
.w1w-region-tab { padding: 8px 14px; background: var(--bg-2); border: 1px solid var(--line); color: var(--ink-2); font-family: var(--font-display); font-weight: 700; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; cursor: pointer; transition: all .15s; }
.w1w-region-tab:hover { border-color: var(--line-strong); color: var(--ink-0); }
.w1w-region-tab.active { background: var(--lime-softer); border-color: var(--lime); color: var(--lime); }

/* Country card grid */
.w1w-upsell-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(88px, 1fr));
  gap: 6px; max-height: 460px; overflow-y: auto; padding-right: 4px;
}
.w1w-upsell-grid::-webkit-scrollbar { width: 4px; }
.w1w-upsell-grid::-webkit-scrollbar-thumb { background: var(--line-strong); }
.w1w-upsell-card {
  aspect-ratio: 3/4; background: var(--bg-2); padding: 10px; cursor: pointer;
  display: flex; flex-direction: column; justify-content: space-between;
  border: 1px solid transparent; transition: all .15s; position: relative;
}
.w1w-upsell-card:hover { border-color: var(--line-strong); transform: translateY(-2px); }
.w1w-upsell-card.picked { border-color: var(--lime); background: var(--lime-softer); }
.w1w-upsell-swatch { aspect-ratio: 3/2; border-radius: 2px; }
.w1w-upsell-nm { font-family: var(--font-display); font-weight: 700; font-size: 9px; letter-spacing: 0.05em; color: var(--ink-0); text-transform: uppercase; line-height: 1.2; }
.w1w-upsell-check { position: absolute; top: 6px; right: 6px; width: 18px; height: 18px; background: var(--lime); color: var(--lime-dark) !important; border-radius: 50%; display: none; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; }
.w1w-upsell-card.picked .w1w-upsell-check { display: inline-flex; }

/* Summary sidebar */
.w1w-upsell-summary { background: var(--bg-2); border: 1px solid var(--line); padding: 24px; position: sticky; top: calc(var(--nav-h, 72px) + 24px); }
.w1w-upsell-summary-title { font-family: var(--font-display); font-size: 11px; letter-spacing: 0.2em; color: var(--lime); margin-bottom: 16px; text-transform: uppercase; font-weight: 700; }
.w1w-squad-count { color: var(--ink-3); }
.w1w-upsell-picked { display: flex; flex-wrap: wrap; gap: 4px; min-height: 48px; margin-bottom: 16px; padding: 8px; border: 1px dashed var(--line); }
.w1w-upsell-pill { display: inline-flex; align-items: center; gap: 6px; padding: 4px 8px; background: var(--bg-3); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer; font-family: var(--font-display); font-weight: 700; color: var(--ink-0); transition: background .12s; }
.w1w-upsell-pill:hover { background: var(--red); color: white; }
.w1w-pill-swatch { display: inline-block; width: 16px; height: 10px; border-radius: 1px; flex-shrink: 0; }
.w1w-upsell-empty { color: var(--ink-3); font-size: 12px; padding: 12px; letter-spacing: 0.1em; text-transform: uppercase; font-family: var(--font-display); }
.w1w-upsell-math { display: grid; gap: 8px; font-size: 13px; margin-bottom: 16px; padding: 16px 0; border-top: 1px solid var(--line); }
.w1w-math-row { display: flex; justify-content: space-between; color: var(--ink-1); }
.w1w-math-disc { color: var(--lime); font-weight: 700; }
.w1w-math-hint { color: var(--ink-3); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; font-family: var(--font-display); }
.w1w-math-tot { border-top: 1px solid var(--line); padding-top: 12px; color: var(--ink-0); font-size: 15px; font-weight: 700; }
.w1w-math-tot span:last-child { color: var(--lime); font-family: var(--font-display); font-size: 22px; }
.w1w-upsell-clear { margin-top: 12px; width: 100%; color: var(--ink-3); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; background: transparent; border: none; cursor: pointer; font-family: var(--font-display); transition: color .12s; }
.w1w-upsell-clear:hover { color: var(--ink-1); }

/* ── Related Nations ── */
.w1w-related { padding: 80px 0 120px; background: var(--bg-0); border-top: 1px solid var(--line); }
.w1w-related-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }

@media (max-width: 1024px) { .w1w-upsell-picker { grid-template-columns: 1fr 280px; } }
@media (max-width: 900px) {
  .w1w-upsell-picker { grid-template-columns: 1fr; }
  .w1w-upsell-summary { position: static; }
  .w1w-related-grid { grid-template-columns: repeat(2, 1fr); }
  .w1w-upsell-banner { flex-direction: column; gap: 12px; }
  .w1w-upsell-section { padding: 48px 0; }
}

{% endstylesheet %}

{% schema %}
{
  "name": "W1W PDP Upsell",
  "settings": [
    {
      "type": "header",
      "content": "Discount Banner"
    },
    { "type": "checkbox", "id": "show_banner", "label": "Show discount banner", "default": true },
    { "type": "text", "id": "banner_heading", "label": "Banner heading", "default": "Stack 3+ nations and save up to 20%." },
    { "type": "text", "id": "banner_body", "label": "Banner body text", "default": "Discount applied automatically at checkout — no code needed." },
    {
      "type": "header",
      "content": "Tier 1"
    },
    { "type": "number", "id": "tier_1_qty", "label": "Tier 1 quantity", "default": 3 },
    { "type": "number", "id": "tier_1_pct", "label": "Tier 1 discount %", "default": 10 },
    {
      "type": "header",
      "content": "Tier 2"
    },
    { "type": "number", "id": "tier_2_qty", "label": "Tier 2 quantity", "default": 5 },
    { "type": "number", "id": "tier_2_pct", "label": "Tier 2 discount %", "default": 15 },
    {
      "type": "header",
      "content": "Tier 3"
    },
    { "type": "number", "id": "tier_3_qty", "label": "Tier 3 quantity", "default": 8 },
    { "type": "number", "id": "tier_3_pct", "label": "Tier 3 discount %", "default": 20 },
    {
      "type": "header",
      "content": "Bundle Builder"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow label", "default": "Build Your Squad" },
    { "type": "text", "id": "title", "label": "Section title", "default": "STACK THE NATIONS." },
    { "type": "textarea", "id": "hint", "label": "Hint text", "default": "Pick up to 11 nations. Build the starting XI, gift the supporters, dress the group chat." },
    {
      "type": "header",
      "content": "Related Nations"
    },
    { "type": "text", "id": "related_eyebrow", "label": "Eyebrow label", "default": "More From This Region" },
    { "type": "text", "id": "related_title", "label": "Section title", "default": "RELATED NATIONS" },
    { "type": "text", "id": "related_cta_label", "label": "CTA button label", "default": "VIEW ALL →" },
    { "type": "url", "id": "related_cta_url", "label": "CTA button URL", "default": "/collections/all" }
  ],
  "presets": [{ "name": "W1W PDP Upsell" }]
}
{% endschema %}
