<section class="w1w-faq-hero">
  <div class="wrap">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h1 class="w1w-faq-hero-h" style="margin-top:16px">{{ section.settings.heading }}</h1>
  </div>
</section>

{% stylesheet %}
.w1w-faq-hero {
  padding: 80px 0 40px;
  border-bottom: 1px solid var(--line);
}
.w1w-faq-hero-h {
  font-size: clamp(56px, 9vw, 120px);
  line-height: 0.9;
  letter-spacing: -0.04em;
}
{% endstylesheet %}

{% schema %}
{
  "name": "W1W FAQ Hero",
  "settings": [
    { "type": "text", "id": "eyebrow",  "label": "Eyebrow text", "default": "Help Center" },
    { "type": "text", "id": "heading",  "label": "Heading",      "default": "ALL ANSWERS." }
  ],
  "presets": [{ "name": "W1W FAQ Hero" }]
}
{% endschema %}
