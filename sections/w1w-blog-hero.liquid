<section class="w1w-blog-hero">
  <div class="wrap">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h1 class="w1w-contact-hero-h" style="margin-top:16px">
      {%- if section.settings.heading != blank -%}
        {{ section.settings.heading }}
      {%- else -%}
        {{ blog.title | upcase }}.
      {%- endif -%}
    </h1>
  </div>
</section>

{% stylesheet %}
.w1w-blog-hero {
  padding: 80px 0 40px;
  border-bottom: 1px solid var(--line);
}
{% endstylesheet %}

{% schema %}
{
  "name": "W1W Blog Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Stories · Culture · The Beautiful Game" },
    { "type": "text", "id": "heading", "label": "Heading (blank = blog title)", "default": "THE JOURNAL." }
  ],
  "presets": [{ "name": "W1W Blog Hero" }]
}
{% endschema %}
