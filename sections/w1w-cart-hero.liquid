<section class="w1w-cart-hero">
  <div class="wrap">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h1 class="w1w-cart-hero-h" style="margin-top:16px">{{ section.settings.heading }}</h1>
  </div>
</section>

{% stylesheet %}
.w1w-cart-hero {
  padding: 56px 0 32px;
  border-bottom: 1px solid var(--line);
}
.w1w-cart-hero-h {
  font-size: clamp(48px, 7vw, 96px);
  line-height: 0.9;
  letter-spacing: -0.03em;
}
{% endstylesheet %}

{% schema %}
{
  "name": "W1W Cart Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Checkout · Step 1 of 3" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "YOUR BAG." }
  ],
  "presets": [{ "name": "W1W Cart Hero" }]
}
{% endschema %}
