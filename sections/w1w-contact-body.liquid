    { "type": "text", "id": "email_placeholder", "label": "Email placeholder", "default": "you@domain.com" },
    { "type": "checkbox", "id": "show_country_field", "label": "Show country/team field", "default": true },
    { "type": "text", "id": "country_label", "label": "Country field label", "default": "Country / Team" },
    { "type": "text", "id": "country_placeholder", "label": "Country field placeholder", "default": "Which side do you support?" },
    { "type": "text", "id": "message_label", "label": "Message label", "default": "Message" },
    { "type": "text", "id": "message_placeholder", "label": "Message placeholder", "default": "Tell us what's up" },
    {
      "type": "header",
      "content": "Button & messages"
