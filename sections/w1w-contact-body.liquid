        { "type": "textarea", "id": "detail", "label": "Detail text" },
        { "type": "textarea", "id": "address", "label": "Address (for HQ card)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "W1W Contact Body",
      "blocks": [
        { "type": "contact_card", "settings": { "label": "General", "heading": "SAY HELLO.", "email": "info@world1world.com" } },
        { "type": "contact_card", "settings": { "label": "Support", "heading": "ORDER HELP.", "email": "info@world1world.com", "detail": "Avg. response: 24 hours · Mon–Fri" } },
        { "type": "contact_card", "settings": { "label": "Teams & Custom", "heading": "25+ BAND ORDERS.", "email": "info@world1world.com", "detail": "Custom colourways, club crests, corporate. 3-week lead time." } }
      ]
    }
  ]
}
{% endschema %}
