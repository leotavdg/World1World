<section class="w1w-lifestyle">
  <div class="w1w-lifestyle__bg">
    {%- if section.settings.bg_image != blank -%}
      {{ section.settings.bg_image | image_url: width: 2000 | image_tag: loading: 'lazy', class: 'w1w-lifestyle__bg-img', alt: section.settings.bg_image.alt }}
    {%- endif -%}
    <div class="w1w-lifestyle__bg-overlay"></div>
  </div>
  <div class="w1w-lifestyle__content">
    <h2 class="w1w-lifestyle__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.subtext != blank -%}
      <p class="w1w-lifestyle__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="w1w-lifestyle__btn">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .w1w-lifestyle {
    position: relative;
    min-height: 820px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .w1w-lifestyle__bg {
    position: absolute;
    inset: 0;
  }
  .w1w-lifestyle__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
    transform: scale(1.1);
    display: block;
  }
  .w1w-lifestyle__bg-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
  }
  .w1w-lifestyle__content {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 56rem;
    padding: 0 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }
  .w1w-lifestyle__heading {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 900;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    font-style: italic;
    margin: 0 0 32px;
    line-height: 1;
  }
  .w1w-lifestyle__subtext {
    font-family: "Inter", sans-serif;
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    color: #fff;
    font-weight: 300;
    margin: 0 0 40px;
    max-width: 40rem;
    line-height: 1.5;
  }
  .w1w-lifestyle__btn {
    display: inline-block;
    padding: 24px 48px;
    background: #f3ffca;
    color: #516700;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    text-decoration: none;
    transition: transform 0.2s;
  }
  .w1w-lifestyle__btn:hover {
    transform: scale(1.1);
  }
  @media (max-width: 768px) {
    .w1w-lifestyle {
      min-height: 600px;
    }
    .w1w-lifestyle__content {
      padding: 0 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "W1W Lifestyle",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Match Day Energy"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "More than an accessory. It's a badge of honor for the 90 minutes and beyond."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Live the game"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "W1W Lifestyle"
    }
  ]
}
{% endschema %}
