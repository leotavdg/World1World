<section class="w1w-lifestyle">
  <div class="w1w-lifestyle__bg">
    {%- if section.settings.bg_image != blank -%}
      {{ section.settings.bg_image | image_url: width: 2000 | image_tag: loading: 'lazy', class: 'w1w-lifestyle__bg-img', alt: section.settings.bg_image.alt }}
    {%- endif -%}
    <div class="w1w-lifestyle__bg-overlay"></div>
  </div>
  <div class="w1w-lifestyle__content">
    <h2 class="w1w-lifestyle__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.subtext != blank -%}
      <p class="w1w-lifestyle__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="w1w-lifestyle__btn">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}

    {%- assign has_scoreboard = false -%}
    {%- if section.settings.sb1_label != blank or section.settings.sb2_label != blank or section.settings.sb3_label != blank or section.settings.sb4_label != blank -%}
      {%- assign has_scoreboard = true -%}
    {%- endif -%}
    {%- if has_scoreboard -%}
      <div class="w1w-scoreboard">
        {%- if section.settings.sb1_label != blank -%}
          <div class="w1w-sb-cell">
            <span class="w1w-sb-cell__k">{{ section.settings.sb1_label }}</span>
            <span class="w1w-sb-cell__v">{{ section.settings.sb1_value }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.sb2_label != blank -%}
          <div class="w1w-sb-cell">
            <span class="w1w-sb-cell__k">{{ section.settings.sb2_label }}</span>
            <span class="w1w-sb-cell__v">{{ section.settings.sb2_value }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.sb3_label != blank -%}
          <div class="w1w-sb-cell">
            <span class="w1w-sb-cell__k">{{ section.settings.sb3_label }}</span>
            <span class="w1w-sb-cell__v">{{ section.settings.sb3_value }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.sb4_label != blank -%}
          <div class="w1w-sb-cell">
            <span class="w1w-sb-cell__k">{{ section.settings.sb4_label }}</span>
            <span class="w1w-sb-cell__v">{{ section.settings.sb4_value }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .w1w-lifestyle {
    position: relative;
    min-height: 820px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .w1w-lifestyle__bg {
    position: absolute;
    inset: 0;
  }
  .w1w-lifestyle__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
    transform: scale(1.1);
    display: block;
  }
  .w1w-lifestyle__bg-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
  }
  .w1w-lifestyle__content {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 56rem;
    padding: 0 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }
  .w1w-lifestyle__heading {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 900;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    font-style: italic;
    margin: 0 0 32px;
    line-height: 1;
  }
  .w1w-lifestyle__subtext {
    font-family: "Inter", sans-serif;
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    color: #fff;
    font-weight: 300;
    margin: 0 0 40px;
    max-width: 40rem;
    line-height: 1.5;
  }
  .w1w-lifestyle__btn {
    display: inline-block;
    padding: 24px 48px;
    background: #f3ffca;
    color: #516700;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    text-decoration: none;
    transition: transform 0.2s;
  }
  .w1w-lifestyle__btn:hover {
    transform: scale(1.1);
  }
  /* Scoreboard */
  .w1w-scoreboard {
    display: inline-flex;
    gap: 2px;
    margin-top: 48px;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
  }
  .w1w-sb-cell {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 16px 24px;
    border: 1px solid rgba(243, 255, 202, 0.15);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .w1w-sb-cell__k {
    font-size: 10px;
    letter-spacing: 0.2em;
    color: #737373;
    text-transform: uppercase;
    display: block;
    margin-bottom: 4px;
  }
  .w1w-sb-cell__v {
    font-size: 32px;
    letter-spacing: -0.02em;
    color: #f3ffca;
    display: block;
  }

  @media (max-width: 768px) {
    .w1w-lifestyle {
      min-height: 600px;
    }
    .w1w-lifestyle__content {
      padding: 0 24px;
    }
    .w1w-scoreboard {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "W1W Lifestyle",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Match Day Energy"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "More than an accessory. It's a badge of honor for the 90 minutes and beyond."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Live the game"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Scoreboard stats"
    },
    {
      "type": "text",
      "id": "sb1_label",
      "label": "Stat 1 label",
      "default": "Kit"
    },
    {
      "type": "text",
      "id": "sb1_value",
      "label": "Stat 1 value",
      "default": "W1W"
    },
    {
      "type": "text",
      "id": "sb2_label",
      "label": "Stat 2 label",
      "default": "Price"
    },
    {
      "type": "text",
      "id": "sb2_value",
      "label": "Stat 2 value",
      "default": "$5"
    },
    {
      "type": "text",
      "id": "sb3_label",
      "label": "Stat 3 label",
      "default": "Stack"
    },
    {
      "type": "text",
      "id": "sb3_value",
      "label": "Stat 3 value",
      "default": "3+"
    },
    {
      "type": "text",
      "id": "sb4_label",
      "label": "Stat 4 label",
      "default": "Ships"
    },
    {
      "type": "text",
      "id": "sb4_value",
      "label": "Stat 4 value",
      "default": "24H"
    }
  ],
  "presets": [
    {
      "name": "W1W Lifestyle"
    }
  ]
}
{% endschema %}
