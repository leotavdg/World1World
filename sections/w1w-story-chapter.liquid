<section class="w1w-sc {% if section.settings.image_position == 'left' %}w1w-sc--img-left{% else %}w1w-sc--img-right{% endif %}">
  <div class="w1w-sc__inner">

    <div class="w1w-sc__media">
      {%- if section.settings.image != blank -%}
        <div class="w1w-sc__img-wrap">
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'w1w-sc__img', alt: section.settings.image.alt }}
          {%- if section.settings.image_label != blank -%}
            <span class="w1w-sc__img-label">{{ section.settings.image_label }}</span>
          {%- endif -%}
        </div>
      {%- else -%}
        <div class="w1w-sc__img-placeholder"></div>
      {%- endif -%}
    </div>

    <div class="w1w-sc__content">
      {%- if section.settings.chapter_label != blank -%}
        <span class="w1w-sc__label">{{ section.settings.chapter_label }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="w1w-sc__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="w1w-sc__body">{{ section.settings.body }}</div>
      {%- endif -%}

      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link }}" class="w1w-sc__cta">
          {{ section.settings.cta_label }}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="2" y1="8" x2="14" y2="8"/><polyline points="9,3 14,8 9,13"/></svg>
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% stylesheet %}
  .w1w-sc {
    background: #0e0e0e;
    padding: 120px 0;
  }
  .w1w-sc__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 clamp(24px, 4vw, 80px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(48px, 6vw, 96px);
    align-items: center;
  }

  /* Image side order */
  .w1w-sc--img-left .w1w-sc__media  { order: 0; }
  .w1w-sc--img-left .w1w-sc__content { order: 1; }
  .w1w-sc--img-right .w1w-sc__media  { order: 1; }
  .w1w-sc--img-right .w1w-sc__content { order: 0; }

  /* Media block */
  .w1w-sc__img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }
  .w1w-sc__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s ease;
  }
  .w1w-sc__img-wrap:hover .w1w-sc__img {
    transform: scale(1.04);
  }
  .w1w-sc__img-label {
    position: absolute;
    bottom: 16px;
    left: 16px;
    background: rgba(14, 14, 14, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(243, 255, 202, 0.15);
    color: #f3ffca;
    font-family: "Space Grotesk", sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    padding: 6px 12px;
  }
  .w1w-sc__img-placeholder {
    aspect-ratio: 4 / 5;
    background: #131313;
  }

  /* Content block */
  .w1w-sc__label {
    display: block;
    font-family: "Space Grotesk", sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #f3ffca;
    margin-bottom: 24px;
    opacity: 0.8;
  }
  .w1w-sc__heading {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 900;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 32px;
  }
  .w1w-sc__body {
    font-family: "Inter", sans-serif;
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.8;
    max-width: 44ch;
  }
  .w1w-sc__body p { margin: 0 0 1.25em; }
  .w1w-sc__body p:last-child { margin: 0; }
  .w1w-sc__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 40px;
    font-family: "Space Grotesk", sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #f3ffca;
    text-decoration: none;
    border-bottom: 1px solid rgba(243, 255, 202, 0.4);
    padding-bottom: 6px;
    transition: border-color 0.2s, gap 0.2s;
  }
  .w1w-sc__cta:hover {
    border-color: #f3ffca;
    gap: 16px;
  }

  @media (max-width: 900px) {
    .w1w-sc__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .w1w-sc--img-left .w1w-sc__media,
    .w1w-sc--img-right .w1w-sc__media { order: 0; }
    .w1w-sc--img-left .w1w-sc__content,
    .w1w-sc--img-right .w1w-sc__content { order: 1; }
    .w1w-sc__img-wrap { aspect-ratio: 16 / 9; }
    .w1w-sc__img-placeholder { aspect-ratio: 16 / 9; }
    .w1w-sc { padding: 72px 0; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "W1W Story Chapter",
  "settings": [
    {
      "type": "header",
      "content": "Chapter identity"
    },
    {
      "type": "text",
      "id": "chapter_label",
      "label": "Chapter label",
      "default": "01 — Origin"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Born on the Terraces"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Every great movement starts with a single moment of clarity. Ours came during the 2022 World Cup — watching fans from every corner of the planet wave their colors with unmatched pride.</p><p>We asked ourselves: what if that pride could travel on your wrist every single day?</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_label",
      "label": "Image caption label",
      "info": "Small label shown over the image (e.g. location or year)"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image side",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    }
  ],
  "presets": [
    {
      "name": "W1W Story Chapter"
    }
  ]
}
{% endschema %}
