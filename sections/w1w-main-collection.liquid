{%- liquid
  assign products_per_page = section.settings.products_per_page | default: 24
  assign sort_by = collection.sort_by | default: collection.default_sort_by

  assign continent_filter = nil
  assign country_filter = nil
  assign sport_filter = nil

  for filter in collection.filters
    if filter.label == 'Continent'
      assign continent_filter = filter
    elsif filter.label == 'Country'
      assign country_filter = filter
    elsif filter.label == 'Sport'
      assign sport_filter = filter
    endif
  endfor

  assign active_count = 0
  for filter in collection.filters
    for v in filter.active_values
      assign active_count = active_count | plus: 1
    endfor
  endfor
-%}

{%- paginate collection.products by products_per_page -%}

<section class="w1w-shop">

  <!-- Continent chips (server-side filter) -->
  {%- if continent_filter -%}
    {%- assign has_active_continent = false -%}
    {%- for v in continent_filter.active_values -%}
      {%- assign has_active_continent = true -%}
    {%- endfor -%}
    <div class="w1w-shop-chips-bar" data-continent-param="{{ continent_filter.param_name }}">
      <div class="w1w-shop-chips-bar__inner">
        <button class="w1w-chip{% unless has_active_continent %} w1w-chip--active{% endunless %}" data-continent-value="all">
          ALL <span class="w1w-chip__count">{{ collection.products_count }}</span>
        </button>
        {%- for value in continent_filter.values -%}
          {%- assign clean_label = value.label | remove: '[' | remove: ']' | remove: '"' | strip -%}
          <button class="w1w-chip{% if value.active %} w1w-chip--active{% endif %}" data-continent-value="{{ value.value }}">
            {{ clean_label | upcase }} <span class="w1w-chip__count">{{ value.count }}</span>
          </button>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <div class="w1w-shop__inner">

    <!-- Sidebar -->
    <aside class="w1w-shop-sidebar" id="w1w-shop-sidebar">
      <div class="w1w-shop-sidebar__sticky">

        <!-- Close button (mobile) -->
        <button class="w1w-shop-sidebar__close" id="w1w-sidebar-close" aria-label="Close filters">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>

        <!-- Search (client-side, current page only) -->
        <div class="w1w-shop-filter-group">
          <div class="w1w-shop-search">
            <svg class="w1w-shop-search__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input type="text" id="w1w-shop-search-input" placeholder="Search nations..." class="w1w-shop-search__input" autocomplete="off">
          </div>
        </div>

        <!-- Country filter (server-side via Shopify storefront filtering) -->
        {%- if country_filter and country_filter.values.size > 0 -%}
          <div class="w1w-shop-filter-group">
            <h3 class="w1w-shop-filter-label">COUNTRY</h3>
            <div class="w1w-shop-filter-scroll">
              <ul class="w1w-shop-filter-list">
                {%- for value in country_filter.values -%}
                  {%- assign clean_label = value.label | remove: '[' | remove: ']' | remove: '"' | strip -%}
                  <li>
                    {%- if value.active -%}
                      <a href="{{ value.url_to_remove }}" class="w1w-shop-filter-link active">
                        <span class="w1w-shop-filter-check w1w-shop-filter-check--on"></span>
                        <span>{{ clean_label }}</span>
                        <span class="w1w-shop-filter-cnt">{{ value.count }}</span>
                      </a>
                    {%- else -%}
                      <a href="{{ value.url_to_add }}" class="w1w-shop-filter-link{% if value.count == 0 %} disabled{% endif %}">
                        <span class="w1w-shop-filter-check"></span>
                        <span>{{ clean_label }}</span>
                        <span class="w1w-shop-filter-cnt">{{ value.count }}</span>
                      </a>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          </div>
        {%- endif -%}

        <!-- Theme filter (from Sport metafield, labeled as THEME) -->
        {%- if sport_filter and sport_filter.values.size > 0 -%}
          <div class="w1w-shop-filter-group">
            <h3 class="w1w-shop-filter-label">THEME</h3>
            <div class="w1w-shop-filter-scroll">
              <ul class="w1w-shop-filter-list">
                {%- for value in sport_filter.values -%}
                  {%- assign clean_label = value.label | remove: '[' | remove: ']' | remove: '"' | strip -%}
                  <li>
                    {%- if value.active -%}
                      <a href="{{ value.url_to_remove }}" class="w1w-shop-filter-link active">
                        <span class="w1w-shop-filter-check w1w-shop-filter-check--on"></span>
                        <span>{{ clean_label }}</span>
                        <span class="w1w-shop-filter-cnt">{{ value.count }}</span>
                      </a>
                    {%- else -%}
                      <a href="{{ value.url_to_add }}" class="w1w-shop-filter-link{% if value.count == 0 %} disabled{% endif %}">
                        <span class="w1w-shop-filter-check"></span>
                        <span>{{ clean_label }}</span>
                        <span class="w1w-shop-filter-cnt">{{ value.count }}</span>
                      </a>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          </div>
        {%- endif -%}

        <!-- Sort -->
        <div class="w1w-shop-filter-group">
          <h3 class="w1w-shop-filter-label">SORT BY</h3>
          <div class="w1w-shop-sort-list">
            {%- for option in collection.sort_options -%}
              <a
                href="{{ collection.url }}?sort_by={{ option.value }}"
                class="w1w-shop-sort-link{% if option.value == sort_by %} active{% endif %}"
              >{{ option.label }}</a>
            {%- endfor -%}
          </div>
        </div>

        <!-- Other Shopify native filters (price, availability, etc.) -->
        {%- for filter in collection.filters -%}
          {%- if filter.label == 'Continent' or filter.label == 'Country' or filter.label == 'Sport' -%}
            {%- continue -%}
          {%- endif -%}
          <div class="w1w-shop-filter-group">
            <h3 class="w1w-shop-filter-label">{{ filter.label | upcase }}</h3>
            {%- if filter.type == 'price_range' -%}
              <div class="w1w-shop-price-row">
                <input type="number" name="{{ filter.min_value.param_name }}"
                  value="{{ filter.min_value.value | divided_by: 100.0 }}"
                  placeholder="Min" class="w1w-shop-price-input" min="0"
                  max="{{ filter.range_max | divided_by: 100.0 }}">
                <span class="w1w-shop-price-dash">&ndash;</span>
                <input type="number" name="{{ filter.max_value.param_name }}"
                  value="{{ filter.max_value.value | divided_by: 100.0 }}"
                  placeholder="Max" class="w1w-shop-price-input" min="0"
                  max="{{ filter.range_max | divided_by: 100.0 }}">
              </div>
            {%- elsif filter.type == 'boolean' or filter.type == 'list' -%}
              <ul class="w1w-shop-filter-list">
                {%- for value in filter.values -%}
                  {%- assign clean_label = value.label | remove: '[' | remove: ']' | remove: '"' | strip -%}
                  <li>
                    {%- if value.active -%}
                      <a href="{{ value.url_to_remove }}" class="w1w-shop-filter-link active">
                        <span class="w1w-shop-filter-check w1w-shop-filter-check--on"></span>
                        <span>{{ clean_label }}</span>
                        <span class="w1w-shop-filter-cnt">{{ value.count }}</span>
                      </a>
                    {%- else -%}
                      <a href="{{ value.url_to_add }}" class="w1w-shop-filter-link{% if value.count == 0 %} disabled{% endif %}">
                        <span class="w1w-shop-filter-check"></span>
                        <span>{{ clean_label }}</span>
                        <span class="w1w-shop-filter-cnt">{{ value.count }}</span>
                      </a>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endfor -%}

        {%- if active_count > 0 -%}
          <a href="{{ collection.url }}" class="w1w-shop-clear">Clear all filters</a>
        {%- endif -%}

      </div>
    </aside>

    <!-- Main content -->
    <div class="w1w-shop-main">

      <!-- Top bar -->
      <div class="w1w-shop-topbar">
        <span class="w1w-shop-topbar__count">
          <span id="w1w-visible-count">{{ paginate.items }}</span> NATIONS
        </span>
        <!-- Active filter tags (server-side rendered) -->
        <div class="w1w-shop-active-filters" id="w1w-active-filters">
          {%- for filter in collection.filters -%}
            {%- for value in filter.active_values -%}
              {%- assign tag_label = value.label | remove: '[' | remove: ']' | remove: '"' | strip -%}
              <a href="{{ value.url_to_remove }}" class="w1w-shop-active-tag">
                {{ tag_label }}
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
              </a>
            {%- endfor -%}
          {%- endfor -%}
        </div>
        <button class="w1w-shop-topbar__filter-toggle" id="w1w-filter-toggle" aria-label="Toggle filters">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
          FILTERS
        </button>
      </div>

      <!-- Product grid -->
      <div class="w1w-shop-grid" id="w1w-shop-grid">
        {%- if collection.products.size == 0 -%}
          <p class="w1w-shop-empty">No products found in this collection.</p>
        {%- else -%}
          {%- for product in collection.products -%}
            {%- assign p_continent = product.metafields.custom.continent | remove: '[' | remove: ']' | remove: '"' | strip | default: '' -%}
            <div
              class="w1w-nation-card"
              data-handle="{{ product.handle }}"
              data-title="{{ product.title | downcase | escape }}"
            >
              <a href="{{ product.url }}" class="w1w-nation-card__link">
                <div class="w1w-nation-card__scene" data-bracelet-handle="{{ product.handle }}">
                  {%- if product.featured_image != blank -%}
                    {{ product.featured_image | image_url: width: 600 | image_tag:
                      loading: 'lazy',
                      class: 'w1w-nation-card__img',
                      sizes: '(max-width: 480px) 50vw, (max-width: 768px) 50vw, (max-width: 1280px) 33vw, 25vw',
                      alt: product.featured_image.alt | escape }}
                  {%- else -%}
                    <div class="w1w-nation-card__bracelet-ph"></div>
                  {%- endif -%}
                  <div class="w1w-nation-card__overlay"></div>
                </div>
                <div class="w1w-nation-card__info">
                  <div class="w1w-nation-card__meta">
                    <span class="w1w-nation-card__swatch" data-swatch-handle="{{ product.handle }}"></span>
                    <div class="w1w-nation-card__text">
                      <span class="w1w-nation-card__name">{{ product.title }}</span>
                      {%- if p_continent != blank -%}
                        <span class="w1w-nation-card__continent">{{ p_continent }}</span>
                      {%- endif -%}
                    </div>
                  </div>
                  <span class="w1w-nation-card__price">{{ product.price | money_without_trailing_zeros }}</span>
                </div>
              </a>
              <button
                class="w1w-nation-card__atc"
                data-product-id="{{ product.variants.first.id }}"
                data-handle="{{ product.handle }}"
                aria-label="Add {{ product.title | escape }} to bag"
              >
                {%- if product.available -%}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                  ADD TO BAG
                {%- else -%}
                  SOLD OUT
                {%- endif -%}
              </button>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <!-- No results message -->
      {%- if collection.products.size == 0 and active_count > 0 -%}
        <div class="w1w-shop-no-results">
          <div class="w1w-shop-no-results__inner">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(243,255,202,0.3)" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <p>No nations match your filters.</p>
            <a href="{{ collection.url }}" class="w1w-shop-no-results__reset">Reset all filters</a>
          </div>
        </div>
      {%- endif -%}

      <!-- Client-side search no-results (hidden by default) -->
      <div class="w1w-shop-no-results" id="w1w-shop-no-results" style="display:none">
        <div class="w1w-shop-no-results__inner">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(243,255,202,0.3)" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <p>No nations match your search.</p>
          <button class="w1w-shop-no-results__reset" id="w1w-reset-search">Clear search</button>
        </div>
      </div>

      <!-- Pagination -->
      {%- if paginate.pages > 1 -%}
        <div class="w1w-shop-pagination" id="w1w-shop-pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="w1w-shop-pg-btn">&larr;</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="w1w-shop-pg-num">{{ part.title }}</a>
            {%- else -%}
              {%- if part.title == paginate.current_page -%}
                <span class="w1w-shop-pg-num active">{{ part.title }}</span>
              {%- else -%}
                <span class="w1w-shop-pg-ellipsis">&hellip;</span>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="w1w-shop-pg-btn">&rarr;</a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{%- endpaginate -%}

{% stylesheet %}
/* ── Prevent horizontal scroll ── */
.w1w-shop {
  background: #0E0E0E;
  min-height: 60vh;
  padding-bottom: 96px;
  overflow-x: hidden;
  max-width: 100vw;
}

/* ── Continent chips bar ── */
.w1w-shop-chips-bar {
  background: #0E0E0E;
  border-bottom: 1px solid rgba(243,255,202,0.08);
  padding: 0 32px;
  position: sticky;
  top: 0;
  z-index: 30;
}
.w1w-shop-chips-bar__inner {
  max-width: 1536px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 6px;
  overflow-x: auto;
  scrollbar-width: none;
  padding: 14px 0;
}
.w1w-shop-chips-bar__inner::-webkit-scrollbar { display: none; }
.w1w-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 7px 16px;
  border-radius: 999px;
  border: 1px solid rgba(243,255,202,0.12);
  background: transparent;
  color: rgba(255,255,255,0.5);
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  white-space: nowrap;
  cursor: pointer;
  transition: all 0.25s ease;
}
.w1w-chip:hover {
  border-color: rgba(243,255,202,0.35);
  color: #F3FFCA;
}
.w1w-chip--active {
  background: #F3FFCA;
  border-color: #F3FFCA;
  color: #1a2600;
}
.w1w-chip__count {
  font-size: 0.5625rem;
  opacity: 0.6;
}

/* ── Inner layout ── */
.w1w-shop__inner {
  max-width: 1536px;
  margin: 0 auto;
  padding: 40px 32px 0;
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 48px;
  align-items: start;
  min-width: 0;
}

/* ── Sidebar ── */
.w1w-shop-sidebar {
  min-width: 0;
}
.w1w-shop-sidebar__close {
  display: none;
  background: none;
  border: none;
  color: rgba(255,255,255,0.5);
  cursor: pointer;
  padding: 4px;
  margin-left: auto;
}
.w1w-shop-sidebar__sticky {
  position: sticky;
  top: calc(var(--header-group-height, 80px) + 60px);
  max-height: calc(100vh - var(--header-group-height, 80px) - 80px);
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(243,255,202,0.15) transparent;
  display: flex;
  flex-direction: column;
  gap: 32px;
}
.w1w-shop-sidebar__sticky::-webkit-scrollbar { width: 4px; }
.w1w-shop-sidebar__sticky::-webkit-scrollbar-track { background: transparent; }
.w1w-shop-sidebar__sticky::-webkit-scrollbar-thumb { background: rgba(243,255,202,0.15); border-radius: 2px; }
.w1w-shop-filter-group { display: flex; flex-direction: column; gap: 10px; }
.w1w-shop-filter-label {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.5625rem;
  font-weight: 700;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  margin: 0;
  padding-bottom: 4px;
  border-bottom: 1px solid rgba(243,255,202,0.06);
}

/* Search */
.w1w-shop-search {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #1a1a1a !important;
  border: 1px solid rgba(243,255,202,0.12) !important;
  border-radius: 6px;
  padding: 10px 14px;
  transition: all 0.25s ease;
}
.w1w-shop-search:focus-within {
  border-color: rgba(243,255,202,0.4) !important;
  background: #222 !important;
}
.w1w-shop-search__icon { color: rgba(255,255,255,0.25); flex-shrink: 0; }
.w1w-shop .w1w-shop-search__input,
.w1w-shop .w1w-shop-search__input:hover,
.w1w-shop .w1w-shop-search__input:focus {
  background: transparent !important;
  background-color: transparent !important;
  border: none !important;
  border-color: transparent !important;
  outline: none !important;
  box-shadow: none !important;
  color: #FFF !important;
  font-family: 'Inter', sans-serif;
  font-size: 0.8125rem;
  width: 100%;
  padding: 0;
  margin: 0;
  border-radius: 0;
}
.w1w-shop .w1w-shop-search__input::placeholder { color: rgba(255,255,255,0.3) !important; }
.w1w-shop .w1w-shop-search__input:not(:placeholder-shown)::placeholder { opacity: 0; }

/* Filter scroll container */
.w1w-shop-filter-scroll {
  max-height: 200px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(243,255,202,0.15) transparent;
}
.w1w-shop-filter-scroll::-webkit-scrollbar { width: 4px; }
.w1w-shop-filter-scroll::-webkit-scrollbar-track { background: transparent; }
.w1w-shop-filter-scroll::-webkit-scrollbar-thumb { background: rgba(243,255,202,0.15); border-radius: 2px; }

/* Filter list & buttons */
.w1w-shop-filter-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
.w1w-shop-filter-check {
  width: 14px;
  height: 14px;
  border: 1px solid rgba(243,255,202,0.2);
  border-radius: 3px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}
.w1w-shop-filter-check--on {
  background: #F3FFCA;
  border-color: #F3FFCA;
}
.w1w-shop-filter-check--on::after {
  content: '';
  width: 6px;
  height: 6px;
  background: #0E0E0E;
  border-radius: 1px;
}
.w1w-shop-filter-cnt {
  margin-left: auto;
  font-size: 0.625rem;
  color: rgba(255,255,255,0.2);
}
.w1w-shop-filter-link {
  display: flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
  color: rgba(255,255,255,0.5);
  font-family: 'Inter', sans-serif;
  font-size: 0.8125rem;
  font-weight: 500;
  transition: color 0.2s;
  padding: 4px 0;
}
.w1w-shop-filter-link:hover { color: #FFF; }
.w1w-shop-filter-link.active { color: #F3FFCA; }
.w1w-shop-filter-link.disabled { opacity: 0.3; pointer-events: none; }

/* Sort */
.w1w-shop-sort-list { display: flex; flex-direction: column; gap: 6px; }
.w1w-shop-sort-link {
  font-family: 'Inter', sans-serif;
  font-size: 0.8125rem;
  font-weight: 500;
  color: rgba(255,255,255,0.4);
  text-decoration: none;
  text-transform: capitalize;
  transition: color 0.2s;
  padding: 2px 0;
}
.w1w-shop-sort-link:hover { color: #FFF; }
.w1w-shop-sort-link.active { color: #F3FFCA; }

/* Price */
.w1w-shop-price-row {
  display: flex;
  align-items: center;
  gap: 8px;
}
.w1w-shop-price-dash {
  color: rgba(255,255,255,0.3);
  font-size: 0.875rem;
}
.w1w-shop .w1w-shop-price-input,
.w1w-shop .w1w-shop-price-input:hover,
.w1w-shop .w1w-shop-price-input:focus {
  flex: 1;
  min-width: 0;
  background: #1a1a1a !important;
  background-color: #1a1a1a !important;
  border: 1px solid rgba(243,255,202,0.15) !important;
  border-color: rgba(243,255,202,0.15) !important;
  border-radius: 4px;
  color: #FFF !important;
  padding: 10px 12px;
  font-family: 'Inter', sans-serif;
  font-size: 0.8125rem;
  outline: none !important;
  box-shadow: none !important;
  transition: border-color 0.2s;
  -moz-appearance: textfield;
}
.w1w-shop .w1w-shop-price-input::-webkit-outer-spin-button,
.w1w-shop .w1w-shop-price-input::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}
.w1w-shop .w1w-shop-price-input::placeholder {
  color: rgba(255,255,255,0.3) !important;
}
.w1w-shop .w1w-shop-price-input:focus {
  border-color: rgba(243,255,202,0.5) !important;
  background: #222 !important;
  background-color: #222 !important;
}

/* Clear */
.w1w-shop-clear {
  font-family: 'Inter', sans-serif;
  font-size: 0.75rem;
  color: rgba(255,255,255,0.3);
  text-decoration: underline;
  transition: color 0.2s;
}
.w1w-shop-clear:hover { color: #F3FFCA; }

/* ── Main grid area ── */
.w1w-shop-main {
  min-width: 0;
}
.w1w-shop-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 28px;
  padding-bottom: 16px;
  border-bottom: 1px solid rgba(243,255,202,0.08);
}
.w1w-shop-topbar__count {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: rgba(255,255,255,0.35);
  white-space: nowrap;
}
.w1w-shop-active-filters {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  flex: 1;
}
.w1w-shop-active-tag {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  background: rgba(243,255,202,0.1);
  border: 1px solid rgba(243,255,202,0.15);
  border-radius: 999px;
  color: #F3FFCA;
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.5625rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.2s;
}
.w1w-shop-active-tag:hover {
  background: rgba(243,255,202,0.2);
}
.w1w-shop-active-tag svg {
  opacity: 0.6;
}
.w1w-shop-topbar__filter-toggle {
  display: none;
  align-items: center;
  gap: 8px;
  background: transparent;
  border: 1px solid rgba(243,255,202,0.15);
  border-radius: 6px;
  color: rgba(255,255,255,0.6);
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  padding: 8px 14px;
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
}
.w1w-shop-topbar__filter-toggle:hover {
  border-color: rgba(243,255,202,0.4);
  color: #F3FFCA;
}

/* ── Nation Cards Grid — uniform columns ── */
.w1w-shop-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 2px;
}
.w1w-nation-card {
  position: relative;
  background: #131313;
  display: flex;
  flex-direction: column;
  min-width: 0;
  overflow: hidden;
}
.w1w-nation-card__link {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  flex: 1;
  min-width: 0;
}
.w1w-nation-card__scene {
  position: relative;
  aspect-ratio: 1 / 1;
  background: #0a0a0a;
  overflow: hidden;
  display: grid;
  place-items: center;
}
.w1w-nation-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
  display: block;
}
.w1w-nation-card:hover .w1w-nation-card__img { transform: scale(1.05); }
.w1w-nation-card__bracelet-ph {
  width: 70%;
  aspect-ratio: 3 / 1;
  border-radius: 999px;
  background: repeating-linear-gradient(45deg,
    var(--c1,#D72638) 0, var(--c1,#D72638) 12px,
    var(--c2,#FFFFFF) 12px, var(--c2,#FFFFFF) 24px,
    var(--c3,#000000) 24px, var(--c3,#000000) 36px);
  box-shadow: 0 4px 24px rgba(0,0,0,0.5);
}
.w1w-nation-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(14,14,14,0.3) 0%, transparent 50%);
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
}
.w1w-nation-card:hover .w1w-nation-card__overlay {
  opacity: 1;
}
.w1w-nation-card__info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 14px 10px;
  gap: 8px;
  border-top: 1px solid rgba(243,255,202,0.06);
  min-width: 0;
}
.w1w-nation-card__meta {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
  flex: 1;
}
.w1w-nation-card__swatch {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  flex-shrink: 0;
  background: #333;
  display: block;
}
.w1w-nation-card__text {
  display: flex;
  flex-direction: column;
  gap: 1px;
  min-width: 0;
}
.w1w-nation-card__name {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.02em;
  color: #FFF;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  transition: color 0.2s;
}
.w1w-nation-card__continent {
  font-family: 'Inter', sans-serif;
  font-size: 0.5625rem;
  font-weight: 500;
  color: rgba(255,255,255,0.25);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}
.w1w-nation-card:hover .w1w-nation-card__name { color: #F3FFCA; }
.w1w-nation-card__price {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  color: #F3FFCA;
  white-space: nowrap;
  flex-shrink: 0;
}
.w1w-nation-card__atc {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  background: rgba(243,255,202,0.06);
  border: none;
  border-top: 1px solid rgba(243,255,202,0.06);
  color: rgba(255,255,255,0.5);
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.5625rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: 11px 10px;
  cursor: pointer;
  transition: all 0.25s ease;
}
.w1w-nation-card__atc svg {
  opacity: 0.6;
  transition: opacity 0.2s;
}
.w1w-nation-card__atc:hover {
  background: #F3FFCA;
  color: #1a2600;
  border-top-color: #F3FFCA;
}
.w1w-nation-card__atc:hover svg {
  opacity: 1;
  stroke: #1a2600;
}
.w1w-nation-card--hidden { display: none !important; }

/* Empty / no results */
.w1w-shop-empty {
  grid-column: 1 / -1;
  text-align: center;
  padding: 80px 0;
  color: rgba(255,255,255,0.3);
  font-family: 'Inter', sans-serif;
  font-size: 0.9375rem;
}
.w1w-shop-no-results {
  text-align: center;
  padding: 80px 0;
}
.w1w-shop-no-results__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.w1w-shop-no-results__inner p {
  color: rgba(255,255,255,0.3);
  font-family: 'Inter', sans-serif;
  font-size: 0.9375rem;
  margin: 0;
}
.w1w-shop-no-results__reset {
  background: rgba(243,255,202,0.1);
  border: 1px solid rgba(243,255,202,0.2);
  border-radius: 6px;
  color: #F3FFCA;
  cursor: pointer;
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 10px 20px;
  transition: all 0.2s;
  text-decoration: none;
}
.w1w-shop-no-results__reset:hover {
  background: rgba(243,255,202,0.2);
}

/* Pagination */
.w1w-shop-pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin-top: 72px;
}
.w1w-shop-pg-btn,
.w1w-shop-pg-num {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 40px;
  height: 40px;
  padding: 0 8px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(243,255,202,0.08);
  border-radius: 4px;
  color: #FFF;
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.875rem;
  font-weight: 700;
  text-decoration: none;
  transition: all 0.2s;
}
.w1w-shop-pg-btn:hover, .w1w-shop-pg-num:hover {
  border-color: rgba(243,255,202,0.3);
  color: #F3FFCA;
}
.w1w-shop-pg-num.active {
  background: #F3FFCA;
  border-color: #F3FFCA;
  color: #1a2600;
  pointer-events: none;
}
.w1w-shop-pg-ellipsis { color: rgba(255,255,255,0.3); padding: 0 6px; }

/* ── Responsive ── */
@media (max-width: 1280px) {
  .w1w-shop-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
}
@media (max-width: 1024px) {
  .w1w-shop__inner {
    grid-template-columns: 200px 1fr;
    gap: 32px;
    padding: 32px 24px 0;
  }
  .w1w-shop-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (max-width: 768px) {
  .w1w-shop-chips-bar { padding: 0 16px; }
  .w1w-shop__inner {
    grid-template-columns: 1fr;
    padding: 24px 16px 0;
  }
  .w1w-shop-sidebar {
    display: none;
  }
  .w1w-shop-sidebar.open {
    display: block;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: #0E0E0E;
    overflow-y: auto;
    padding: 24px;
  }
  .w1w-shop-sidebar.open .w1w-shop-sidebar__close { display: block; }
  .w1w-shop-topbar__filter-toggle { display: flex; }
  .w1w-shop-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1px; }
}
@media (max-width: 480px) {
  .w1w-shop-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .w1w-nation-card__name { font-size: 0.625rem; }
  .w1w-nation-card__continent { display: none; }
}
{% endstylesheet %}

<script>
(function() {
  function initShop() {
    var countries = window.W1W_COUNTRIES || [];
    var cards = document.querySelectorAll('.w1w-nation-card');
    var noResults = document.getElementById('w1w-shop-no-results');
    var visibleCount = document.getElementById('w1w-visible-count');

    // Map handle -> country data for swatches
    var countryByHandle = {};
    countries.forEach(function(c) { countryByHandle[c.slug] = c; });

    // Render bracelet placeholders and swatches
    cards.forEach(function(card) {
      var handle = card.dataset.handle;
      var country = countryByHandle[handle];
      if (!country) return;

      var scene = card.querySelector('[data-bracelet-handle]');
      var ph = scene && scene.querySelector('.w1w-nation-card__bracelet-ph');
      var swatch = card.querySelector('[data-swatch-handle]');

      if (ph && country.colors) {
        ph.style.setProperty('--c1', country.colors[0]);
        ph.style.setProperty('--c2', country.colors[1]);
        ph.style.setProperty('--c3', country.colors[2]);
      }

      if (swatch && country.colors) {
        swatch.style.background = 'linear-gradient(135deg, ' +
          country.colors[0] + ' 0%, ' +
          country.colors[0] + ' 33%, ' +
          country.colors[1] + ' 33%, ' +
          country.colors[1] + ' 66%, ' +
          country.colors[2] + ' 66%, ' +
          country.colors[2] + ' 100%)';
      }
    });

    // Continent chips — single-select, navigates via URL params (server-side filtering)
    var chipsBar = document.querySelector('[data-continent-param]');
    if (chipsBar) {
      var continentParam = chipsBar.dataset.continentParam;
      chipsBar.querySelectorAll('.w1w-chip').forEach(function(chip) {
        chip.addEventListener('click', function(e) {
          e.preventDefault();
          var url = new URL(window.location.href);
          // Remove all continent params
          url.searchParams.delete(continentParam);
          var val = chip.dataset.continentValue;
          if (val && val !== 'all') {
            url.searchParams.set(continentParam, val);
          }
          // Reset to page 1 when changing filters
          url.searchParams.delete('page');
          window.location.href = url.toString();
        });
      });
    }

    // Client-side search (filters current page only)
    var searchInput = document.getElementById('w1w-shop-search-input');
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        var q = this.value.trim().toLowerCase();
        var visible = 0;

        cards.forEach(function(card) {
          var title = card.dataset.title || '';
          var show = !q || title.indexOf(q) !== -1;
          card.classList.toggle('w1w-nation-card--hidden', !show);
          if (show) visible++;
        });

        if (visibleCount) visibleCount.textContent = visible;
        if (noResults) noResults.style.display = (visible === 0 && q) ? 'block' : 'none';
      });
    }

    // Clear search button
    var resetSearch = document.getElementById('w1w-reset-search');
    if (resetSearch && searchInput) {
      resetSearch.addEventListener('click', function() {
        searchInput.value = '';
        searchInput.dispatchEvent(new Event('input'));
      });
    }

    // Mobile filter toggle
    var filterToggle = document.getElementById('w1w-filter-toggle');
    var sidebar = document.getElementById('w1w-shop-sidebar');
    var sidebarClose = document.getElementById('w1w-sidebar-close');
    if (filterToggle && sidebar) {
      filterToggle.addEventListener('click', function() {
        sidebar.classList.add('open');
        document.body.style.overflow = 'hidden';
      });
      if (sidebarClose) {
        sidebarClose.addEventListener('click', function() {
          sidebar.classList.remove('open');
          document.body.style.overflow = '';
        });
      }
      sidebar.addEventListener('click', function(e) {
        if (e.target === sidebar) {
          sidebar.classList.remove('open');
          document.body.style.overflow = '';
        }
      });
    }

    // ATC buttons
    document.querySelectorAll('.w1w-nation-card__atc').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        var variantId = btn.dataset.productId;
        if (!variantId) return;
        if (window.W1W && window.W1W.addToCart) {
          window.W1W.addToCart({ id: parseInt(variantId, 10), quantity: 1 });
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShop);
  } else {
    initShop();
  }
})();
</script>

{% schema %}
{
  "name": "W1W Collection Grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 12,
      "max": 60,
      "step": 6,
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "W1W Collection Grid"
    }
  ]
}
{% endschema %}
