{
  "name": "W1W Collection Grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 12,
      "max": 60,
      "step": 6,
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "W1W Collection Grid"
    }
  ]
}
{% endschema %}
