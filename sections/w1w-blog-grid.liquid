{%- liquid
  assign per_page = section.settings.per_page | default: 12
-%}

<div class="w1w-blog-wrap">
  <div class="wrap">

    <!-- Tag filter chips -->
    {%- if blog.all_tags.size > 0 and section.settings.show_tags -%}
      <div class="w1w-blog-tags">
        <a href="{{ blog.url }}" class="w1w-blog-chip {% if current_tags == blank %}active{% endif %}">All</a>
        {%- for tag in blog.all_tags -%}
          <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="w1w-blog-chip {% if current_tags contains tag %}active{% endif %}">{{ tag }}</a>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <!-- Article grid -->
    {%- paginate blog.articles by per_page -%}
      <div class="w1w-blog-grid">
        {%- for article in blog.articles -%}
          <a href="{{ article.url }}" class="w1w-blog-card">
            <div class="w1w-blog-card-media">
              {%- if article.image != blank -%}
                {{ article.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'w1w-blog-card-img', alt: article.title }}
              {%- else -%}
                <div class="w1w-blog-card-placeholder">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                </div>
              {%- endif -%}
              {%- if article.tags.size > 0 -%}
                <span class="w1w-blog-card-tag">{{ article.tags | first }}</span>
              {%- endif -%}
            </div>
            <div class="w1w-blog-card-body">
              <div class="w1w-blog-card-meta">
                <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%b %d, %Y' }}</time>
                {%- if section.settings.show_author and article.author != blank -%}
                  <span class="w1w-blog-card-dot">·</span>
                  <span>{{ article.author }}</span>
                {%- endif -%}
              </div>
              <h2 class="w1w-blog-card-title">{{ article.title }}</h2>
              {%- if article.excerpt_or_content != blank -%}
                <p class="w1w-blog-card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
              {%- endif -%}
              <span class="w1w-blog-card-read">Read More →</span>
            </div>
          </a>
        {%- endfor -%}
      </div>

      <!-- Pagination -->
      {%- if paginate.pages > 1 -%}
        <nav class="w1w-blog-pagination" aria-label="Blog pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="w1w-blog-page-btn">← Previous</a>
          {%- endif -%}
          <div class="w1w-blog-page-nums">
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="w1w-blog-page-num">{{ part.title }}</a>
              {%- else -%}
                <span class="w1w-blog-page-num active">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="w1w-blog-page-btn">Next →</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}

  </div>
</div>

{% stylesheet %}

.w1w-blog-wrap {
  padding: 48px 0 120px;
}

/* Tag chips */
.w1w-blog-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 48px;
}
.w1w-blog-chip {
  display: inline-flex;
  align-items: center;
  padding: 8px 16px;
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--ink-1);
  transition: all .15s ease;
  white-space: nowrap;
}
.w1w-blog-chip:hover {
  border-color: var(--line-strong);
  color: var(--ink-0);
}
.w1w-blog-chip.active {
  background: var(--lime);
  border-color: var(--lime);
  color: var(--lime-dark);
}

/* Article grid */
.w1w-blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}

/* Card */
.w1w-blog-card {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  transition: transform .2s ease;
}
.w1w-blog-card:hover {
  transform: translateY(-4px);
}
.w1w-blog-card-media {
  position: relative;
  aspect-ratio: 16 / 10;
  overflow: hidden;
  background: var(--bg-1);
  border: 1px solid var(--line);
}
.w1w-blog-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform .6s ease;
}
.w1w-blog-card:hover .w1w-blog-card-img {
  transform: scale(1.05);
}
.w1w-blog-card-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ink-3);
}
.w1w-blog-card-tag {
  position: absolute;
  top: 12px;
  left: 12px;
  padding: 4px 10px;
  background: var(--lime);
  color: var(--lime-dark);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

/* Card body */
.w1w-blog-card-body {
  padding: 20px 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.w1w-blog-card-meta {
  font-family: var(--font-display);
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--ink-3);
  display: flex;
  align-items: center;
  gap: 6px;
}
.w1w-blog-card-dot {
  color: var(--lime);
}
.w1w-blog-card-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 22px;
  letter-spacing: -0.01em;
  text-transform: uppercase;
  line-height: 1.1;
  color: var(--ink-0);
  transition: color .15s;
}
.w1w-blog-card:hover .w1w-blog-card-title {
  color: var(--lime);
}
.w1w-blog-card-excerpt {
  color: var(--ink-2);
  font-size: 14px;
  line-height: 1.6;
}
.w1w-blog-card-read {
  font-family: var(--font-display);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--lime);
  margin-top: 4px;
  transition: transform .15s;
  display: inline-block;
}
.w1w-blog-card:hover .w1w-blog-card-read {
  transform: translateX(4px);
}

/* Pagination */
.w1w-blog-pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  margin-top: 64px;
  padding-top: 48px;
  border-top: 1px solid var(--line);
}
.w1w-blog-page-nums {
  display: flex;
  gap: 4px;
}
.w1w-blog-page-btn {
  padding: 10px 20px;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-1);
  text-decoration: none;
  border: 1px solid var(--line);
  transition: all .15s;
}
.w1w-blog-page-btn:hover {
  border-color: var(--lime);
  color: var(--lime);
}
.w1w-blog-page-num {
  width: 40px;
  height: 40px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 13px;
  color: var(--ink-2);
  text-decoration: none;
  transition: color .15s;
}
.w1w-blog-page-num:hover {
  color: var(--lime);
}
.w1w-blog-page-num.active {
  color: var(--lime);
  border-bottom: 2px solid var(--lime);
}

/* Responsive */
@media (max-width: 900px) {
  .w1w-blog-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
}
@media (max-width: 600px) {
  .w1w-blog-grid {
    grid-template-columns: 1fr;
    gap: 32px;
  }
  .w1w-blog-wrap {
    padding: 32px 0 80px;
  }
  .w1w-blog-card-title {
    font-size: 18px;
  }
}

{% endstylesheet %}

{% schema %}
{
  "name": "W1W Blog Grid",
  "settings": [
    { "type": "range",    "id": "per_page",    "label": "Articles per page", "min": 3, "max": 24, "step": 3, "default": 12 },
    { "type": "checkbox", "id": "show_tags",   "label": "Show tag filters",  "default": true },
    { "type": "checkbox", "id": "show_author", "label": "Show author",       "default": false }
  ],
  "presets": [{ "name": "W1W Blog Grid" }]
}
{% endschema %}
