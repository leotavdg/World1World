{%- liquid
  assign color_option = nil
  for option in product.options_with_values
    assign option_name_down = option.name | downcase
    if option_name_down == 'color' or option_name_down == 'colour' or option_name_down == 'style'
      assign color_option = option
      break
    endif
  endfor
-%}

{%- if color_option != nil and color_option.values.size > 1 -%}
<section class="w1w-colors" id="w1w-pdp-colors">
  <div class="wrap">
    {%- if section.settings.eyebrow != blank -%}
      <span class="w1w-colors__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="w1w-colors__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="w1w-colors__desc">{{ section.settings.description }}</p>
    {%- endif -%}

    <div class="w1w-colors__row">
      {%- for value in color_option.values -%}
        {%- assign is_selected = false -%}
        {%- if value.selected -%}{%- assign is_selected = true -%}{%- endif -%}
        {%- assign swatch_bg = nil -%}
        {%- if value.swatch.color -%}
          {%- assign swatch_bg = 'rgb(' | append: value.swatch.color.rgb | append: ')' -%}
        {%- elsif value.swatch.image -%}
          {%- assign swatch_bg = 'url(' | append: value.swatch.image | image_url: width: 80 | append: ')' -%}
        {%- endif -%}
        <button
          class="w1w-colors__swatch{% if is_selected %} active{% endif %}"
          data-color-value="{{ value | escape }}"
          aria-label="{{ value | escape }}"
          type="button"
        >
          <span class="w1w-colors__dot" style="{% if swatch_bg %}background: {{ swatch_bg }};{% else %}background: #737373;{% endif %}"></span>
          <span class="w1w-colors__label">{{ value }}</span>
        </button>
      {%- endfor -%}
    </div>

    <div class="w1w-colors__selected">
      <span class="w1w-colors__selected-name">{{ color_option.selected_value }}</span>
    </div>
  </div>
</section>

<script>
(function () {
  var section = document.getElementById('w1w-pdp-colors');
  if (!section) return;

  var swatches = section.querySelectorAll('.w1w-colors__swatch');
  var nameEl = section.querySelector('.w1w-colors__selected-name');

  swatches.forEach(function (swatch) {
    swatch.addEventListener('click', function () {
      var colorVal = swatch.dataset.colorValue;

      // Update active state
      swatches.forEach(function (s) { s.classList.remove('active'); });
      swatch.classList.add('active');
      if (nameEl) nameEl.textContent = colorVal;

      // Find and click matching variant option in the main product form
      var mainForm = document.getElementById('w1w-product-form');
      if (!mainForm) return;
      var inputs = mainForm.querySelectorAll('input[type="radio"], button[data-variant-id]');
      inputs.forEach(function (input) {
        if (input.value === colorVal || input.textContent.trim() === colorVal) {
          input.click();
        }
      });

      // Also try Shopify's variant picker
      var variantPicker = document.querySelector('variant-picker');
      if (variantPicker) {
        var optionInput = variantPicker.querySelector('input[value="' + colorVal + '"]');
        if (optionInput) {
          optionInput.checked = true;
          optionInput.dispatchEvent(new Event('change', { bubbles: true }));
        }
      }
    });
  });
})();
</script>
{%- endif -%}

{% stylesheet %}
.w1w-colors {
  padding: 80px 0;
  background: var(--bg-0, #0E0E0E);
  border-top: 1px solid var(--line, rgba(243,255,202,0.12));
}
.w1w-colors__eyebrow {
  display: block;
  font-family: var(--font-display, 'Space Grotesk', sans-serif);
  font-size: 11px;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--lime, #F3FFCA);
  margin-bottom: 12px;
}
.w1w-colors__heading {
  font-family: var(--font-display, 'Space Grotesk', sans-serif);
  font-size: clamp(32px, 5vw, 56px);
  font-weight: 700;
  color: var(--ink-0, #fff);
  line-height: 0.92;
  letter-spacing: -0.03em;
  margin: 0 0 16px;
  text-transform: uppercase;
}
.w1w-colors__desc {
  color: var(--ink-2, #ADAAAA);
  font-size: 14px;
  line-height: 1.6;
  max-width: 480px;
  margin: 0 0 40px;
}

.w1w-colors__row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 24px;
}

.w1w-colors__swatch {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 20px 10px 10px;
  background: var(--bg-1, #131313);
  border: 2px solid transparent;
  border-radius: 40px;
  cursor: pointer;
  transition: border-color .2s, background .2s, transform .15s;
}
.w1w-colors__swatch:hover {
  border-color: rgba(243,255,202,0.3);
  background: var(--bg-2, #1C1C1C);
}
.w1w-colors__swatch.active {
  border-color: var(--lime, #F3FFCA);
  background: var(--bg-2, #1C1C1C);
  transform: scale(1.05);
}

.w1w-colors__dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: block;
  flex-shrink: 0;
  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.12);
  background-size: cover;
  background-position: center;
}

.w1w-colors__label {
  font-family: var(--font-display, 'Space Grotesk', sans-serif);
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-1, #D4D4D4);
}
.w1w-colors__swatch.active .w1w-colors__label {
  color: var(--lime, #F3FFCA);
}

.w1w-colors__selected {
  display: flex;
  align-items: center;
  gap: 12px;
}
.w1w-colors__selected-name {
  font-family: var(--font-display, 'Space Grotesk', sans-serif);
  font-weight: 700;
  font-size: 14px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--lime, #F3FFCA);
}

@media (max-width: 600px) {
  .w1w-colors { padding: 48px 0; }
  .w1w-colors__row { gap: 8px; }
  .w1w-colors__swatch { padding: 8px 14px 8px 8px; }
  .w1w-colors__dot { width: 22px; height: 22px; }
  .w1w-colors__label { font-size: 10px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "W1W Color Variants",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Colorway"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PICK YOUR EDITION."
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Four colorways per nation — choose the one that matches your game day fit."
    }
  ],
  "presets": [{ "name": "W1W Color Variants" }]
}
{% endschema %}
