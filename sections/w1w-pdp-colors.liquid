<section class="w1w-colors" id="w1w-pdp-colors">
  <div class="wrap">
    {%- if section.settings.eyebrow != blank -%}
      <span class="w1w-colors__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="w1w-colors__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="w1w-colors__desc">{{ section.settings.description }}</p>
    {%- endif -%}

    <div class="w1w-colors__row" id="w1wColorGrid">
      <!-- JS populates color swatches -->
    </div>

    <div class="w1w-colors__selected" id="w1wColorSelected">
      <span class="w1w-colors__selected-name" id="w1wColorName"></span>
      <span class="w1w-colors__selected-tag" id="w1wColorTag"></span>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var COUNTRIES = window.W1W_COUNTRIES || [];
  var slug = {{ product.handle | json }};
  var country = COUNTRIES.find(function (c) { return c.slug === slug; });
  if (!country || !country.colors) return;

  var colors = country.colors;
  var variants = [
    { name: '{{ section.settings.variant_1_name }}', tag: '{{ section.settings.variant_1_tag }}', colors: colors },
    { name: '{{ section.settings.variant_2_name }}', tag: '{{ section.settings.variant_2_tag }}', colors: [colors[1], colors[2], colors[0]] },
    { name: '{{ section.settings.variant_3_name }}', tag: '{{ section.settings.variant_3_tag }}', colors: [colors[2], colors[0], colors[1]] },
    { name: '{{ section.settings.variant_4_name }}', tag: '{{ section.settings.variant_4_tag }}', colors: ['#0E0E0E', colors[0], colors[1]] }
  ];

  var grid = document.getElementById('w1wColorGrid');
  var nameEl = document.getElementById('w1wColorName');
  var tagEl = document.getElementById('w1wColorTag');
  if (!grid) return;

  function setActive(idx) {
    var v = variants[idx];
    grid.querySelectorAll('.w1w-colors__swatch').forEach(function (s, i) {
      s.classList.toggle('active', i === idx);
    });
    if (nameEl) nameEl.textContent = v.name;
    if (tagEl) tagEl.textContent = v.tag;
  }

  grid.innerHTML = variants.map(function (v, i) {
    return '<button class="w1w-colors__swatch' + (i === 0 ? ' active' : '') + '" data-ci="' + i + '" aria-label="' + v.name + '">' +
      '<span class="w1w-colors__dot" style="background:' + v.colors[0] + '"></span>' +
      '<span class="w1w-colors__dot" style="background:' + v.colors[1] + '"></span>' +
      '<span class="w1w-colors__dot" style="background:' + v.colors[2] + '"></span>' +
    '</button>';
  }).join('');

  setActive(0);

  grid.querySelectorAll('.w1w-colors__swatch').forEach(function (swatch) {
    swatch.addEventListener('click', function () {
      setActive(parseInt(swatch.dataset.ci));
      var thumbs = document.getElementById('w1wThumbs');
      if (thumbs) {
        var thumb = thumbs.querySelectorAll('.w1w-pdp-thumb')[parseInt(swatch.dataset.ci)];
        if (thumb) thumb.click();
      }
    });
  });
});
</script>

{% stylesheet %}
.w1w-colors {
  padding: 80px 0;
  background: var(--bg-0, #0E0E0E);
  border-top: 1px solid var(--line, rgba(243,255,202,0.12));
}
.w1w-colors__eyebrow {
  display: block;
  font-family: var(--font-display, 'Space Grotesk', sans-serif);
  font-size: 11px;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--lime, #F3FFCA);
  margin-bottom: 12px;
}
.w1w-colors__heading {
  font-family: var(--font-display, 'Space Grotesk', sans-serif);
  font-size: clamp(32px, 5vw, 56px);
  font-weight: 700;
  color: var(--ink-0, #fff);
  line-height: 0.92;
  letter-spacing: -0.03em;
  margin: 0 0 16px;
  text-transform: uppercase;
}
.w1w-colors__desc {
  color: var(--ink-2, #ADAAAA);
  font-size: 14px;
  line-height: 1.6;
  max-width: 480px;
  margin: 0 0 40px;
}

.w1w-colors__row {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 24px;
}

.w1w-colors__swatch {
  display: flex;
  gap: 6px;
  align-items: center;
  padding: 12px 20px;
  background: var(--bg-1, #131313);
  border: 2px solid transparent;
  border-radius: 40px;
  cursor: pointer;
  transition: border-color .2s, background .2s, transform .15s;
}
.w1w-colors__swatch:hover {
  border-color: rgba(243,255,202,0.3);
  background: var(--bg-2, #1C1C1C);
}
.w1w-colors__swatch.active {
  border-color: var(--lime, #F3FFCA);
  background: var(--bg-2, #1C1C1C);
  transform: scale(1.05);
}

.w1w-colors__dot {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: block;
  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.1);
}

.w1w-colors__selected {
  display: flex;
  align-items: center;
  gap: 12px;
}
.w1w-colors__selected-name {
  font-family: var(--font-display, 'Space Grotesk', sans-serif);
  font-weight: 700;
  font-size: 14px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--lime, #F3FFCA);
}
.w1w-colors__selected-tag {
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--ink-3, #737373);
}

@media (max-width: 600px) {
  .w1w-colors { padding: 48px 0; }
  .w1w-colors__row { gap: 10px; }
  .w1w-colors__swatch { padding: 10px 16px; }
  .w1w-colors__dot { width: 20px; height: 20px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "W1W Color Variants",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Colorway"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PICK YOUR EDITION."
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Four colorways per nation — choose the one that matches your game day fit."
    },
    {
      "type": "header",
      "content": "Variant names"
    },
    { "type": "text", "id": "variant_1_name", "label": "Variant 1 name", "default": "Home" },
    { "type": "text", "id": "variant_1_tag",  "label": "Variant 1 tag",  "default": "DROP 03" },
    { "type": "text", "id": "variant_2_name", "label": "Variant 2 name", "default": "Away" },
    { "type": "text", "id": "variant_2_tag",  "label": "Variant 2 tag",  "default": "ALTERNATE" },
    { "type": "text", "id": "variant_3_name", "label": "Variant 3 name", "default": "Reverse" },
    { "type": "text", "id": "variant_3_tag",  "label": "Variant 3 tag",  "default": "INVERTED" },
    { "type": "text", "id": "variant_4_name", "label": "Variant 4 name", "default": "Blackout" },
    { "type": "text", "id": "variant_4_tag",  "label": "Variant 4 tag",  "default": "STEALTH" }
  ],
  "presets": [{ "name": "W1W Color Variants" }]
}
{% endschema %}
