<section class="w1w-colors" id="w1w-pdp-colors">
  <div class="wrap">
    {%- if section.settings.eyebrow != blank -%}
      <span class="w1w-colors__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="w1w-colors__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="w1w-colors__desc">{{ section.settings.description }}</p>
    {%- endif -%}

    <div class="w1w-colors__row" id="w1wColorRow"></div>
    <div class="w1w-colors__selected">
      <span class="w1w-colors__selected-name" id="w1wColorName">—</span>
    </div>
  </div>
</section>

<script>
(function () {
  function init() {
    var COUNTRIES = window.W1W_COUNTRIES;
    if (!COUNTRIES) return;

    var slug = {{ product.handle | json }};
    var country = COUNTRIES.find(function (c) { return c.slug === slug; });
    if (!country || !country.colors) return;

    var c = country.colors;
    var variants = [
      { name: '{{ section.settings.variant_1_name }}', colors: [c[0], c[1], c[2]] },
      { name: '{{ section.settings.variant_2_name }}', colors: [c[1], c[2], c[0]] },
      { name: '{{ section.settings.variant_3_name }}', colors: [c[2], c[0], c[1]] },
      { name: '{{ section.settings.variant_4_name }}', colors: ['#0E0E0E', c[0], c[1]] }
    ];

    var row = document.getElementById('w1wColorRow');
    var nameEl = document.getElementById('w1wColorName');
    if (!row) return;

    var html = '';
    for (var i = 0; i < variants.length; i++) {
      var v = variants[i];
      html += '<button type="button" class="w1w-colors__swatch' + (i === 0 ? ' active' : '') + '" data-ci="' + i + '">';
      html += '<span class="w1w-colors__dot" style="background:' + v.colors[0] + ';"></span>';
      html += '<span class="w1w-colors__dot" style="background:' + v.colors[1] + ';"></span>';
      html += '<span class="w1w-colors__dot" style="background:' + v.colors[2] + ';"></span>';
      html += '<span class="w1w-colors__name">' + v.name + '</span>';
      html += '</button>';
    }
    row.innerHTML = html;
    if (nameEl) nameEl.textContent = variants[0].name;

    row.addEventListener('click', function (e) {
      var btn = e.target.closest('.w1w-colors__swatch');
      if (!btn) return;
      var idx = parseInt(btn.dataset.ci);

      row.querySelectorAll('.w1w-colors__swatch').forEach(function (s) { s.classList.remove('active'); });
      btn.classList.add('active');
      if (nameEl) nameEl.textContent = variants[idx].name;

      // Sync with gallery thumbs
      var thumbs = document.getElementById('w1wThumbs');
      if (thumbs) {
        var thumb = thumbs.querySelectorAll('.w1w-pdp-thumb')[idx];
        if (thumb) thumb.click();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

{% stylesheet %}
.w1w-colors {
  padding: 80px 0;
  background: var(--bg-0, #0E0E0E);
  border-top: 1px solid var(--line, rgba(243,255,202,0.12));
}
.w1w-colors__eyebrow {
  display: block;
  font-family: var(--font-display, 'Space Grotesk', sans-serif);
  font-size: 11px;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--lime, #F3FFCA);
  margin-bottom: 12px;
}
.w1w-colors__heading {
  font-family: var(--font-display, 'Space Grotesk', sans-serif);
  font-size: clamp(32px, 5vw, 56px);
  font-weight: 700;
  color: var(--ink-0, #fff);
  line-height: 0.92;
  letter-spacing: -0.03em;
  margin: 0 0 16px;
  text-transform: uppercase;
}
.w1w-colors__desc {
  color: var(--ink-2, #ADAAAA);
  font-size: 14px;
  line-height: 1.6;
  max-width: 480px;
  margin: 0 0 40px;
}
.w1w-colors__row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 24px;
}
.w1w-colors__swatch {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px 10px 12px;
  background: var(--bg-1, #131313);
  border: 2px solid rgba(243,255,202,0.08);
  border-radius: 40px;
  cursor: pointer;
  transition: border-color .2s, background .2s, transform .15s;
}
.w1w-colors__swatch:hover {
  border-color: rgba(243,255,202,0.3);
  background: var(--bg-2, #1C1C1C);
}
.w1w-colors__swatch.active {
  border-color: var(--lime, #F3FFCA);
  background: var(--bg-2, #1C1C1C);
  transform: scale(1.05);
}
.w1w-colors__dot {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  display: block;
  flex-shrink: 0;
  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.15);
}
.w1w-colors__name {
  font-family: var(--font-display, 'Space Grotesk', sans-serif);
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-2, #ADAAAA);
  margin-left: 4px;
}
.w1w-colors__swatch.active .w1w-colors__name {
  color: var(--lime, #F3FFCA);
}
.w1w-colors__selected {
  display: flex;
  align-items: center;
}
.w1w-colors__selected-name {
  font-family: var(--font-display, 'Space Grotesk', sans-serif);
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--lime, #F3FFCA);
}
@media (max-width: 600px) {
  .w1w-colors { padding: 48px 0; }
  .w1w-colors__row { gap: 8px; }
  .w1w-colors__swatch { padding: 8px 14px 8px 8px; }
  .w1w-colors__dot { width: 18px; height: 18px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "W1W Color Variants",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Colorway"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PICK YOUR EDITION."
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Four colorways per nation — choose the one that matches your game day fit."
    },
    {
      "type": "header",
      "content": "Variant names"
    },
    { "type": "text", "id": "variant_1_name", "label": "Variant 1 name", "default": "Home" },
    { "type": "text", "id": "variant_2_name", "label": "Variant 2 name", "default": "Away" },
    { "type": "text", "id": "variant_3_name", "label": "Variant 3 name", "default": "Reverse" },
    { "type": "text", "id": "variant_4_name", "label": "Variant 4 name", "default": "Blackout" }
  ],
  "presets": [{ "name": "W1W Color Variants" }]
}
{% endschema %}
