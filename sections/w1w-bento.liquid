<section class="w1w-bento">
  <div class="w1w-bento__inner">
    <div class="w1w-bento__grid">

      <div class="w1w-bento__card w1w-bento__card--legacy">
        <div class="w1w-bento__card-content">
          <h3 class="w1w-bento__card-title">
            {{ section.settings.legacy_title }}
          </h3>
          <p class="w1w-bento__card-desc">{{ section.settings.legacy_desc }}</p>
        </div>
        {%- if section.settings.legacy_image != blank -%}
          {{ section.settings.legacy_image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'w1w-bento__card-bg-img', alt: section.settings.legacy_image.alt }}
        {%- endif -%}
        <a href="{{ section.settings.legacy_link }}" class="w1w-bento__card-cta">
          {{ section.settings.legacy_cta }}
        </a>
      </div>

      <div class="w1w-bento__card w1w-bento__card--player">
        <div class="w1w-bento__card-row">
          <div>
            <h3 class="w1w-bento__card-title w1w-bento__card-title--sm">{{ section.settings.player_title }}</h3>
            <p class="w1w-bento__card-desc">{{ section.settings.player_desc }}</p>
          </div>
          <svg class="w1w-bento__icon" width="48" height="56" viewBox="0 0 32 40" fill="currentColor"><path d="M8 40l2-14H0L18 0h4l-2 16h12L12 40H8z"/></svg>
        </div>
      </div>

      <div class="w1w-bento__card w1w-bento__card--shipping">
        <svg class="w1w-bento__icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"/></svg>
        <h3 class="w1w-bento__card-title w1w-bento__card-title--sm">{{ section.settings.shipping_title }}</h3>
        <p class="w1w-bento__card-desc">73 countries</p>
      </div>

      <div class="w1w-bento__card w1w-bento__card--quality">
        <svg class="w1w-bento__icon w1w-bento__icon--dark" width="32" height="32" viewBox="0 0 30 28.5" fill="currentColor"><path d="M5.7 28.5 8.2 18 0 10.9 10.8 9.9 15 0 19.2 9.9 30 10.9 21.8 18l2.5 10.5L15 22.9z"/></svg>
        <h3 class="w1w-bento__card-title w1w-bento__card-title--sm w1w-bento__card-title--dark">
          {{ section.settings.quality_title }}
        </h3>
        <p class="w1w-bento__card-desc w1w-bento__card-desc--dark">Pro-grade paracord</p>
      </div>

    </div>
  </div>
</section>

{% stylesheet %}
  .w1w-bento {
    padding: 96px 0;
    background: #0e0e0e;
  }
  .w1w-bento__inner {
    max-width: 1536px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .w1w-bento__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto auto;
    gap: 8px;
  }
  .w1w-bento__card {
    padding: 48px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
  }
  .w1w-bento__card--legacy {
    grid-column: span 2;
    grid-row: span 2;
    background: #131313;
    min-height: 600px;
  }
  .w1w-bento__card--player {
    grid-column: span 2;
    background: #201f1f;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding: 32px;
    min-height: 280px;
  }
  .w1w-bento__card--shipping {
    background: #262626;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 32px;
    text-align: center;
    min-height: 280px;
  }
  .w1w-bento__card--quality {
    background: #f3ffca;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 32px;
    text-align: center;
    min-height: 280px;
  }
  .w1w-bento__card-content {
    position: relative;
    z-index: 10;
  }
  .w1w-bento__card-title {
    font-family: "Space Grotesk", sans-serif;
    font-size: 2rem;
    font-weight: 900;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 16px;
  }
  .w1w-bento__card-title--sm {
    font-size: 1.25rem;
    margin: 0;
  }
  .w1w-bento__card-title--dark {
    color: #516700;
  }
  .w1w-bento__card-desc {
    color: #adaaaa;
    font-family: "Inter", sans-serif;
    font-size: 0.9rem;
    max-width: 18rem;
    margin: 0;
    line-height: 1.5;
  }
  .w1w-bento__card-bg-img {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 66%;
    object-fit: contain;
    transform: translate(40px, 40px);
    transition: transform 1s;
    opacity: 0.4;
  }
  .w1w-bento__card--legacy:hover .w1w-bento__card-bg-img {
    transform: translate(0, 0);
    opacity: 1;
  }
  .w1w-bento__card-cta {
    position: relative;
    z-index: 10;
    display: inline-block;
    color: #f3ffca;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-decoration: none;
    border-bottom: 2px solid #f3ffca;
    padding-bottom: 4px;
    width: fit-content;
  }
  .w1w-bento__icon {
    color: #f3ffca;
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .w1w-bento__icon--dark {
    color: #516700;
  }
  .w1w-bento__card-desc--dark {
    color: #516700;
  }
  .w1w-bento__card--player:hover .w1w-bento__icon {
    transform: translateX(8px);
  }
  .w1w-bento__card--shipping {
    text-align: center;
  }
  .w1w-bento__card--shipping .w1w-bento__card-title--sm {
    color: #fff;
  }
  .w1w-bento__card--quality {
    text-align: center;
  }
  .w1w-bento__card--player .w1w-bento__card-row {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .w1w-bento__card--player .w1w-bento__card-desc {
    font-size: 0.8rem;
    margin-top: 4px;
    max-width: none;
  }
  @media (max-width: 990px) {
    .w1w-bento__grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
    }
    .w1w-bento__card--legacy {
      grid-column: span 2;
      grid-row: span 1;
      min-height: 320px;
    }
    .w1w-bento__card--player {
      grid-column: span 2;
    }
  }
  @media (max-width: 480px) {
    .w1w-bento__grid {
      grid-template-columns: 1fr;
    }
    .w1w-bento__card--legacy,
    .w1w-bento__card--player {
      grid-column: span 1;
    }
    .w1w-bento__inner {
      padding: 0 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "W1W Bento Grid",
  "settings": [
    {
      "type": "header",
      "content": "Legacy Series card"
    },
    {
      "type": "text",
      "id": "legacy_title",
      "label": "Title",
      "default": "The World Cup Legacy Series"
    },
    {
      "type": "text",
      "id": "legacy_desc",
      "label": "Description",
      "default": "Commemorating the greatest stages in football history."
    },
    {
      "type": "image_picker",
      "id": "legacy_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "legacy_cta",
      "label": "CTA label",
      "default": "Shop Legacy"
    },
    {
      "type": "url",
      "id": "legacy_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Player Edition card"
    },
    {
      "type": "text",
      "id": "player_title",
      "label": "Title",
      "default": "Player Edition"
    },
    {
      "type": "text",
      "id": "player_desc",
      "label": "Description",
      "default": "Lightweight. Breathable. Pro-grade."
    },
    {
      "type": "header",
      "content": "Global Shipping card"
    },
    {
      "type": "text",
      "id": "shipping_title",
      "label": "Title",
      "default": "Global Shipping"
    },
    {
      "type": "header",
      "content": "Elite Quality card"
    },
    {
      "type": "text",
      "id": "quality_title",
      "label": "Title",
      "default": "Elite Quality"
    }
  ],
  "presets": [
    {
      "name": "W1W Bento Grid"
    }
  ]
}
{% endschema %}
