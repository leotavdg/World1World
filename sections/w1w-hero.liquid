<section class="w1w-hero" id="w1wHero">
  <div class="w1w-hero__bg" id="w1wHeroBg">
    {%- if section.settings.bg_image != blank -%}
      {{ section.settings.bg_image | image_url: width: 2000 | image_tag: loading: 'eager', class: 'w1w-hero__bg-img', alt: section.settings.bg_image.alt }}
    {%- endif -%}
    <div class="w1w-hero__bg-gradient"></div>
  </div>
  <div class="w1w-hero__flood"></div>
  <div class="w1w-hero__smoke"></div>

  <div class="w1w-hero__inner">
    <div class="w1w-hero__content">
      {%- if section.settings.badge_text != blank -%}
        <span class="w1w-hero__badge">{{ section.settings.badge_text }}</span>
      {%- endif -%}
      <h1 class="w1w-hero__headline">
        {{ section.settings.headline_line1 }}<br>
        <span class="w1w-hero__accent">{{ section.settings.headline_line2 }}</span>
      </h1>
      {%- if section.settings.subtext != blank -%}
        <p class="w1w-hero__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
      <div class="w1w-hero__actions">
        {%- if section.settings.primary_button_label != blank -%}
          <a href="{{ section.settings.primary_button_link }}" class="w1w-btn w1w-btn--primary w1w-btn--lg">
            {{ section.settings.primary_button_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_button_label != blank -%}
          <a href="{{ section.settings.secondary_button_link }}" class="w1w-btn w1w-btn--ghost w1w-btn--lg">
            {{ section.settings.secondary_button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.product_image != blank -%}
      <div class="w1w-hero__product-wrap">
        <div class="w1w-hero__product-glow"></div>
        {%- if section.settings.corner_tl != blank -%}
          <span class="w1w-hero__corner w1w-hero__corner--tl">{{ section.settings.corner_tl }}</span>
        {%- endif -%}
        {{ section.settings.product_image | image_url: width: 800 | image_tag: loading: 'eager', class: 'w1w-hero__product-img', alt: section.settings.product_image.alt }}
        {%- if section.settings.corner_br != blank -%}
          <span class="w1w-hero__corner w1w-hero__corner--br">{{ section.settings.corner_br }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  {%- if section.settings.stat1_label != blank or section.settings.stat2_label != blank or section.settings.stat3_label != blank -%}
    <div class="w1w-hero__meta">
      {%- if section.settings.stat1_label != blank -%}
        <div class="w1w-hero__stat">
          {{ section.settings.stat1_label }}<strong>{{ section.settings.stat1_value }}</strong>
        </div>
      {%- endif -%}
      {%- if section.settings.stat2_label != blank -%}
        <div class="w1w-hero__stat">
          {{ section.settings.stat2_label }}<strong>{{ section.settings.stat2_value }}</strong>
        </div>
      {%- endif -%}
      {%- if section.settings.stat3_label != blank -%}
        <div class="w1w-hero__stat">
          {{ section.settings.stat3_label }}<strong>{{ section.settings.stat3_value }}</strong>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

<script>
(function () {
  var heroBg = document.getElementById('w1wHeroBg');
  if (!heroBg) return;
  window.addEventListener('scroll', function () {
    var y = window.scrollY;
    if (y < 1200) heroBg.style.transform = 'translateY(' + (y * 0.15) + 'px)';
  }, { passive: true });
})();
</script>

{% stylesheet %}
  .w1w-hero {
    position: relative;
    min-height: clamp(680px, 92vh, 920px);
    overflow: hidden;
    background: #000;
    isolation: isolate;
  }

  /* Background image */
  .w1w-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    will-change: transform;
  }
  .w1w-hero__bg-img {
    width: 100%;
    height: 115%;
    object-fit: cover;
    opacity: 0.42;
    mix-blend-mode: luminosity;
    display: block;
  }
  .w1w-hero__bg-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 80% 50%, rgba(243, 255, 202, 0.07), transparent),
      linear-gradient(180deg, rgba(14, 14, 14, 0.7) 0%, rgba(14, 14, 14, 0.15) 40%, rgba(14, 14, 14, 0.1) 60%, #0e0e0e 100%);
  }

  /* Flood sweep */
  .w1w-hero__flood {
    position: absolute;
    top: -10%;
    width: 120%;
    height: 120%;
    left: -10%;
    background: conic-gradient(
      from 210deg at 50% 0%,
      transparent 340deg,
      rgba(243, 255, 202, 0.07) 355deg,
      rgba(243, 255, 202, 0.13) 360deg,
      rgba(243, 255, 202, 0.07) 365deg,
      transparent 380deg
    );
    animation: w1w-floodSweep 12s ease-in-out infinite alternate;
    pointer-events: none;
    mix-blend-mode: screen;
    z-index: 1;
  }
  @keyframes w1w-floodSweep {
    from { transform: rotate(-8deg); }
    to   { transform: rotate(8deg); }
  }

  /* Smoke drift */
  .w1w-hero__smoke {
    position: absolute;
    bottom: -20%;
    left: -10%;
    right: -10%;
    height: 60%;
    background:
      radial-gradient(ellipse at 30% 80%, rgba(243, 255, 202, 0.05), transparent 50%),
      radial-gradient(ellipse at 70% 60%, rgba(255, 255, 255, 0.03), transparent 60%);
    animation: w1w-smokeDrift 18s ease-in-out infinite alternate;
    pointer-events: none;
    z-index: 1;
  }
  @keyframes w1w-smokeDrift {
    from { transform: translate(-4%, 2%) scale(1); }
    to   { transform: translate(4%, -3%) scale(1.15); }
  }

  /* Inner grid */
  .w1w-hero__inner {
    position: relative;
    z-index: 2;
    max-width: 1440px;
    margin: 0 auto;
    padding: 96px clamp(24px, 4vw, 64px);
    padding-bottom: 120px;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 48px;
    align-items: center;
  }

  /* Content */
  .w1w-hero__badge {
    display: inline-flex;
    background: #F3FFCA;
    color: #516700 !important;
    padding: 6px 10px;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 32px;
  }
  .w1w-hero__headline {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(72px, 11vw, 160px);
    font-weight: 700;
    color: #fff;
    line-height: 0.88;
    letter-spacing: -0.04em;
    margin: 0 0 32px;
  }
  .w1w-hero__accent { color: #f3ffca; }
  .w1w-hero__subtext {
    color: #d4d4d4;
    font-family: "Inter", sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 1.6;
    max-width: 440px;
    margin: 0 0 40px;
  }
  .w1w-hero__actions { display: flex; gap: 16px; flex-wrap: wrap; }

  /* Buttons (shared across W1W sections) */
  .w1w-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 18px 32px;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px solid transparent;
    transition: transform 0.12s ease, background 0.18s ease, border-color 0.18s ease, color 0.18s ease, filter 0.18s ease;
    cursor: pointer;
    white-space: nowrap;
    text-decoration: none;
  }
  .w1w-btn:active { transform: translateY(1px); }
  .w1w-btn--primary {
    background: linear-gradient(180deg, #f3ffca 0%, #cafd00 100%);
    color: #516700;
  }
  .w1w-btn--primary:hover { filter: brightness(1.05); }
  .w1w-btn--ghost {
    background: #262626;
    border-color: rgba(243, 255, 202, 0.2);
    color: #f3ffca;
  }
  .w1w-btn--ghost:hover { border-color: #f3ffca; }
  .w1w-btn--outline {
    background: transparent;
    border-color: #f3ffca;
    color: #f3ffca;
  }
  .w1w-btn--outline:hover { background: #f3ffca; color: #516700; }
  .w1w-btn--lg { padding: 22px 44px; font-size: 14px; letter-spacing: 0.14em; }
  .w1w-btn--sm { padding: 12px 20px; font-size: 11px; }
  .w1w-btn--block { width: 100%; justify-content: center; }

  /* Product image */
  .w1w-hero__product-wrap {
    position: relative;
    aspect-ratio: 4 / 5;
    max-width: 560px;
    justify-self: end;
    transform: rotate(3deg);
    transform-origin: center;
  }
  .w1w-hero__product-wrap::before {
    content: '';
    position: absolute;
    inset: -20px;
    background: rgba(243, 255, 202, 0.07);
    backdrop-filter: blur(8px);
    z-index: -1;
  }
  .w1w-hero__product-glow {
    position: absolute;
    inset: -60px;
    background: rgba(243, 255, 202, 0.08);
    filter: blur(60px);
    border-radius: 50%;
    pointer-events: none;
    z-index: -1;
  }
  .w1w-hero__product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.7);
  }
  .w1w-hero__corner {
    position: absolute;
    padding: 6px 10px;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .w1w-hero__corner--tl {
    top: -12px;
    left: -12px;
    background: #131313;
    color: #f3ffca;
    border: 1px solid rgba(243, 255, 202, 0.25);
  }
  .w1w-hero__corner--br {
    bottom: -12px;
    right: -12px;
    background: #f3ffca;
    color: #516700;
  }

  /* Stats bar */
  .w1w-hero__meta {
    position: absolute;
    left: clamp(24px, 4vw, 64px);
    bottom: 32px;
    display: flex;
    gap: 48px;
    font-family: "Space Grotesk", sans-serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: #737373;
    text-transform: uppercase;
    z-index: 3;
  }
  .w1w-hero__stat { display: flex; flex-direction: column; }
  .w1w-hero__stat strong {
    color: #f3ffca;
    display: block;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 0;
    margin-top: 4px;
  }

  /* Responsive */
  @media (max-width: 960px) {
    .w1w-hero__inner {
      grid-template-columns: 1fr;
      gap: 32px;
      padding-bottom: 96px;
    }
    .w1w-hero__product-wrap { max-width: 100%; }
    .w1w-hero__meta { gap: 24px; }
  }
  @media (max-width: 600px) {
    .w1w-hero__meta { display: none; }
  }
{% endstylesheet %}

