<section class="w1w-sv">
  <div class="w1w-sv__inner">

    <div class="w1w-sv__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="w1w-sv__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="w1w-sv__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="w1w-sv__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="w1w-sv__grid">
        {%- for block in section.blocks -%}
          <div class="w1w-sv__card {% if forloop.first %}w1w-sv__card--accent{% endif %}" {{ block.shopify_attributes }}>
            <div class="w1w-sv__card-icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'globe' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"/></svg>
                {%- when 'bolt' -%}
                  <svg width="24" height="28" viewBox="0 0 32 40" fill="currentColor"><path d="M8 40l2-14H0L18 0h4l-2 16h12L12 40H8z"/></svg>
                {%- when 'star' -%}
                  <svg width="28" height="28" viewBox="0 0 30 28.5" fill="currentColor"><path d="M5.7 28.5 8.2 18 0 10.9 10.8 9.9 15 0 19.2 9.9 30 10.9 21.8 18l2.5 10.5L15 22.9z"/></svg>
                {%- when 'heart' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                {%- when 'flag' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
                {%- else -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"/></svg>
              {%- endcase -%}
            </div>
            {%- if block.settings.title != blank -%}
              <h3 class="w1w-sv__card-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="w1w-sv__card-desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
  .w1w-sv {
    background: #0a0a0a;
    padding: 120px 0;
  }
  .w1w-sv__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 clamp(24px, 4vw, 80px);
  }

  /* Header */
  .w1w-sv__header {
    max-width: 640px;
    margin-bottom: 64px;
  }
  .w1w-sv__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: "Space Grotesk", sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #f3ffca;
    margin-bottom: 20px;
  }
  .w1w-sv__eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: #f3ffca;
    opacity: 0.5;
  }
  .w1w-sv__heading {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 20px;
  }
  .w1w-sv__subtext {
    font-family: "Inter", sans-serif;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.7;
    margin: 0;
  }

  /* Grid */
  .w1w-sv__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 8px;
  }
  .w1w-sv__card {
    background: #131313;
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: border-color 0.25s, background 0.25s;
  }
  .w1w-sv__card:hover {
    border-color: rgba(243, 255, 202, 0.2);
    background: #181818;
  }
  .w1w-sv__card--accent {
    background: #f3ffca;
    border-color: transparent;
  }
  .w1w-sv__card--accent:hover {
    background: #edfab8;
    border-color: transparent;
  }
  .w1w-sv__card--accent .w1w-sv__card-icon { color: #516700; }
  .w1w-sv__card--accent .w1w-sv__card-title { color: #1a2800; }
  .w1w-sv__card--accent .w1w-sv__card-desc { color: #516700; }

  .w1w-sv__card-icon {
    color: #f3ffca;
    flex-shrink: 0;
  }
  .w1w-sv__card-title {
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin: 0;
    line-height: 1.2;
  }
  .w1w-sv__card-desc {
    font-family: "Inter", sans-serif;
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 600px) {
    .w1w-sv { padding: 72px 0; }
    .w1w-sv__card { padding: 32px 24px; }
    .w1w-sv__header { margin-bottom: 40px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "W1W Story Values",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "What We Stand For"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built on Three Pillars"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Every decision we make — from materials to markets — comes back to these core beliefs."
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "globe",  "label": "Globe" },
            { "value": "bolt",   "label": "Bolt / Energy" },
            { "value": "star",   "label": "Star / Quality" },
            { "value": "heart",  "label": "Heart / Community" },
            { "value": "flag",   "label": "Flag / Nation" }
          ],
          "default": "globe"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Global Community"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Football is the world's language. We make something every fan on every continent can wear with pride."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "W1W Story Values",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "icon": "globe",
            "title": "Global Community",
            "description": "Football is the world's language. We make something every fan on every continent can wear with pride."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "star",
            "title": "Elite Craft",
            "description": "Pro-grade paracord. Military spec hardware. Every bead and knot engineered to outlast the season."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "bolt",
            "title": "Match Day Energy",
            "description": "We don't make jewelry. We make fuel. The wristband you put on before kick-off and never take off."
          }
        }
      ]
    }
  ]
}
{% endschema %}
