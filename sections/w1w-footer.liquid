<footer class="w1w-footer">
  <div class="wrap">
    <div class="w1w-footer-top">

      <!-- Brand -->
      <div class="w1w-footer-brand">
        <h3 class="w1w-footer-logo">WORLD<span class="w1w-footer-dot"></span>1<span class="w1w-footer-dot"></span>WORLD</h3>
        <p class="w1w-footer-tagline">{{ section.settings.tagline }}</p>
        <div class="w1w-footer-social">
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" class="w1w-footer-icon-btn" aria-label="Instagram" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.tiktok_url != blank -%}
            <a href="{{ section.settings.tiktok_url }}" class="w1w-footer-icon-btn" aria-label="TikTok" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M10 8v10a3 3 0 1 1-3-3"/><path d="M10 8a5 5 0 0 0 5 5V8"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.twitter_url != blank -%}
            <a href="{{ section.settings.twitter_url }}" class="w1w-footer-icon-btn" aria-label="X" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 3h3l-7.5 8.6L22 21h-6.8l-5-6.5L4 21H1l8.1-9.3L1 3h7l4.6 6z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Shop column -->
      <div class="w1w-footer-col">
        <h4 class="w1w-footer-col-h">{{ section.settings.shop_heading }}</h4>
        <ul class="w1w-footer-links">
          {%- if linklists[section.settings.shop_menu].links.size > 0 -%}
            {%- for link in linklists[section.settings.shop_menu].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="{{ routes.all_products_collection_url }}">All Nations</a></li>
            <li><a href="{{ routes.all_products_collection_url }}">New Arrivals</a></li>
            <li><a href="{{ routes.all_products_collection_url }}">Best Sellers</a></li>
            <li><a href="{{ routes.collections_url }}">Collections</a></li>
          {%- endif -%}
        </ul>
      </div>

      <!-- Support column -->
      <div class="w1w-footer-col">
        <h4 class="w1w-footer-col-h">{{ section.settings.support_heading }}</h4>
        <ul class="w1w-footer-links">
          {%- if linklists[section.settings.support_menu].links.size > 0 -%}
            {%- for link in linklists[section.settings.support_menu].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="/pages/faq">Shipping</a></li>
            <li><a href="/pages/faq">Returns</a></li>
            <li><a href="/pages/faq">Sizing</a></li>
            <li><a href="/pages/faq">FAQ</a></li>
            <li><a href="/pages/contact">Contact</a></li>
          {%- endif -%}
        </ul>
      </div>

      <!-- Newsletter -->
      <div class="w1w-footer-col w1w-footer-news">
        <h4 class="w1w-footer-col-h">{{ section.settings.newsletter_heading }}</h4>
        <p class="w1w-footer-news-desc">{{ section.settings.newsletter_desc }}</p>
        {%- form 'customer', class: 'w1w-footer-newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="w1w-footer-news-row">
            <input
              type="email"
              name="contact[email]"
              class="w1w-footer-news-input"
              placeholder="{{ section.settings.email_placeholder }}"
              required
              autocomplete="email"
            >
            <button type="submit" class="w1w-footer-news-btn">
              {{ section.settings.submit_label }}
            </button>
          </div>
          {%- if form.posted_successfully? -%}
            <p class="w1w-footer-news-success">✓ {{ section.settings.success_message }}</p>
          {%- endif -%}
          <p class="w1w-recaptcha-notice">This site is protected by reCAPTCHA and the Google <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Privacy Policy</a> and <a href="https://policies.google.com/terms" target="_blank" rel="noopener">Terms of Service</a> apply.</p>
        {%- endform -%}
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="w1w-footer-bottom">
      <span>{{ section.settings.copyright_text }}</span>
      <ul>
        {%- for policy in shop.policies -%}
          {%- if policy != blank -%}
            <li><a href="{{ policy.url }}">{{ policy.title }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  </div>
</footer>

{% stylesheet %}
.w1w-footer {
  background: var(--bg-1, #131313);
  border-top: 1px solid var(--line, rgba(243,255,202,0.12));
  padding: 80px 0 32px;
  margin-top: 0;
}

/* Top grid — 4 columns */
.w1w-footer-top {
  display: grid;
  grid-template-columns: 1.4fr 1fr 1fr 1.4fr;
  gap: 48px;
  padding-bottom: 64px;
  border-bottom: 1px solid var(--line, rgba(243,255,202,0.12));
}

/* Brand */
.w1w-footer-logo {
  font-family: var(--font-display, 'Space Grotesk', sans-serif);
  font-size: 18px;
  font-weight: 700;
  color: var(--lime, #F3FFCA);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 16px;
  line-height: 0.95;
}
.w1w-footer-dot {
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--lime-hot, #CAFD00);
  margin: 0 6px 2px;
  vertical-align: middle;
  box-shadow: 0 0 12px var(--lime-hot, #CAFD00);
}
.w1w-footer-tagline {
  font-size: 14px;
  color: var(--ink-1, #D4D4D4);
  max-width: 320px;
  margin-bottom: 24px;
  line-height: 1.7;
}
.w1w-footer-social {
  display: flex;
  gap: 12px;
}
.w1w-footer-icon-btn {
  width: 40px;
  height: 40px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--ink-1, #D4D4D4);
  border-radius: 4px;
  transition: color .15s, background .15s;
  text-decoration: none;
}
.w1w-footer-icon-btn:hover {
  color: var(--lime, #F3FFCA);
  background: rgba(243,255,202,0.08);
}

/* Link columns */
.w1w-footer-col-h {
  font-family: var(--font-display, 'Space Grotesk', sans-serif);
  font-size: 11px;
  letter-spacing: 0.2em;
  color: var(--lime, #F3FFCA);
  text-transform: uppercase;
  font-weight: 700;
  margin-bottom: 20px;
  line-height: 0.95;
}
.w1w-footer-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 0;
  margin: 0;
}
.w1w-footer-links a {
  font-size: 13px;
  color: var(--ink-1, #D4D4D4);
  text-decoration: none;
  transition: color .12s;
}
.w1w-footer-links a:hover {
  color: var(--lime, #F3FFCA);
}

/* Newsletter */
.w1w-footer-news-desc {
  color: var(--ink-2, #ADAAAA);
  font-size: 13px;
  margin-bottom: 16px;
  line-height: 1.5;
}
.w1w-footer-newsletter-form {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.w1w-footer-news-row {
  display: flex;
  align-items: center;
  gap: 10px;
}
.w1w-footer-news-input {
  flex: 1;
  min-width: 0;
  background: #1a1a1a !important;
  background-color: #1a1a1a !important;
  border: 1px solid rgba(243,255,202,0.15) !important;
  border-color: rgba(243,255,202,0.15) !important;
  border-radius: 4px;
  color: #FFF !important;
  padding: 10px 12px;
  font-family: 'Inter', sans-serif;
  font-size: 0.8125rem;
  outline: none !important;
  box-shadow: none !important;
  transition: border-color 0.2s;
}
.w1w-footer-news-input:hover,
.w1w-footer-news-input:focus {
  background: #222 !important;
  background-color: #222 !important;
  border-color: rgba(243,255,202,0.5) !important;
}
.w1w-footer-news-input::placeholder {
  color: rgba(255,255,255,0.3) !important;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-size: 0.75rem;
}
.w1w-footer-news-btn {
  background: var(--lime-hot, #CAFD00);
  color: var(--lime-dark, #516700);
  padding: 10px 20px;
  font-family: var(--font-display, 'Space Grotesk', sans-serif);
  font-weight: 700;
  font-size: 0.6875rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  transition: background .15s;
  white-space: nowrap;
}
.w1w-footer-news-btn:hover {
  background: var(--lime, #F3FFCA);
}
.w1w-footer-news-success {
  color: var(--lime, #F3FFCA);
  margin-top: 12px;
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* Bottom bar */
.w1w-footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 32px;
  font-size: 12px;
  color: var(--ink-3, #737373);
  flex-wrap: wrap;
  gap: 16px;
}
.w1w-footer-bottom ul {
  list-style: none;
  display: flex;
  gap: 24px;
  padding: 0;
  margin: 0;
}
.w1w-footer-bottom a {
  color: var(--ink-3, #737373);
  text-decoration: none;
  font-size: 12px;
  transition: color .12s;
}
.w1w-footer-bottom a:hover {
  color: var(--lime, #F3FFCA);
}

/* Responsive */
@media (max-width: 900px) {
  .w1w-footer-top {
    grid-template-columns: 1fr 1fr;
  }
  .w1w-footer-brand {
    grid-column: span 2;
  }
}
@media (max-width: 600px) {
  .w1w-footer {
    padding: 48px 0 24px;
  }
  .w1w-footer-top {
    grid-template-columns: 1fr;
    gap: 32px;
    padding-bottom: 40px;
  }
  .w1w-footer-brand {
    grid-column: span 1;
  }
  .w1w-footer-bottom {
    flex-direction: column;
    align-items: flex-start;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "W1W Footer",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Collectibles for the beautiful game. Worn on match day and every day after."
    },
    {
      "type": "header",
      "content": "Social links"
    },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok URL" },
    { "type": "url", "id": "twitter_url", "label": "Twitter / X URL" },
    {
      "type": "header",
      "content": "Shop column"
    },
    { "type": "text", "id": "shop_heading", "label": "Heading", "default": "SHOP" },
    { "type": "link_list", "id": "shop_menu", "label": "Menu" },
    {
      "type": "header",
      "content": "Support column"
    },
    { "type": "text", "id": "support_heading", "label": "Heading", "default": "SUPPORT" },
    { "type": "link_list", "id": "support_menu", "label": "Menu" },
    {
      "type": "header",
      "content": "Newsletter"
    },
    { "type": "text", "id": "newsletter_heading", "label": "Heading", "default": "JOIN THE RANKS" },
    { "type": "text", "id": "newsletter_desc", "label": "Description", "default": "First access to drops and exclusive editions." },
    { "type": "text", "id": "email_placeholder", "label": "Email placeholder", "default": "EMAIL ADDRESS" },
    { "type": "text", "id": "submit_label", "label": "Submit button label", "default": "JOIN" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "You're on the list." },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    { "type": "text", "id": "copyright_text", "label": "Copyright text", "default": "© 2026 World 1 World. All prices in USD." }
  ],
  "presets": [{ "name": "W1W Footer" }]
}
{% endschema %}
