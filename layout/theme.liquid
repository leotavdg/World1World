<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {% # theme-check-disable RemoteAsset %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link rel="expect" href="#MainContent" blocking="render" id="view-transition-render-blocker">
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}

    {{- 'w1w.css' | asset_url | stylesheet_tag -}}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet">

    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
    {% # theme-check-enable RemoteAsset %}

    <style>
      /* ── W1W Global Overrides (after framework CSS) ── */

      /* Force dark everywhere the framework tries to inject light colors */
      html, body {
        background: #0E0E0E !important;
        color: #FFFFFF !important;
      }

      /* Nuke light scheme backgrounds */
      .shopify-section > .section-background,
      .content-for-layout,
      main#MainContent {
        background-color: transparent !important;
      }

      /* Override ALL Shopify color scheme CSS vars to be dark */
      :root {
        --color-background: 14,14,14;
        --color-foreground: 255,255,255;
        --color-base-background-1: 14,14,14;
        --color-base-background-2: 19,19,19;
        --color-base-text: 255,255,255;
        --color-base-border-1: rgba(243,255,202,0.12);
        --color-base-border-2: rgba(243,255,202,0.25);
        --color-border: rgba(243,255,202,0.12);
        --colors-solid-button-labels: 81,103,0;
        --color-button: #F3FFCA;
        --color-button-text: #516700;
        --color-link: #F3FFCA;
        --color-header-background: rgba(14,14,14,0.85);
      }

      /* Force any computed background in scheme containers */
      [class*="color-scheme-"] {
        background-color: transparent !important;
        color: #FFFFFF !important;
      }

      /* Kill pure white injected backgrounds */
      [style*="background-color: rgb(255, 255, 255)"],
      [style*="background-color:rgb(255,255,255)"],
      [style*="background: rgb(255, 255, 255)"],
      [style*="background: white"] {
        background-color: #0E0E0E !important;
      }

      /* Hide framework announcement bar (we use w1w-announcement) */
      .announcement-bar,
      .shopify-section .announcement-bar,
      aside.announcement-bar { display: none !important; }
      .announcement-bar slideshow-arrows,
      .announcement-bar .slideshow-control { display: none !important; }

      /* Hide framework header (we use w1w-nav) */
      #header-group header-component,
      #header-group .header-section { display: none !important; }

      /* Footer dark */
      footer,
      footer .shopify-section,
      .w1w-footer { background: #131313 !important; color: #FFFFFF !important; }

      /* Material symbols */
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }

      /* Selection */
      ::selection { background: #CAFD00; color: #3a4a00; }

      /* Generic text normalization */
      a { color: inherit; }
    </style>
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}

    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      (function setHeaderHeighCustomProperties() {
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');
        if (!header || !headerGroup) return;
        const headerTopRow = header.querySelector('.header__row--top');
        const headerHeight = header.offsetHeight;
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);
        if (headerTopRow) {
          window.requestAnimationFrame(function () {
            document.body.style.setProperty('--top-row-height', `${headerTopRow.offsetHeight}px`);
          });
        }
        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }
        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');
        document.body.style.setProperty('--transparent-header-offset-boolean', !hasImmediateSection ? '1' : '0');
      })();

      (function setHeaderMenuStyle() {
        const headerComponent = document.querySelector('#header-component');
        if (headerComponent) {
          const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
          const overflowList = headerComponent?.querySelector('overflow-list');
          const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
          headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
        }
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    <footer>
      {% sections 'footer-group' %}
    </footer>

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}

    {%- comment -%} W1W Cart Drawer {%- endcomment -%}
    {% render 'w1w-cart-drawer' %}

    {%- comment -%} W1W Data + App JS {%- endcomment -%}
    <script src="{{ 'w1w-data.js' | asset_url }}" defer></script>
    <script src="{{ 'w1w-app.js' | asset_url }}" defer></script>
  </body>
</html>
